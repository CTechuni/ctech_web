---
import MentorLayout from '../../layouts/MentorLayout.astro';
---

<MentorLayout title="Eventos" subtitle="Gestiona los eventos de tu comunidad">
<div class="events-page">

    <!-- Toolbar -->
    <div class="toolbar">
        <div class="search-wrap">
            <i class="fas fa-search search-ico"></i>
            <input type="text" id="eventSearch" placeholder="Buscar por título o ubicación..." />
        </div>
        <div class="seg-ctrl" id="typeFilter">
            <button class="seg active" data-filter="all">Todos</button>
            <button class="seg" data-filter="virtual">Virtual</button>
            <button class="seg" data-filter="presencial">Presencial</button>
        </div>
        <button class="btn-primary" id="btnNewEvent">
            <i class="fas fa-plus"></i> Nuevo Evento
        </button>
    </div>

    <!-- Status legend -->
    <div class="status-legend">
        <span class="leg-item"><span class="st-dot st-draft"></span>Borrador</span>
        <span class="leg-item"><span class="st-dot st-pending"></span>En revisión</span>
        <span class="leg-item"><span class="st-dot st-approved"></span>Aprobado</span>
        <span class="leg-item"><span class="st-dot st-rejected"></span>Rechazado</span>
    </div>

    <!-- Grid -->
    <div class="events-grid" id="eventsGrid">
        <div class="loading-state">
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            <span>Cargando eventos...</span>
        </div>
    </div>
</div>

<!-- ══ Modal Crear / Editar Evento ══ -->
<div class="m-overlay" id="eventModal">
    <div class="m-card">
        <div class="m-header">
            <h4 id="mTitle">Nuevo Evento</h4>
            <button class="m-close" id="btnCloseModal"><i class="fas fa-times"></i></button>
        </div>

        <form id="eventForm" class="m-body">
            <input type="hidden" id="fId" />

            <!-- Título -->
            <div class="fg">
                <label>Título del evento <span class="req">*</span></label>
                <input type="text" id="fTitle" class="fi" placeholder="Ej: Workshop de React" required />
            </div>

            <!-- Descripción -->
            <div class="fg">
                <label>Descripción</label>
                <textarea id="fDesc" class="fi" rows="3" placeholder="¿De qué trata el evento? ¿Qué aprenderán?..."></textarea>
            </div>

            <!-- Fecha + Hora -->
            <div class="row2">
                <div class="fg">
                    <label>Fecha <span class="req">*</span></label>
                    <input type="date" id="fDate" class="fi" required />
                </div>
                <div class="fg">
                    <label>Hora</label>
                    <input type="time" id="fTime" class="fi" />
                </div>
            </div>

            <!-- Tipo + Capacidad -->
            <div class="row2">
                <div class="fg">
                    <label>Tipo de evento <span class="req">*</span></label>
                    <div class="type-toggle" id="typeToggle">
                        <button type="button" class="type-btn active" data-val="virtual">
                            <i class="fas fa-video"></i> Virtual
                        </button>
                        <button type="button" class="type-btn" data-val="presencial">
                            <i class="fas fa-map-marker-alt"></i> Presencial
                        </button>
                    </div>
                    <input type="hidden" id="fType" value="virtual" />
                </div>
                <div class="fg">
                    <label>Capacidad <span class="hint">(participantes)</span></label>
                    <input type="number" id="fCapacity" class="fi" placeholder="Ej: 50" min="1" />
                </div>
            </div>

            <!-- URL / Dirección -->
            <div class="fg">
                <label id="locationLabel">Link de la reunión</label>
                <input type="text" id="fLocation" class="fi" placeholder="https://meet.google.com/..." />
            </div>

            <!-- Visibilidad (cuando sea aprobado) -->
            <div class="fg">
                <label>Visibilidad <span class="hint">(cuando sea aprobado)</span></label>
                <div class="vis-toggle">
                    <label class="vis-opt">
                        <input type="radio" name="fVisibility" value="publico" checked />
                        <span class="vis-card">
                            <i class="fas fa-globe-americas"></i>
                            <strong>Público</strong>
                            <small>Visible para todos, incluso visitantes</small>
                        </span>
                    </label>
                    <label class="vis-opt">
                        <input type="radio" name="fVisibility" value="privado" />
                        <span class="vis-card">
                            <i class="fas fa-lock"></i>
                            <strong>Privado</strong>
                            <small>Solo para miembros registrados</small>
                        </span>
                    </label>
                </div>
            </div>

            <!-- Estado de publicación -->
            <div class="fg">
                <label>Publicación</label>
                <div class="pub-toggle" id="pubToggle">
                    <button type="button" class="pub-btn active" data-val="draft">
                        <i class="fas fa-file-alt"></i>
                        <div>
                            <strong>Guardar borrador</strong>
                            <small>Solo tú lo verás</small>
                        </div>
                    </button>
                    <button type="button" class="pub-btn" data-val="pending">
                        <i class="fas fa-paper-plane"></i>
                        <div>
                            <strong>Enviar a revisión</strong>
                            <small>El líder lo revisará</small>
                        </div>
                    </button>
                </div>
                <input type="hidden" id="fStatus" value="draft" />
            </div>

            <div class="m-footer">
                <button type="button" class="btn-ghost" id="btnCancelModal">Cancelar</button>
                <button type="submit" class="btn-primary" id="btnSubmit">
                    <i class="fas fa-check"></i> <span id="btnTxt">Crear Evento</span>
                </button>
            </div>
        </form>
    </div>
</div>
</MentorLayout>

<style>
.events-page { max-width: 1100px; display: flex; flex-direction: column; gap: 1.5rem; }

/* Toolbar */
.toolbar {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
}
.search-wrap { position: relative; flex: 1; min-width: 220px; }
.search-ico {
    position: absolute; left: 14px; top: 50%;
    transform: translateY(-50%); color: #94a3b8; font-size: .9rem;
}
.search-wrap input {
    width: 100%; box-sizing: border-box;
    padding: 10px 14px 10px 40px;
    border: 1px solid #e2e8f0; border-radius: 50px;
    font-size: .88rem; outline: none; background: #fff;
    transition: border-color .2s;
}
.search-wrap input:focus { border-color: #3b82f6; }

.seg-ctrl { display: flex; background: #f1f5f9; padding: 4px; border-radius: 12px; gap: 4px; }
.seg {
    border: none; background: transparent; padding: 7px 16px;
    border-radius: 8px; font-size: .82rem; font-weight: 600; color: #64748b; cursor: pointer;
}
.seg:hover { color: #0f172a; }
.seg.active { background: #fff; color: #0073ff; box-shadow: 0 2px 6px rgba(0,0,0,.05); }

.btn-primary {
    display: flex; align-items: center; gap: 7px;
    background: #0073ff; color: #fff; border: none;
    padding: 10px 18px; border-radius: 10px;
    font-weight: 700; font-size: .85rem; cursor: pointer;
    transition: background .2s; white-space: nowrap;
}
.btn-primary:hover { background: #0062cc; }
.btn-primary:disabled { background: #94a3b8; cursor: not-allowed; }

/* Legend */
.status-legend {
    display: flex; gap: 20px; flex-wrap: wrap;
}
.leg-item {
    display: flex; align-items: center; gap: 6px;
    font-size: .78rem; font-weight: 600; color: #64748b;
}
.st-dot {
    width: 8px; height: 8px; border-radius: 50%;
}
.st-draft    { background: #94a3b8; }
.st-pending  { background: #f59e0b; }
.st-approved { background: #22c55e; }
.st-rejected { background: #ef4444; }

/* Grid */
.events-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
}
.loading-state {
    grid-column: 1/-1; display: flex; align-items: center; gap: 10px;
    justify-content: center; padding: 3rem; color: #94a3b8; font-size: .88rem;
}
.empty-state {
    grid-column: 1/-1; text-align: center; padding: 4rem; color: #94a3b8;
}
.empty-state i { font-size: 2rem; margin-bottom: .75rem; display: block; }

/* Event Card */
.ev-card {
    background: #fff; border-radius: 18px; padding: 22px;
    border: 1px solid #f1f5f9; display: flex; flex-direction: column; gap: 14px;
    transition: all .3s; position: relative;
}
.ev-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,.06); }
.ev-card.is-draft    { border-left: 3px solid #94a3b8; }
.ev-card.is-pending  { border-left: 3px solid #f59e0b; }
.ev-card.is-rejected { border-left: 3px solid #ef4444; }

.card-top { display: flex; justify-content: space-between; align-items: flex-start; }

.badges { display: flex; gap: 6px; flex-wrap: wrap; }
.badge-type {
    font-size: .65rem; font-weight: 800; padding: 3px 10px;
    border-radius: 20px; text-transform: uppercase; letter-spacing: .04em;
}
.badge-virtual    { background: #eff6ff; color: #3b82f6; }
.badge-presencial { background: #fdf2f8; color: #db2777; }
.badge-publico    { background: #dcfce7; color: #15803d; }
.badge-privado    { background: #f1f5f9; color: #64748b; }
.badge-draft      { background: #f1f5f9; color: #64748b; }
.badge-pending    { background: #fef3c7; color: #d97706; }
.badge-approved   { background: #dcfce7; color: #15803d; }
.badge-rejected   { background: #fee2e2; color: #dc2626; }

.date-box { text-align: right; line-height: 1; }
.date-num { font-size: 1.8rem; font-weight: 800; color: #0073ff; display: block; }
.date-mon { font-size: .7rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; }

.card-body h3 { margin: 0 0 6px; font-size: 1rem; font-weight: 700; color: #0f172a; line-height: 1.3; }
.card-body p  { margin: 0; font-size: .83rem; color: #64748b; line-height: 1.5;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

.card-meta {
    display: flex; flex-wrap: wrap; gap: 10px;
    padding-top: 12px; border-top: 1px dashed #f1f5f9; margin-top: auto;
}
.meta-it { display: flex; align-items: center; gap: 5px; font-size: .78rem; color: #94a3b8; font-weight: 500; }
.meta-it i { font-size: .8rem; }
.meta-link {
    font-size: .75rem; font-weight: 600; color: #0073ff; text-decoration: none;
    display: flex; align-items: center; gap: 4px; margin-left: auto;
}
.meta-link:hover { text-decoration: underline; }

.rejected-msg {
    font-size: .78rem; color: #dc2626; background: #fee2e2;
    border-radius: 8px; padding: 6px 10px; margin-top: 4px;
    display: flex; align-items: center; gap: 5px;
}

.card-actions {
    position: absolute; top: 14px; right: 14px;
    display: flex; gap: 6px;
}
.btn-ic {
    width: 28px; height: 28px; border-radius: 7px;
    border: 1px solid #e2e8f0; background: #fff; cursor: pointer;
    font-size: .72rem; color: #94a3b8;
    display: flex; align-items: center; justify-content: center; transition: all .2s;
}
.btn-ic:hover { color: #0073ff; border-color: #0073ff; }
.btn-ic.del:hover { color: #ef4444; border-color: #ef4444; }

/* Modal */
.m-overlay {
    position: fixed; inset: 0;
    background: rgba(15,23,42,.55); backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    z-index: 3000; padding: 20px;
}
.m-overlay.open { display: flex; }
.m-card {
    background: #fff; border-radius: 20px;
    width: 100%; max-width: 600px; max-height: 92vh; overflow-y: auto;
    box-shadow: 0 25px 50px rgba(0,0,0,.15);
}
.m-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 22px 28px 18px; border-bottom: 1px solid #f1f5f9;
    position: sticky; top: 0; background: #fff; z-index: 1;
}
.m-header h4 { margin: 0; font-size: 1.1rem; font-weight: 800; color: #0f172a; }
.m-close {
    background: #f1f5f9; border: none; width: 32px; height: 32px;
    border-radius: 8px; cursor: pointer; color: #64748b;
    display: flex; align-items: center; justify-content: center;
}
.m-close:hover { background: #e2e8f0; }

.m-body { padding: 22px 28px; display: flex; flex-direction: column; gap: 16px; }

.fg { display: flex; flex-direction: column; gap: 6px; }
.fg label { font-size: .8rem; font-weight: 700; color: #475569; }
.fi {
    border: 1px solid #e2e8f0; border-radius: 10px;
    padding: 10px 13px; font-size: .88rem; color: #1e293b;
    font-family: inherit; outline: none; width: 100%; box-sizing: border-box; transition: border-color .2s;
}
.fi:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.1); }
textarea.fi { resize: vertical; }
.req  { color: #ef4444; }
.hint { font-weight: 400; color: #94a3b8; }
.row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

/* Tipo toggle */
.type-toggle { display: flex; gap: 0; border: 1px solid #e2e8f0; border-radius: 10px; overflow: hidden; }
.type-btn {
    flex: 1; padding: 9px 0; font-size: .82rem; font-weight: 600;
    background: #fff; border: none; color: #64748b; cursor: pointer; transition: all .2s;
    display: flex; align-items: center; justify-content: center; gap: 6px;
}
.type-btn:not(:last-child) { border-right: 1px solid #e2e8f0; }
.type-btn.active { background: #0073ff; color: #fff; }

/* Visibilidad */
.vis-toggle { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.vis-opt { cursor: pointer; }
.vis-opt input[type="radio"] { display: none; }
.vis-card {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    border: 2px solid #e2e8f0; border-radius: 12px; padding: 12px 10px;
    text-align: center; transition: all .2s; background: #fff;
}
.vis-card i      { font-size: 1.2rem; color: #94a3b8; margin-bottom: 3px; }
.vis-card strong { font-size: .85rem; color: #475569; font-weight: 700; }
.vis-card small  { font-size: .7rem; color: #94a3b8; }
.vis-opt input:checked + .vis-card { border-color: #0073ff; background: #f0f7ff; }
.vis-opt input:checked + .vis-card i      { color: #0073ff; }
.vis-opt input:checked + .vis-card strong { color: #0073ff; }
.vis-opt:last-child input:checked + .vis-card {
    border-color: #64748b; background: #f8fafc;
}
.vis-opt:last-child input:checked + .vis-card i      { color: #64748b; }
.vis-opt:last-child input:checked + .vis-card strong { color: #475569; }

/* Publicación toggle */
.pub-toggle { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.pub-btn {
    display: flex; align-items: center; gap: 10px;
    border: 2px solid #e2e8f0; border-radius: 12px; padding: 12px 14px;
    background: #fff; cursor: pointer; transition: all .2s; text-align: left;
}
.pub-btn i { font-size: 1.3rem; color: #94a3b8; flex-shrink: 0; }
.pub-btn div { display: flex; flex-direction: column; gap: 2px; }
.pub-btn strong { font-size: .82rem; font-weight: 700; color: #475569; }
.pub-btn small  { font-size: .7rem; color: #94a3b8; }
.pub-btn.active { border-color: #0073ff; background: #f0f7ff; }
.pub-btn.active i      { color: #0073ff; }
.pub-btn.active strong { color: #0073ff; }

.m-footer {
    display: flex; justify-content: flex-end; gap: 10px;
    padding: 16px 28px 22px; border-top: 1px solid #f1f5f9;
    position: sticky; bottom: 0; background: #fff;
}
.btn-ghost {
    background: #f1f5f9; border: none; padding: 10px 20px;
    border-radius: 10px; font-weight: 600; font-size: .88rem; cursor: pointer; color: #64748b;
}

@media(max-width: 1024px) { .events-grid { grid-template-columns: repeat(2, 1fr); } }
@media(max-width: 640px)  {
    .events-grid { grid-template-columns: 1fr; }
    .toolbar { flex-direction: column; align-items: stretch; }
    .row2 { grid-template-columns: 1fr; }
    .pub-toggle { grid-template-columns: 1fr; }
}
</style>

<script>
import { AuthManager, authManager } from '../../utils/auth.js';

let allEvents  = [];
let activeType = 'all';
let editingId  = null;

const MONTHS = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

const STATUS_MAP = {
    draft:    { label: 'Borrador',    cls: 'badge-draft',    cardCls: 'is-draft' },
    pending:  { label: 'En revisión', cls: 'badge-pending',  cardCls: 'is-pending' },
    approved: { label: 'Aprobado',    cls: 'badge-approved', cardCls: '' },
    rejected: { label: 'Rechazado',   cls: 'badge-rejected', cardCls: 'is-rejected' },
};

// ── Carga ────────────────────────────────────────────────────────────────────
async function init() {
    const data = await AuthManager.fetch('/events/my');
    allEvents  = Array.isArray(data) ? data : [];
    render();
}

// ── Render ───────────────────────────────────────────────────────────────────
function render() {
    const grid = document.getElementById('eventsGrid');
    const term = (document.getElementById('eventSearch') as HTMLInputElement).value.toLowerCase();

    const filtered = allEvents.filter(ev => {
        const matchTerm = ev.title.toLowerCase().includes(term) ||
                          (ev.location || '').toLowerCase().includes(term);
        const type = (ev.event_type || '').toLowerCase();
        const matchType = activeType === 'all' || type === activeType;
        return matchTerm && matchType;
    });

    if (!filtered.length) {
        grid.innerHTML = `
            <div class="empty-state">
                <i class="fas fa-calendar-times"></i>
                No se encontraron eventos.
            </div>`;
        return;
    }

    grid.innerHTML = filtered.map(ev => {
        const d     = new Date((ev.event_date || '') + 'T00:00:00');
        const day   = d.getDate();
        const mon   = MONTHS[d.getMonth()] || '';
        const type  = (ev.event_type || 'virtual').toLowerCase();
        const typeLabel = type === 'presencial' ? 'Presencial' : 'Virtual';
        const typeCls   = type === 'presencial' ? 'badge-presencial' : 'badge-virtual';

        const stInfo    = STATUS_MAP[ev.status] || STATUS_MAP.pending;
        const visCls    = ev.visibility === 'privado' ? 'badge-privado' : 'badge-publico';
        const visLabel  = ev.visibility === 'privado' ? '🔒 Privado' : '🌐 Público';

        // Solo se puede editar/eliminar en draft o pending
        const canEdit = ev.status === 'draft' || ev.status === 'pending';

        const locationHtml = ev.location
            ? (ev.event_type === 'virtual'
                ? `<a class="meta-link" href="${ev.location}" target="_blank" rel="noopener"><i class="fas fa-external-link-alt"></i> Unirse</a>`
                : `<span class="meta-it"><i class="fas fa-map-marker-alt"></i> ${ev.location.substring(0, 30)}${ev.location.length > 30 ? '…' : ''}</span>`)
            : '';

        const rejectedMsg = ev.status === 'rejected'
            ? `<div class="rejected-msg"><i class="fas fa-times-circle"></i> Rechazado por el líder. Puedes editar y reenviar a revisión.</div>` : '';

        return `
        <div class="ev-card ${stInfo.cardCls}">
            ${canEdit ? `
            <div class="card-actions">
                <button class="btn-ic" onclick="openEdit(${ev.id})" title="Editar"><i class="fas fa-pencil-alt"></i></button>
                <button class="btn-ic del" onclick="deleteEvent(${ev.id})" title="Eliminar"><i class="fas fa-trash"></i></button>
            </div>` : ''}
            <div class="card-top">
                <div class="badges">
                    <span class="badge-type ${typeCls}">${typeLabel}</span>
                    <span class="badge-type ${stInfo.cls}">${stInfo.label}</span>
                    ${ev.status === 'approved' ? `<span class="badge-type ${visCls}">${visLabel}</span>` : ''}
                </div>
                <div class="date-box">
                    <span class="date-num">${day}</span>
                    <span class="date-mon">${mon}</span>
                </div>
            </div>
            <div class="card-body">
                <h3>${ev.title}</h3>
                <p>${ev.description || 'Sin descripción.'}</p>
                ${rejectedMsg}
            </div>
            <div class="card-meta">
                ${ev.event_time ? `<span class="meta-it"><i class="fas fa-clock"></i> ${String(ev.event_time).substring(0,5)}h</span>` : ''}
                ${ev.capacity  ? `<span class="meta-it"><i class="fas fa-users"></i> ${ev.capacity}</span>` : ''}
                ${locationHtml}
            </div>
        </div>`;
    }).join('');
}

// ── Eliminar ─────────────────────────────────────────────────────────────────
window.deleteEvent = async function(id) {
    if (!confirm('¿Eliminar este evento?')) return;
    const res = await AuthManager.fetch(`/events/${id}`, { method: 'DELETE' });
    if (res !== null) {
        allEvents = allEvents.filter(e => e.id !== id);
        render();
    }
};

// ── Modal ─────────────────────────────────────────────────────────────────────
function openModal(ev = null) {
    editingId = ev?.id || null;
    document.getElementById('mTitle').textContent = ev ? 'Editar Evento' : 'Nuevo Evento';
    document.getElementById('btnTxt').textContent = ev ? 'Guardar Cambios' : 'Crear Evento';
    document.getElementById('fId').value       = ev?.id || '';
    document.getElementById('fTitle').value    = ev?.title || '';
    document.getElementById('fDesc').value     = ev?.description || '';
    document.getElementById('fDate').value     = ev?.event_date || '';
    document.getElementById('fTime').value     = ev?.event_time ? String(ev.event_time).substring(0,5) : '';
    document.getElementById('fLocation').value = ev?.location || '';
    document.getElementById('fCapacity').value = ev?.capacity || '';

    // tipo
    const type = (ev?.event_type || 'virtual').toLowerCase();
    document.getElementById('fType').value = type;
    document.querySelectorAll('.type-btn').forEach(b => b.classList.toggle('active', b.dataset.val === type));
    updateLocationLabel(type);

    // visibilidad
    const vis = ev?.visibility || 'publico';
    document.querySelectorAll('input[name="fVisibility"]').forEach(r => { r.checked = r.value === vis; });

    // estado de publicación: si era rechazado, permitir reenviar como pending
    const status = ev?.status === 'approved' ? 'pending' : (ev?.status || 'draft');
    document.getElementById('fStatus').value = status;
    document.querySelectorAll('.pub-btn').forEach(b => b.classList.toggle('active', b.dataset.val === status));

    document.getElementById('eventModal').classList.add('open');
    document.getElementById('fTitle').focus();
}

window.openEdit = function(id) {
    const ev = allEvents.find(e => e.id === id);
    if (ev) openModal(ev);
};

function closeModal() {
    document.getElementById('eventModal').classList.remove('open');
    document.getElementById('eventForm').reset();
    editingId = null;
    document.querySelectorAll('.type-btn').forEach(b => b.classList.toggle('active', b.dataset.val === 'virtual'));
    document.getElementById('fType').value = 'virtual';
    updateLocationLabel('virtual');
    // reset pub toggle
    document.querySelectorAll('.pub-btn').forEach(b => b.classList.toggle('active', b.dataset.val === 'draft'));
    document.getElementById('fStatus').value = 'draft';
}

function updateLocationLabel(type) {
    document.getElementById('locationLabel').textContent =
        type === 'virtual' ? 'Link de la reunión' : 'Dirección del lugar';
    document.getElementById('fLocation').placeholder =
        type === 'virtual' ? 'https://meet.google.com/...' : 'Calle 123, Ciudad...';
}

// Tipo toggle
document.getElementById('typeToggle').addEventListener('click', e => {
    const btn = e.target.closest('.type-btn');
    if (!btn) return;
    document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('fType').value = btn.dataset.val;
    updateLocationLabel(btn.dataset.val);
});

// Pub toggle
document.getElementById('pubToggle').addEventListener('click', e => {
    const btn = e.target.closest('.pub-btn');
    if (!btn) return;
    document.querySelectorAll('.pub-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('fStatus').value = btn.dataset.val;
});

// ── Submit ────────────────────────────────────────────────────────────────────
document.getElementById('eventForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = document.getElementById('btnSubmit');
    btn.disabled = true;

    const payload = {
        title:       (document.getElementById('fTitle') as HTMLInputElement).value.trim(),
        description: (document.getElementById('fDesc') as HTMLTextAreaElement).value.trim() || null,
        event_date:  (document.getElementById('fDate') as HTMLInputElement).value,
        event_time:  (document.getElementById('fTime') as HTMLInputElement).value || null,
        event_type:  (document.getElementById('fType') as HTMLInputElement).value,
        location:    (document.getElementById('fLocation') as HTMLInputElement).value.trim() || null,
        capacity:    parseInt((document.getElementById('fCapacity') as HTMLInputElement).value) || null,
        visibility:  (document.querySelector('input[name="fVisibility"]:checked') as HTMLInputElement)?.value || 'publico',
        status:      (document.getElementById('fStatus') as HTMLInputElement).value,
    };

    try {
        let result;
        if (editingId) {
            result = await AuthManager.fetch(`/events/${editingId}`, {
                method: 'PUT', body: JSON.stringify(payload),
            });
            if (result) {
                const idx = allEvents.findIndex(e => e.id === editingId);
                if (idx !== -1) allEvents[idx] = result;
            }
        } else {
            result = await AuthManager.fetch('/events/', {
                method: 'POST', body: JSON.stringify(payload),
            });
            if (result) allEvents.unshift(result);
        }
        if (result) { render(); closeModal(); }
    } catch(err) {
        alert('Error al guardar: ' + err.message);
    } finally {
        btn.disabled = false;
    }
});

// ── Eventos UI ────────────────────────────────────────────────────────────────
document.getElementById('btnNewEvent').addEventListener('click',  () => openModal());
document.getElementById('btnCloseModal').addEventListener('click', closeModal);
document.getElementById('btnCancelModal').addEventListener('click', closeModal);
document.getElementById('eventModal').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeModal();
});
document.getElementById('eventSearch').addEventListener('input', render);
document.querySelectorAll('.seg').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.seg').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeType = btn.dataset.filter;
        render();
    });
});

init();
</script>
