---
// src/pages/mentor/events.astro
import MentorLayout from '../../layouts/MentorLayout.astro';
---

<MentorLayout title="Eventos" subtitle="Calendario Global de Eventos y Talleres">
    <div class="events-container">
        <!-- Dashboard Header Actions -->
        <div class="events-toolbar">
            <div class="search-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="search-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
                <input type="text" id="eventSearch" placeholder="Buscar eventos por título o ubicación..." />
            </div>

            <div class="segmented-control" id="typeFilter">
                <button class="seg-btn active" data-filter="all">Todos</button>
                <button class="seg-btn" data-filter="virtual">Virtual</button>
                <button class="seg-btn" data-filter="presencial">Presencial</button>
            </div>
        </div>

        <!-- Events Grid -->
        <div class="events-grid" id="eventsGrid">
            <!-- Shimmer/Loading items -->
            <div class="loading-placeholder">
                <div class="spinner"></div>
                <p>Cargando calendario de eventos...</p>
            </div>
        </div>
    </div>
</MentorLayout>

<style>
    .events-container {
        max-width: 1200px;
    }

    /* Toolbar */
    .events-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 2.5rem;
    }

    .search-wrapper {
        position: relative;
        flex: 1;
        max-width: 400px;
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        width: 18px;
        height: 18px;
        color: #94a3b8;
    }

    .search-wrapper input {
        width: 100%;
        padding: 12px 14px 12px 42px;
        border: 1px solid #e2e8f0;
        border-radius: 50px;
        font-size: 0.9rem;
        background: white;
        outline: none;
        transition: all 0.2s;
    }

    .search-wrapper input:focus {
        border-color: var(--color-azure-radiant);
        box-shadow: 0 0 0 4px rgba(0, 115, 255, 0.08);
    }

    .segmented-control {
        display: flex;
        background: #f1f5f9;
        padding: 4px;
        border-radius: 12px;
        gap: 4px;
    }

    .seg-btn {
        border: none;
        background: transparent;
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #64748b;
        cursor: pointer;
        transition: all 0.2s;
    }

    .seg-btn:hover { color: #0f172a; }

    .seg-btn.active {
        background: white;
        color: var(--color-azure-radiant);
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    /* Grid */
    .events-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    @media (max-width: 1024px) {
        .events-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .events-toolbar { flex-direction: column; align-items: stretch; }
        .search-wrapper { max-width: 100%; }
        .events-grid { grid-template-columns: 1fr; }
    }

    /* Event Card (Premium) */
    :global(.event-card) {
        background: white;
        border-radius: 20px;
        padding: 24px;
        border: 1px solid #f1f5f9;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

    :global(.event-card:hover) {
        transform: translateY(-6px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        border-color: #e0f2fe;
    }

    :global(.card-top) {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    :global(.event-badge) {
        font-size: 0.7rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 40px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    :global(.badge-virtual), :global(.badge-online) { background: #eff6ff; color: #3b82f6; }
    :global(.badge-presencial) { background: #fdf2f8; color: #db2777; }

    :global(.event-date-box) {
        text-align: right;
        display: flex;
        flex-direction: column;
        line-height: 1;
    }

    :global(.date-num) {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--color-azure-radiant);
    }

    :global(.date-txt) {
        font-size: 0.75rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
    }

    :global(.card-body h3) {
        font-size: 1.15rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 8px 0;
        line-height: 1.4;
    }

    :global(.event-description) {
        font-size: 0.88rem;
        color: #64748b;
        margin: 0;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    :global(.card-footer-meta) {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-top: 16px;
        border-top: 1.5px dashed #f1f5f9;
        margin-top: auto;
    }

    :global(.meta-item) {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        color: #94a3b8;
    }

    :global(.meta-item svg) { width: 15px; height: 15px; color: #cbd5e1; }

    :global(.capacity-indicator) {
        margin-left: auto;
        background: #f8fafc;
        padding: 4px 8px;
        border-radius: 6px;
    }

    /* Loading state */
    .loading-placeholder {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 100px 0;
        color: #94a3b8;
    }

    .spinner {
        width: 32px;
        height: 32px;
        border: 4px solid #f1f5f9;
        border-top-color: var(--color-azure-radiant);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
    import { authManager as auth } from "../../utils/auth.js";

    let allEvents = [];
    let activeFilter = 'all';

    async function init() {
        try {
            // Fetch real events
            const data = await auth.get('events');
            allEvents = data || [];

            // Mock fallback for UI demonstration
            if (allEvents.length === 0) {
                allEvents = [
                    { title: 'Workshop de Astro para Mentores', event_date: '2026-03-24', description: 'Capacitación avanzada sobre el ecosistema Astro y cómo mentorizar a nuevos estudiantes.', location: 'Zoom Meet', event_type: 'virtual', capacity: 30, event_time: '18:00' },
                    { title: 'Meetup CTech: Medellín', event_date: '2026-04-05', description: 'Encuentro presencial para establecer contactos y compartir experiencias de tecnología.', location: 'Ruta N, Medellín', event_type: 'presencial', capacity: 100, event_time: '16:30' },
                    { title: 'Taller de TypeScript Avanzado', event_date: '2026-03-15', description: 'Profundizando en tipos genéricos y decoradores para proyectos a gran escala.', location: 'Discord Community Lab', event_type: 'virtual', capacity: 50, event_time: '19:00' }
                ];
            }

            renderGrid();
        } catch (err) {
            console.error('Failure loading events', err);
            const grid = document.getElementById('eventsGrid');
            if (grid) grid.innerHTML = '<p>Error al sincronizar el calendario. Intente más tarde.</p>';
        }
    }

    function renderGrid() {
        const grid = document.getElementById('eventsGrid');
        const searchTerm = (document.getElementById('eventSearch') as HTMLInputElement)?.value.toLowerCase() || '';
        
        if (!grid) return;

        const filtered = allEvents.filter(ev => {
            const matchesSearch = ev.title.toLowerCase().includes(searchTerm) || ev.location.toLowerCase().includes(searchTerm);
            
            let typeRaw = `${ev.event_type || ''} ${ev.type_event || ''} ${ev.location || ''}`.toLowerCase();
            let normalizedType = typeRaw.includes('presencial') ? 'presencial' : 'virtual';
            
            const matchesType = activeFilter === 'all' || normalizedType === activeFilter;
            return matchesSearch && matchesType;
        });

        if (filtered.length === 0) {
            grid.innerHTML = '<p style="grid-column: 1/-1; text-align: center; color: #94a3b8;">No se encontraron eventos con los criterios actuales.</p>';
            return;
        }

        grid.innerHTML = filtered.map(ev => {
            const date = new Date(ev.event_date + 'T00:00:00');
            const dayNum = date.getDate();
            const monthText = date.toLocaleString('es', { month: 'short' }).toUpperCase();
            
            let typeRaw = `${ev.event_type || ''} ${ev.type_event || ''} ${ev.location || ''}`.toLowerCase();
            let type = typeRaw.includes('presencial') ? 'presencial' : 'virtual';
            
            const typeClass = type === 'virtual' ? 'badge-virtual' : 'badge-presencial';
            const typeLabel = type === 'virtual' ? 'Virtual' : 'Presencial';

            return `
                <div class="event-card">
                    <div class="card-top">
                        <span class="event-badge ${typeClass}">${typeLabel}</span>
                        <div class="event-date-box">
                            <span class="date-num">${dayNum}</span>
                            <span class="date-txt">${monthText}</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <h3>${ev.title}</h3>
                        <p class="event-description">${ev.description}</p>
                    </div>
                    <div class="card-footer-meta">
                        <div class="meta-item">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                            </svg>
                            <span>${ev.event_time || '18:00'}h</span>
                        </div>
                        <div class="meta-item">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                            </svg>
                            <span>${ev.location.split(',')[0]}</span>
                        </div>
                        <div class="meta-item capacity-indicator">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a5.97 5.97 0 0 0-.942 3.197M12 10.5a3.375 3.375 0 1 0 0-6.75 3.375 3.375 0 0 0 0 6.75ZM2.625 18c0-1.113.285-2.16.786-3.07a4.125 4.125 0 0 1 3.238-2.228M2.625 18c.007.244.025.487.052.729A11.91 11.91 0 0 0 12 21c2.17 0 4.207-.576 5.963-1.584A6.062 6.062 0 0 1 18 18.719m-15.375 0a4.188 4.188 0 0 1-.375-1.75c0-1.113.285-2.16.786-3.07Zm12.188-9.75a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                            </svg>
                            <span>${ev.capacity}</span>
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    }

    // Listeners
    document.getElementById('eventSearch')?.addEventListener('input', renderGrid);
    
    document.querySelectorAll('.seg-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.seg-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activeFilter = btn.getAttribute('data-filter') || 'all';
            renderGrid();
        });
    });

    init();
</script>
