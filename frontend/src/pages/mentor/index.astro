---
// src/pages/mentor/index.astro
import MentorLayout from '../../layouts/MentorLayout.astro';
---

<MentorLayout title="Mis Cursos" subtitle="Gestiona tu contenido educativo">
    <div class="mentor-dashboard">

        <!-- ── Stats ── -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon icon-indigo"><i class="fas fa-book"></i></div>
                <div class="stat-body">
                    <span class="stat-val" id="statCourses">—</span>
                    <span class="stat-lbl">Cursos creados</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-emerald"><i class="fas fa-users"></i></div>
                <div class="stat-body">
                    <span class="stat-val" id="statStudents">—</span>
                    <span class="stat-lbl">Estudiantes activos</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-amber"><i class="fas fa-layer-group"></i></div>
                <div class="stat-body">
                    <span class="stat-val" id="statModules">—</span>
                    <span class="stat-lbl">Módulos totales</span>
                </div>
            </div>
        </div>

        <!-- ── Panel de cursos ── -->
        <div class="courses-panel">
            <div class="panel-top">
                <h3>Mis Cursos</h3>
                <button class="btn-primary" id="btnNewCourse">
                    <i class="fas fa-plus"></i> Nuevo Curso
                </button>
            </div>
            <div id="courseList">
                <div class="loading-msg">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span>Cargando cursos...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         Modal Crear / Editar Curso
    ══════════════════════════════════════════ -->
    <div class="m-overlay" id="courseModal">
        <div class="m-card">
            <div class="m-header">
                <h4 id="mTitle">Nuevo Curso</h4>
                <button class="m-close" id="btnCloseModal"><i class="fas fa-times"></i></button>
            </div>

            <form id="courseForm" class="m-body">
                <input type="hidden" id="fId" />

                <!-- Título -->
                <div class="fg">
                    <label>Título del curso <span class="req">*</span></label>
                    <input type="text" id="fTitle" class="fi"
                        placeholder="Ej: Introducción a React con TypeScript" required />
                </div>

                <!-- Categoría + Nivel -->
                <div class="row2">
                    <div class="fg">
                        <label>Categoría <span class="req">*</span></label>
                        <select id="fSpecialty" class="fi" required>
                            <option value="">Selecciona una categoría...</option>
                        </select>
                    </div>
                    <div class="fg">
                        <label>Nivel <span class="req">*</span></label>
                        <div class="level-group" id="levelGroup">
                            <button type="button" class="level-btn active" data-val="basico">Básico</button>
                            <button type="button" class="level-btn" data-val="intermedio">Intermedio</button>
                            <button type="button" class="level-btn" data-val="avanzado">Avanzado</button>
                        </div>
                        <input type="hidden" id="fLevel" value="basico" />
                    </div>
                </div>

                <!-- Descripción -->
                <div class="fg">
                    <label>Descripción del curso</label>
                    <textarea id="fDesc" class="fi" rows="4"
                        placeholder="¿Qué aprenderán los estudiantes? ¿Cuál es el objetivo del curso?..."></textarea>
                </div>

                <!-- Tecnologías / herramientas -->
                <div class="fg">
                    <label>Tecnologías y herramientas</label>
                    <div class="chip-input-wrap" id="chipWrap">
                        <div class="chips" id="chipList"></div>
                        <input type="text" id="chipInput" class="chip-text-input"
                            placeholder="Escribe y presiona Enter o coma..." autocomplete="off" />
                    </div>
                    <span class="field-hint">Ej: React, TypeScript, Git, Figma…</span>
                </div>

                <!-- Estado -->
                <div class="fg">
                    <label>Estado del curso</label>
                    <div class="status-toggle">
                        <label class="status-opt">
                            <input type="radio" name="fStatus" value="draft" id="stDraft" />
                            <span class="status-card">
                                <i class="fas fa-pencil-alt"></i>
                                <strong>Borrador</strong>
                                <small>Guardado, no enviado</small>
                            </span>
                        </label>
                        <label class="status-opt">
                            <input type="radio" name="fStatus" value="pending" id="stPublish" checked />
                            <span class="status-card">
                                <i class="fas fa-paper-plane"></i>
                                <strong>Publicar</strong>
                                <small>Enviar al líder para revisión</small>
                            </span>
                        </label>
                    </div>
                </div>

                <div class="m-footer">
                    <button type="button" class="btn-ghost" id="btnCancelModal">Cancelar</button>
                    <button type="submit" class="btn-primary" id="btnSubmit">
                        <i class="fas fa-check"></i>
                        <span id="btnTxt">Crear Curso</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</MentorLayout>

<style>
/* ── Layout ─────────────────────────────────── */
.mentor-dashboard { display:flex; flex-direction:column; gap:1.75rem; max-width:1100px; }

/* ── Stats ──────────────────────────────────── */
.stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
.stat-card {
    background:#fff; border:1px solid #e8ecf0; border-radius:14px;
    padding:20px 22px; display:flex; align-items:center; gap:16px;
    box-shadow:0 1px 3px rgba(0,0,0,.05);
}
.stat-icon {
    width:48px; height:48px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    font-size:1.15rem; flex-shrink:0;
}
.icon-indigo  { background:#e0e7ff; color:#4338ca; }
.icon-emerald { background:#d1fae5; color:#059669; }
.icon-amber   { background:#fef3c7; color:#b45309; }
.stat-body { display:flex; flex-direction:column; }
.stat-val { font-size:1.7rem; font-weight:800; color:#0f172a; line-height:1.1; }
.stat-lbl { font-size:0.78rem; color:#64748b; font-weight:500; }

/* ── Panel ──────────────────────────────────── */
.courses-panel {
    background:#fff; border:1px solid #e8ecf0; border-radius:16px;
    box-shadow:0 1px 3px rgba(0,0,0,.05); overflow:hidden;
}
.panel-top {
    display:flex; justify-content:space-between; align-items:center;
    padding:20px 24px; border-bottom:1px solid #f1f5f9;
}
.panel-top h3 { margin:0; font-size:1rem; font-weight:700; color:#0f172a; }

.btn-primary {
    display:flex; align-items:center; gap:7px;
    background:#0073ff; color:#fff; border:none;
    padding:9px 18px; border-radius:10px;
    font-weight:700; font-size:0.85rem; cursor:pointer; transition:background .2s;
}
.btn-primary:hover  { background:#0062cc; }
.btn-primary:disabled { background:#94a3b8; cursor:not-allowed; }

.loading-msg {
    display:flex; align-items:center; gap:10px;
    justify-content:center; padding:3rem;
    color:#94a3b8; font-size:.88rem;
}
.empty-courses { text-align:center; padding:3.5rem 2rem; color:#94a3b8; }
.empty-courses i { font-size:2.2rem; margin-bottom:.75rem; display:block; }

/* ── Curso item ─────────────────────────────── */
.course-item { border-bottom:1px solid #f8fafc; }
.course-item:last-child { border-bottom:none; }
.course-row {
    display:flex; align-items:center; gap:14px;
    padding:16px 24px; cursor:pointer; transition:background .15s;
}
.course-row:hover { background:#f8fafc; }
.cr-info { flex:1; }
.cr-name {
    font-size:.95rem; font-weight:700; color:#1e293b;
    display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:4px;
}
.sbadge {
    font-size:.6rem; padding:2px 8px; border-radius:20px;
    font-weight:800; text-transform:uppercase; letter-spacing:.02em;
}
.sbadge.approved { background:#dcfce7; color:#15803d; }
.sbadge.pending  { background:#fef9c3; color:#a16207; }
.sbadge.rejected { background:#fee2e2; color:#b91c1c; }
.sbadge.draft    { background:#f1f5f9; color:#64748b; }

.cr-tags { display:flex; gap:5px; flex-wrap:wrap; }
.ctag {
    font-size:.7rem; background:rgba(59,130,246,.1);
    color:#3b82f6; padding:2px 8px; border-radius:6px; font-weight:600;
}
.cr-meta { display:flex; align-items:center; gap:14px; font-size:.8rem; color:#94a3b8; }
.cr-meta span { display:flex; align-items:center; gap:5px; }
.cr-actions { display:flex; gap:6px; }
.btn-icon {
    width:30px; height:30px; border-radius:8px;
    border:1px solid #e2e8f0; background:#fff;
    color:#94a3b8; cursor:pointer; font-size:.75rem;
    display:flex; align-items:center; justify-content:center; transition:all .2s;
}
.btn-icon:hover     { color:#0073ff; border-color:#0073ff; }
.btn-icon.del:hover { color:#ef4444; border-color:#ef4444; }
.chevron-icon { color:#cbd5e1; font-size:.78rem; transition:transform .3s; }
.course-item.open .chevron-icon { transform:rotate(180deg); }

/* ── Cuerpo acordeón ────────────────────────── */
.course-body {
    max-height:0; overflow:hidden;
    transition:max-height .35s ease;
    background:#fafcff; border-top:0;
}
.course-item.open .course-body { max-height:800px; border-top:1px solid #f1f5f9; }
.body-inner { padding:18px 24px 20px; }
.mod-list-title {
    font-size:.75rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.05em; color:#94a3b8; margin-bottom:10px;
}

/* módulo card */
.mod-card {
    display:flex; align-items:flex-start; gap:12px;
    background:#fff; border:1px solid #f1f5f9;
    border-radius:10px; padding:10px 14px; margin-bottom:7px;
}
.mod-type-icon {
    width:34px; height:34px; border-radius:8px;
    display:flex; align-items:center; justify-content:center;
    font-size:.95rem; flex-shrink:0;
}
.type-pdf   { background:#fee2e2; color:#dc2626; }
.type-image { background:#d1fae5; color:#059669; }
.type-book  { background:#ede9fe; color:#7c3aed; }
.type-video { background:#dbeafe; color:#2563eb; }
.type-link  { background:#f1f5f9; color:#64748b; }
.mod-text { flex:1; min-width:0; }
.mod-title { font-size:.88rem; font-weight:700; color:#1e293b; }
.mod-desc  { font-size:.77rem; color:#94a3b8; margin-top:2px; }
.mod-link  {
    font-size:.75rem; font-weight:600; color:#0073ff;
    text-decoration:none; white-space:nowrap;
    display:flex; align-items:center; gap:4px;
}
.mod-link:hover { text-decoration:underline; }
.mod-del-btn {
    background:none; border:none; color:#cbd5e1;
    cursor:pointer; padding:2px 4px; font-size:.78rem; transition:color .2s;
}
.mod-del-btn:hover { color:#ef4444; }
.no-mods { font-size:.82rem; color:#cbd5e1; font-style:italic; padding:6px 0 10px; }

/* añadir módulo inline */
.add-mod-section { margin-top:14px; }
.add-mod-toggle {
    background:none; border:1px dashed #cbd5e1;
    color:#94a3b8; width:100%; padding:8px;
    border-radius:9px; cursor:pointer; font-size:.82rem;
    font-weight:600; display:flex; align-items:center;
    justify-content:center; gap:6px; transition:all .2s;
}
.add-mod-toggle:hover { border-color:#0073ff; color:#0073ff; background:#f0f7ff; }
.add-mod-form {
    display:none; flex-direction:column; gap:8px;
    margin-top:10px; padding:14px;
    background:#fff; border:1px solid #e2e8f0; border-radius:10px;
}
.add-mod-form.visible { display:flex; }
.add-mod-form .row2 { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.add-mod-form label { font-size:.75rem; font-weight:700; color:#64748b; }
.add-mod-form input, .add-mod-form select {
    border:1px solid #e2e8f0; border-radius:8px;
    padding:7px 11px; font-size:.83rem; color:#1e293b;
    font-family:inherit; outline:none; width:100%; box-sizing:border-box;
}
.add-mod-form input:focus, .add-mod-form select:focus { border-color:#3b82f6; }
.add-mod-actions { display:flex; justify-content:flex-end; gap:8px; margin-top:4px; }
.btn-sm-ghost {
    background:#f1f5f9; border:none; padding:6px 14px;
    border-radius:8px; font-size:.8rem; font-weight:600; color:#64748b; cursor:pointer;
}
.btn-sm-primary {
    background:#0073ff; color:#fff; border:none;
    padding:6px 14px; border-radius:8px; font-size:.8rem; font-weight:700; cursor:pointer;
}

/* ── Modal ──────────────────────────────────── */
.m-overlay {
    position:fixed; inset:0;
    background:rgba(15,23,42,.55); backdrop-filter:blur(4px);
    display:none; align-items:center; justify-content:center;
    z-index:3000; padding:20px;
}
.m-overlay.open { display:flex; }
.m-card {
    background:#fff; border-radius:20px;
    width:100%; max-width:580px; max-height:92vh; overflow-y:auto;
    box-shadow:0 25px 50px rgba(0,0,0,.15);
}
.m-header {
    display:flex; justify-content:space-between; align-items:center;
    padding:22px 28px 18px; border-bottom:1px solid #f1f5f9;
    position:sticky; top:0; background:#fff; z-index:1;
}
.m-header h4 { margin:0; font-size:1.1rem; font-weight:800; color:#0f172a; }
.m-close {
    background:#f1f5f9; border:none; width:32px; height:32px;
    border-radius:8px; cursor:pointer; color:#64748b;
    display:flex; align-items:center; justify-content:center; font-size:.85rem;
}
.m-close:hover { background:#e2e8f0; }

.m-body { padding:24px 28px; display:flex; flex-direction:column; gap:18px; }

.fg { display:flex; flex-direction:column; gap:6px; }
.fg label { font-size:.8rem; font-weight:700; color:#475569; }
.fi {
    border:1px solid #e2e8f0; border-radius:10px;
    padding:10px 13px; font-size:.88rem; color:#1e293b;
    font-family:inherit; outline:none; width:100%; box-sizing:border-box;
    transition:border-color .2s;
}
.fi:focus { border-color:#3b82f6; box-shadow:0 0 0 3px rgba(59,130,246,.1); }
textarea.fi { resize:vertical; }
.req  { color:#ef4444; }
.field-hint { font-size:.75rem; color:#94a3b8; }

.row2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; }

/* Nivel toggle */
.level-group { display:flex; gap:0; border:1px solid #e2e8f0; border-radius:10px; overflow:hidden; }
.level-btn {
    flex:1; padding:9px 0; font-size:.82rem; font-weight:600;
    background:#fff; border:none; color:#64748b; cursor:pointer; transition:all .2s;
}
.level-btn:not(:last-child) { border-right:1px solid #e2e8f0; }
.level-btn.active { background:#0073ff; color:#fff; }

/* Chip input */
.chip-input-wrap {
    border:1px solid #e2e8f0; border-radius:10px;
    padding:7px 10px; display:flex; flex-wrap:wrap; gap:6px;
    cursor:text; transition:border-color .2s; min-height:42px;
    align-items:center;
}
.chip-input-wrap:focus-within { border-color:#3b82f6; box-shadow:0 0 0 3px rgba(59,130,246,.1); }
.chip {
    display:flex; align-items:center; gap:5px;
    background:#e0e7ff; color:#3730a3;
    padding:3px 10px 3px 12px; border-radius:20px;
    font-size:.78rem; font-weight:700;
}
.chip-rm {
    background:none; border:none; color:#6366f1;
    cursor:pointer; font-size:.8rem; padding:0; line-height:1;
    display:flex; align-items:center;
}
.chip-rm:hover { color:#ef4444; }
.chip-text-input {
    border:none; outline:none; font-size:.85rem; color:#1e293b;
    font-family:inherit; flex:1; min-width:120px; padding:2px 4px; background:transparent;
}

/* Estado toggle */
.status-toggle { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.status-opt { cursor:pointer; }
.status-opt input[type="radio"] { display:none; }
.status-card {
    display:flex; flex-direction:column; align-items:center; gap:4px;
    border:2px solid #e2e8f0; border-radius:12px; padding:14px 10px;
    text-align:center; transition:all .2s; background:#fff;
}
.status-card i { font-size:1.3rem; color:#94a3b8; margin-bottom:4px; }
.status-card strong { font-size:.88rem; color:#475569; font-weight:700; }
.status-card small  { font-size:.72rem; color:#94a3b8; }
.status-opt input:checked + .status-card {
    border-color:#0073ff; background:#f0f7ff;
}
.status-opt input:checked + .status-card i      { color:#0073ff; }
.status-opt input:checked + .status-card strong { color:#0073ff; }

/* Draft highlight */
.status-opt:first-child input:checked + .status-card {
    border-color:#64748b; background:#f8fafc;
}
.status-opt:first-child input:checked + .status-card i      { color:#64748b; }
.status-opt:first-child input:checked + .status-card strong { color:#475569; }

.m-footer {
    display:flex; justify-content:flex-end; gap:10px;
    padding:16px 28px 22px; border-top:1px solid #f1f5f9;
    position:sticky; bottom:0; background:#fff;
}
.btn-ghost {
    background:#f1f5f9; border:none; padding:10px 20px;
    border-radius:10px; font-weight:600; font-size:.88rem;
    cursor:pointer; color:#64748b;
}

@media(max-width:768px) {
    .stats-row { grid-template-columns:1fr; }
    .cr-meta   { display:none; }
    .row2      { grid-template-columns:1fr; }
    .status-toggle { grid-template-columns:1fr 1fr; }
}
</style>

<script>
import { AuthManager } from '../../utils/auth.js';

const MOD_TYPES = {
    pdf:   { label:'PDF',    icon:'fa-file-pdf',   cls:'type-pdf'   },
    image: { label:'Imagen', icon:'fa-image',       cls:'type-image' },
    book:  { label:'Libro',  icon:'fa-book',        cls:'type-book'  },
    video: { label:'Video',  icon:'fa-play-circle', cls:'type-video' },
    link:  { label:'Enlace', icon:'fa-link',        cls:'type-link'  },
};

let courses      = [];
let chips        = [];   // tecnologías del modal
let editingId    = null;
let specialties  = [];

// ── Carga inicial ────────────────────────────────────────────────────────────
async function init() {
    const [metrics, coursesData, specsData] = await Promise.all([
        AuthManager.fetch('/metrics/mentor'),
        AuthManager.fetch('/courses/my'),
        fetch('http://localhost:8000/api/v1/specialties/').then(r => r.json()).catch(()=>[]),
    ]);

    if (metrics) {
        document.getElementById('statCourses').textContent  = metrics.total_courses  ?? 0;
        document.getElementById('statStudents').textContent = metrics.active_students ?? 0;
        document.getElementById('statModules').textContent  = metrics.total_modules  ?? 0;
    }
    courses    = Array.isArray(coursesData) ? coursesData : [];
    specialties = Array.isArray(specsData)  ? specsData   : [];
    populateSpecialties();
    renderCourses();
}

function populateSpecialties() {
    const sel = document.getElementById('fSpecialty');
    specialties.forEach(s => {
        const opt = document.createElement('option');
        opt.value       = s.id;
        opt.textContent = s.name;
        sel.appendChild(opt);
    });
}

// ── Render cursos ────────────────────────────────────────────────────────────
function renderCourses() {
    const el = document.getElementById('courseList');
    if (!courses.length) {
        el.innerHTML = `
            <div class="empty-courses">
                <i class="fas fa-book-open"></i>
                No tienes cursos aún. ¡Crea tu primer curso!
            </div>`;
        return;
    }

    const statusLabel = { approved:'Aprobado', pending:'En revisión', rejected:'Rechazado', draft:'Borrador' };
    const levelLabel  = { basico:'Básico', intermedio:'Intermedio', avanzado:'Avanzado' };

    el.innerHTML = courses.map(c => {
        const tags     = (c.technologies||[]).slice(0,5).map(t=>`<span class="ctag">${t}</span>`).join('');
        const modCount = (c.modules||[]).length;

        return `
        <div class="course-item" data-id="${c.id}">
            <div class="course-row" data-toggle="${c.id}">
                <div class="cr-info">
                    <div class="cr-name">
                        ${c.title}
                        <span class="sbadge ${c.status}">${statusLabel[c.status]||c.status}</span>
                    </div>
                    <div class="cr-tags">${tags}</div>
                </div>
                <div class="cr-meta">
                    <span><i class="fas fa-layer-group"></i> ${modCount} módulos</span>
                    <span><i class="fas fa-signal"></i> ${levelLabel[c.level]||c.level}</span>
                    ${c.specialty_name?`<span><i class="fas fa-tag"></i> ${c.specialty_name}</span>`:''}
                </div>
                <div class="cr-actions" onclick="event.stopPropagation()">
                    <button class="btn-icon" title="Editar" onclick="openEdit(${c.id})"><i class="fas fa-pencil-alt"></i></button>
                    <button class="btn-icon del" title="Eliminar" onclick="deleteCourse(${c.id})"><i class="fas fa-trash"></i></button>
                </div>
                <i class="fas fa-chevron-down chevron-icon"></i>
            </div>
            <div class="course-body">
                <div class="body-inner">
                    <div class="mod-list-title">Módulos</div>
                    <div id="modList-${c.id}">${renderModList(c.modules||[], c.id)}</div>
                    <div class="add-mod-section">
                        <button class="add-mod-toggle" onclick="toggleAddMod(${c.id})">
                            <i class="fas fa-plus"></i> Agregar módulo
                        </button>
                        <div class="add-mod-form" id="addModForm-${c.id}">
                            <div class="row2">
                                <div>
                                    <label>Título <span style="color:#ef4444">*</span></label>
                                    <input type="text" class="am-title" placeholder="Título del módulo" />
                                </div>
                                <div>
                                    <label>Tipo</label>
                                    <select class="am-type">
                                        <option value="pdf">📄 PDF</option>
                                        <option value="image">🖼️ Imagen</option>
                                        <option value="book">📚 Libro</option>
                                        <option value="video">🎥 Video</option>
                                        <option value="link" selected>🔗 Enlace</option>
                                    </select>
                                </div>
                            </div>
                            <div>
                                <label>URL del recurso</label>
                                <input type="url" class="am-url" placeholder="https://..." />
                            </div>
                            <div>
                                <label>Descripción <span style="color:#94a3b8;font-weight:400">(opcional)</span></label>
                                <input type="text" class="am-desc" placeholder="Breve descripción..." />
                            </div>
                            <div class="add-mod-actions">
                                <button class="btn-sm-ghost" onclick="toggleAddMod(${c.id})">Cancelar</button>
                                <button class="btn-sm-primary" onclick="saveModule(${c.id})">Guardar módulo</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>`;
    }).join('');

    document.querySelectorAll('[data-toggle]').forEach(row => {
        row.addEventListener('click', () => row.closest('.course-item').classList.toggle('open'));
    });
}

function renderModList(modules, courseId) {
    if (!modules.length) return `<p class="no-mods">Sin módulos aún.</p>`;
    return modules.map((m, i) => {
        const t = MOD_TYPES[m.type] || MOD_TYPES.link;
        return `
        <div class="mod-card">
            <div class="mod-type-icon ${t.cls}"><i class="fas ${t.icon}"></i></div>
            <div class="mod-text">
                <div class="mod-title">${m.title}</div>
                ${m.description ? `<div class="mod-desc">${m.description}</div>` : ''}
            </div>
            ${m.url ? `<a class="mod-link" href="${m.url}" target="_blank" rel="noopener">
                <i class="fas fa-external-link-alt"></i> Abrir
            </a>` : ''}
            <button class="mod-del-btn" onclick="deleteModule(${courseId},${i})">
                <i class="fas fa-times"></i>
            </button>
        </div>`;
    }).join('');
}

// ── Módulos inline ───────────────────────────────────────────────────────────
window.toggleAddMod = function(id) {
    const f = document.getElementById(`addModForm-${id}`);
    f.classList.toggle('visible');
    if (f.classList.contains('visible')) f.querySelector('.am-title').focus();
};

window.saveModule = async function(courseId) {
    const f     = document.getElementById(`addModForm-${courseId}`);
    const title = f.querySelector('.am-title').value.trim();
    if (!title) { alert('El título del módulo es obligatorio.'); return; }
    const newMod = {
        title,
        type:        f.querySelector('.am-type').value,
        url:         f.querySelector('.am-url').value.trim()  || null,
        description: f.querySelector('.am-desc').value.trim() || null,
    };
    const course = courses.find(c=>c.id===courseId);
    if (!course) return;
    const res = await AuthManager.fetch(`/courses/${courseId}`, {
        method:'PUT',
        body:JSON.stringify({ modules:[...(course.modules||[]), newMod] }),
    });
    if (res) {
        course.modules = res.modules;
        document.getElementById(`modList-${courseId}`).innerHTML = renderModList(course.modules, courseId);
        f.classList.remove('visible');
        f.querySelector('.am-title').value = '';
        f.querySelector('.am-url').value   = '';
        f.querySelector('.am-desc').value  = '';
        updateModStat();
    }
};

window.deleteModule = async function(courseId, idx) {
    if (!confirm('¿Eliminar este módulo?')) return;
    const course = courses.find(c=>c.id===courseId);
    if (!course) return;
    const res = await AuthManager.fetch(`/courses/${courseId}`, {
        method:'PUT',
        body:JSON.stringify({ modules: course.modules.filter((_,i)=>i!==idx) }),
    });
    if (res) {
        course.modules = res.modules;
        document.getElementById(`modList-${courseId}`).innerHTML = renderModList(course.modules, courseId);
        updateModStat();
    }
};

function updateModStat() {
    document.getElementById('statModules').textContent = courses.reduce((a,c)=>a+(c.modules?.length||0),0);
}

// ── Eliminar curso ───────────────────────────────────────────────────────────
window.deleteCourse = async function(id) {
    if (!confirm('¿Eliminar este curso? Esta acción no se puede deshacer.')) return;
    const res = await AuthManager.fetch(`/courses/${id}`, { method:'DELETE' });
    if (res !== null) {
        courses = courses.filter(c=>c.id!==id);
        document.getElementById('statCourses').textContent = courses.length;
        updateModStat();
        renderCourses();
    }
};

// ── Chip input (tecnologías) ─────────────────────────────────────────────────
function addChip(val) {
    const v = val.trim();
    if (!v || chips.includes(v)) return;
    chips.push(v);
    renderChips();
}

function removeChip(val) {
    chips = chips.filter(c=>c!==val);
    renderChips();
}

function renderChips() {
    const list = document.getElementById('chipList');
    list.innerHTML = chips.map(c=>`
        <span class="chip">
            ${c}
            <button type="button" class="chip-rm" onclick="removeChip('${c}')">
                <i class="fas fa-times"></i>
            </button>
        </span>`).join('');
}

window.removeChip = removeChip;

document.getElementById('chipInput').addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        const val = e.target.value;
        addChip(val);
        e.target.value = '';
    }
    if (e.key === 'Backspace' && !e.target.value && chips.length) {
        chips.pop();
        renderChips();
    }
});
document.getElementById('chipInput').addEventListener('blur', e => {
    if (e.target.value.trim()) { addChip(e.target.value); e.target.value = ''; }
});
document.getElementById('chipWrap').addEventListener('click', () => {
    document.getElementById('chipInput').focus();
});

// ── Nivel toggle ─────────────────────────────────────────────────────────────
document.getElementById('levelGroup').addEventListener('click', e => {
    const btn = e.target.closest('.level-btn');
    if (!btn) return;
    document.querySelectorAll('.level-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('fLevel').value = btn.dataset.val;
});

// ── Modal ────────────────────────────────────────────────────────────────────
function openModal(course = null) {
    editingId = course?.id || null;
    chips     = [...(course?.technologies || [])];

    document.getElementById('mTitle').textContent  = course ? 'Editar Curso' : 'Nuevo Curso';
    document.getElementById('btnTxt').textContent  = course ? 'Guardar Cambios' : 'Crear Curso';
    document.getElementById('fId').value           = course?.id || '';
    document.getElementById('fTitle').value        = course?.title || '';
    document.getElementById('fDesc').value         = course?.description || '';
    document.getElementById('fSpecialty').value    = course?.specialty_id || '';

    // nivel
    const level = course?.level || 'basico';
    document.getElementById('fLevel').value = level;
    document.querySelectorAll('.level-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.val === level);
    });

    // estado
    const status = course?.status || 'pending';
    const stId   = status === 'draft' ? 'stDraft' : 'stPublish';
    document.getElementById(stId).checked = true;
    const otherId = stId === 'stDraft' ? 'stPublish' : 'stDraft';
    document.getElementById(otherId).checked = false;

    renderChips();
    document.getElementById('courseModal').classList.add('open');
    document.getElementById('fTitle').focus();
}

window.openEdit = function(id) {
    const c = courses.find(c=>c.id===id);
    if (c) openModal(c);
};

function closeModal() {
    document.getElementById('courseModal').classList.remove('open');
    document.getElementById('courseForm').reset();
    chips     = [];
    editingId = null;
    renderChips();
    // reset nivel
    document.querySelectorAll('.level-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.val === 'basico');
    });
    document.getElementById('fLevel').value = 'basico';
}

// ── Submit ────────────────────────────────────────────────────────────────────
document.getElementById('courseForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = document.getElementById('btnSubmit');
    btn.disabled = true;

    const status     = document.querySelector('input[name="fStatus"]:checked')?.value || 'pending';
    const specialtyId = document.getElementById('fSpecialty').value;

    const payload = {
        title:        document.getElementById('fTitle').value.trim(),
        description:  document.getElementById('fDesc').value.trim() || null,
        specialty_id: specialtyId ? parseInt(specialtyId) : null,
        level:        document.getElementById('fLevel').value,
        technologies: [...chips],
        status,
        modules:       [],
        content_links: { pdfs:[], books:[], videos:[] },
    };

    try {
        let result;
        if (editingId) {
            result = await AuthManager.fetch(`/courses/${editingId}`, {
                method:'PUT', body:JSON.stringify(payload),
            });
            if (result) {
                const idx = courses.findIndex(c=>c.id===editingId);
                if (idx!==-1) courses[idx] = result;
            }
        } else {
            result = await AuthManager.fetch('/courses/', {
                method:'POST', body:JSON.stringify(payload),
            });
            if (result) {
                courses.unshift(result);
                document.getElementById('statCourses').textContent = courses.length;
            }
        }
        if (result) { renderCourses(); closeModal(); }
    } catch(err) {
        alert('Error al guardar: ' + err.message);
    } finally {
        btn.disabled = false;
    }
});

// ── Eventos ──────────────────────────────────────────────────────────────────
document.getElementById('btnNewCourse').addEventListener('click',  () => openModal());
document.getElementById('btnCloseModal').addEventListener('click', closeModal);
document.getElementById('btnCancelModal').addEventListener('click', closeModal);
document.getElementById('courseModal').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeModal();
});

init();
</script>
