<style>
    .comunidades {
        width: 100%;
        overflow: hidden;
        padding: 5rem 0 6rem 0;
        position: relative;
    }

    .carousel-container {
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    .carousel {
        display: flex;
        gap: 4rem;
        animation: scroll-horizontal 40s linear infinite;
    }

    .carousel-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.2rem;
        flex-shrink: 0;
        min-width: 120px;
    }

    .log-carousel {
        width: 100px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border-radius: 12px;
        padding: 0.5rem;
        box-shadow: 0 2px 8px rgb(255, 255, 255);
    }

    .logo-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .company-name {
        font-size: 0.8rem;
        font-weight: 500;
        color: #374151;
        text-align: center;
        margin: 0;
        white-space: nowrap;
    }
  
    @keyframes scroll-horizontal {
        0% {
            transform: translateX(100%);
        }
        100% {
            transform: translateX(-100%);
        }
    }

    /* Responsive */
    @media (max-width: 768px) {
        .carousel {
            gap: 2rem;
            animation: scroll-horizontal 18s linear infinite;
        }

        .carousel-item {
            min-width: 100px;
        }

        .log-carousel {
            width: 100px;
            height: 100px;
        }

        .company-name {
            font-size: 0.7rem;
        }

        .log-carousel {
            border-radius: none;
            padding: 0.5rem;
            box-shadow: 0 2px 8px rgb(255, 255, 255);
        }

        @keyframes scroll-horizontal {
            0% {
                transform: translateX(150%);
            }
            100% {
                transform: translateX(-170%);
            }
        }
    }

    @media (max-width: 480px) {
        .carousel {
            gap: 1.5rem;
            animation: scroll-horizontal 10s linear infinite;
        }

        .carousel-item {
            min-width: 80px;
        }

        .log-carousel {
            width: 90px;
            height: 90px;
        }

        .company-name {
            font-size: 0.7rem;
        }

        .log-carousel {
            border-radius: none;
            padding: 0.5rem;
            box-shadow: 0 2px 8px rgb(255, 255, 255);
        }

        @keyframes scroll-horizontal {
            0% {
                transform: translateX(200%);
            }
            100% {
                transform: translateX(-250%);
            }
        }
    }

</style>

<!-- JavaScript removed: Use Astro or client-side frameworks for dynamic behavior -->
