<nav class="navbar">
  <div class="logo-container">
    <a href="/" class="logo-link">
      <img src="/log-CTech.svg" alt="Logo CTech">
    </a>
  </div>

  <div class="search-bar">
    <input type="text" placeholder="Buscar ...">
    <span class="material-icons search-icon">search</span>
  </div>

  <!-- MENU HAMBUERGUESA -->
  <div class="menu-toggle">
    <span class="material-icons">menu</span>
  </div>

  <ul class="menu-nav">
    <li><a href="#nosotros">Nosotros</a></li>
    <li><a href="#contenido">Contenido</a></li>
    <li><a href="#foro">Foro</a></li>
    <li><a href="#equipo">Equipo</a></li>
    <li><a href="#comunidades">Comunidades</a></li>
  </ul>
</nav>

<style>
  /* NAVBAR PRINCIPAL */
    .navbar {
        font-family: "Segoe UI", "Inter", sans-serif;
        font-style: italic;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 50px;
        background-color: var(--color-white); /* Fondo blanco */
        border-bottom: 1px solid var(--color-white); /* Línea inferior gris clara */
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        height: 57px;
    }

    /* LOGO */
    .logo-link {
        display: flex;
        align-items: center;
        text-decoration: none;
    }

    .logo-link img {
        height: 40px;
        width: auto;
        transition: transform 0.3s ease;
    }

    .logo-link:hover img {
        transform: scale(1.02);
    }

    /* SEARCH BAR */
    .search-bar {
        position: relative;
        display: flex;
        align-items: center;
        flex: 1;
        max-width: 600px;
        margin: 0 2rem;
    }

    .search-bar input {
        padding: 0.60rem 2.5rem 0.60rem 1rem;
        border: 1px solid var(--color-blue-grey-dark);
        border-radius: 25px;
        font-size: 1.05rem;
        width: 71%;
        color: var(--color-primary-dark);
        background-color: var(--color-white);
        transition: border-color 0.3s ease, background-color 0.3s ease;
    }

    .search-bar input:focus {
        outline: none;
        border-color: var( --color-azure-radiant);
        background-color: #fff;
    }

    .search-icon {
        position: absolute;
        right: 8rem;
        font-size: 1.5rem;
        color: var(--color-secondary);
        cursor: pointer;
        transition: color 0.3s ease;
    }

    .search-icon:hover {
        color: var( --color-azure-radiant);
    }

    /* MENÚ DE NAVEGACIÓN */
    .menu-nav {
        display: flex;
        list-style: none;
        gap: 2rem;
        margin: 0;
        padding: 0;
    }

    .menu-nav a {
        text-decoration: none;
        color: var(--color-primary-dark);
        font-weight: 400;
        transition: color 0.3s ease;
        padding: 0.5rem 0;
        position: relative;
    }

    .menu-nav a:hover {
        color: var(--color-secondary);
    }

    .menu-nav a::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 2px;
        background-color: #0073ff; /* --color-azure-radiant */
        transition: width 0.3s ease;
    }

    .menu-nav a:hover::after {
        width: 100%;
    }

    /* MENU HAMBURGUESA, OCULTO EN EL PANTALLA GRANDE */
    .menu-toggle {
        display: none;
        cursor: pointer;
        color: var(--color-primary-dark);
        font-size: 1.8rem;
        margin-left: 1rem;
    }

    /* PORTATILES */
    @media (max-width: 1200px) {
        .navbar {
            padding: 10px 30px;
            gap: 1rem;
        }

        .search-bar {
            max-width: 450px;
            margin: 0 1.5rem;
        }

        .search-bar input {
            width: 80%;
            font-size: 1rem;
        }

        .search-icon {
            right: 3rem;
        }

        .menu-nav {
            gap: 1.5rem;
        }

        .menu-nav a {
            font-size: 0.95rem;
        }
    }

  /* CELULARES*/
    /* CELULARES */
    @media (max-width: 480px) {
        .navbar {
            justify-content: space-between;
            align-items: center;
            padding: 0.6rem 1rem;
            height: 57px;
            position: absolute; /* fixed fija el navbar */
            top: 0;
            left: 0;
            right: 0;
            background-color: var(--color-white);
            z-index: 1002; /* encima del menú desplegable */
        }

        /* Fijar logo */
        .logo-container {
            flex: 1;
            display: flex;
            justify-content: flex-start;
            align-items: center;
        }

        /* Fijar barra de búsqueda */
        .search-bar {
            flex: 1;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            max-width: 180px;
        }

        .search-bar input {
            width: 100%;
            font-size: 0.9rem;
            padding: 0.45rem 2rem 0.45rem 0.8rem;
        }

        .search-icon {
            right: 0.6rem;
            font-size: 1.2rem;
        }

        /* Fijar el botón hamburguesa */
        .menu-toggle {
            display: block;
            position: relative;
            font-size: 1.8rem;
            color: var(--color-primary-dark);
            z-index: 1003;
            background: none;
            cursor: pointer;
            border: none;
            padding: 0;
        }

        /* Menú desplegable hacia abajo */
        .menu-nav {
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            width: 50%;
            height: 35vh; /* solo la mitad inferior */
            background-color: var(--color-white);
            position: fixed;
            top: 65px; /* justo debajo del navbar */
            left: 48%;
            z-index: 1001;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.401);
        }

        .menu-nav.active {
            display: flex;
            animation: slideDown 0.3s ease forwards;
            border-radius: 10px;
        }

        .menu-nav a {
            font-size: 1.1rem;
            text-align: center;
            width: 100%;
            padding: 0.8rem 0;
            color: var(--color-black);
            text-decoration: none;
        }

        .menu-nav a:hover {
            background-color: rgba(0, 0, 0, 0.05);
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10%);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    }


</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.querySelector('.menu-toggle');
        const menu = document.querySelector('.menu-nav');

        if (!toggle || !menu) return;

        // abrir/cerrar el menú con el botón hamburguesa
        toggle.addEventListener('click', (e) => {
            e.stopPropagation(); // evita cerrar el menú al hacer clic en el botón
            menu.classList.toggle('active');
        });

        // cerrar el menú al hacer clic fuera
        document.addEventListener('click', (e) => {
            const target = e.target;
            // asegurarse de que target es un Node antes de usar contains
            if (!(target instanceof Node)) return;

            if (menu.classList.contains('active')) {
                const isClickInsideMenu = menu.contains(target);
                const isClickOnToggle = toggle.contains(target);

                if (!isClickInsideMenu && !isClickOnToggle) {
                    menu.classList.remove('active');
                }
            }
        });

        // cerrar el menú al hacer clic en un enlace dentro del menú
        menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.remove('active');
            });
        });
    });
</script>

