---
// Astro component script (if needed)
---

<section id="nosotros" class="hero-section">
    <h1>Bienvenido a CTech</h1>
    <p>Plataforma para impulsar comunidades tecnológicas</p>
    <p>¡Aquí tienes la oportunidad de aprender desde cero y sin costo!</p>
    
    <slot />
</section>

<style>
    
    .hero-section {
        padding: 5rem 2rem;
        text-align: center;
        background: var(--color-white);
    }

    .hero-section h1 {
        font-family: "DM Serif Display", serif;;
        color: var(--color-primary-dark);
        font-size: 5rem;
        margin: 2.5rem 0 0 0;
        margin-bottom: 0.5rem;
        font-weight: bold;
        font-style: italic;
    }

    .hero-section p {
        font-size: 1rem;
        margin-bottom: 1rem;
        margin: 0.5rem;
        opacity: 0.9;
        color: var(--color-secondary);
        font-style: italic;
    }

    .hero-section p:last-of-type {
        margin-bottom: 2rem;
    }

    /* RESPONSIVE */
    @media (max-width: 1200px) {
        .hero-section {
            padding: 7rem 1.5rem;
        }
        .hero-section h1 {
            font-size: 5rem;
            margin-top: 2rem;
        }
        .hero-section p {
            font-size: 0.95rem;
            margin: 0.5rem 0.4rem;
        }
    }

    @media (max-width: 480px) {
        .hero-section {
            padding: 0 1rem;
            text-align: left;
        }
        .hero-section h1 {
            font-size: 3.5rem;
            margin: 0;
            text-align: center;
        }
        .hero-section p {
            font-size: 0.95rem;
            margin: 0.20rem 0;
            text-align: center;
        }

        .hero-section p:last-of-type {
            margin-bottom: 2rem;
        }
    }

</style>








