---
import AdminLayout from '../../layouts/AdminLayout.astro';

const title = 'Ajustes';
const subtitle = 'Configuración de la plataforma';
---

<AdminLayout title={title} subtitle={subtitle}>
  <div class="settings-page">
    <!-- Información Personal -->
    <div class="settings-card">
      <div class="card-header">
        <div class="header-icon icon-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
        <div>
          <h3>Información Personal</h3>
          <p>Gestiona tu nombre y correo electrónico administrativo</p>
        </div>
      </div>

      <form id="personalInfoForm" class="settings-form">
        <div class="fg">
          <label>Nombre Completo</label>
          <input type="text" id="profileInputName" name="name_user" class="fi" placeholder="Tu nombre" />
        </div>
        <div class="fg">
          <label>Email de Acceso</label>
          <input type="email" id="profileInputEmail" name="email" class="fi" placeholder="correo@ejemplo.com" />
        </div>
        <div class="fg">
          <label>Cargo</label>
          <input type="text" id="profileInputRole" class="fi" readonly value="Administrador Global" style="opacity: 0.7; cursor: not-allowed;" />
        </div>
        <div class="form-footer">
          <button type="submit" class="btn-save" id="btnSaveProfile">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Actualizar Información
          </button>
        </div>
      </form>
    </div>

    <!-- Cambiar contraseña -->
    <div class="settings-card">
      <div class="card-header">
        <div class="header-icon icon-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <div>
          <h3>Cambiar contraseña</h3>
          <p>Actualiza tu clave de acceso administrativo</p>
        </div>
      </div>

      <form id="pwdForm" class="settings-form">
        <div class="fg">
          <label>Contraseña actual</label>
          <div class="input-eye">
            <input type="password" id="currentPwd" class="fi" placeholder="Tu contraseña actual" required />
            <button type="button" class="eye-btn" data-target="currentPwd">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
            </button>
          </div>
        </div>
        <div class="fg">
          <label>Nueva contraseña</label>
          <div class="input-eye">
            <input type="password" id="newPwd" class="fi" placeholder="Mínimo 8 caracteres" required />
            <button type="button" class="eye-btn" data-target="newPwd">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
            </button>
          </div>
          <div class="strength-bar" id="strengthBar">
            <div class="strength-fill" id="strengthFill"></div>
          </div>
          <span class="strength-label" id="strengthLabel"></span>
        </div>
        <div class="fg">
          <label>Confirmar contraseña</label>
          <div class="input-eye">
            <input type="password" id="confirmPwd" class="fi" placeholder="Repite la nueva contraseña" required />
            <button type="button" class="eye-btn" data-target="confirmPwd">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
            </button>
          </div>
        </div>
        <div class="form-footer">
          <button type="submit" class="btn-save" id="btnSavePwd">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Actualizar contraseña
          </button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .settings-page { max-width: 640px; display: flex; flex-direction: column; gap: 24px; }

    .settings-card {
      background: #fff;
      border-radius: 18px;
      border: 1px solid #e2e8f0;
      padding: 28px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 24px;
      padding-bottom: 18px;
      border-bottom: 1px solid #f1f5f9;
    }

    .header-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .icon-blue { background: #eff6ff; color: #3b82f6; }

    .card-header h3 { margin: 0 0 3px; font-size: 1rem; font-weight: 700; color: #0f172a; }
    .card-header p { margin: 0; font-size: 0.82rem; color: #64748b; }

    .settings-form { display: flex; flex-direction: column; gap: 16px; }
    .fg { display: flex; flex-direction: column; gap: 6px; }
    .fg label { font-size: 0.8rem; font-weight: 700; color: #475569; }
    .input-eye { position: relative; }

    .fi {
      width: 100%;
      box-sizing: border-box;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 10px 40px 10px 13px;
      font-size: 0.88rem;
      color: #1e293b;
      font-family: inherit;
      outline: none;
      transition: all 0.2s;
      background: #f8fafc;
    }
    .fi:focus {
      border-color: #3b82f6;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .eye-btn {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #94a3b8;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }
    .eye-btn:hover { color: #64748b; }

    .strength-bar { height: 4px; background: #f1f5f9; border-radius: 4px; margin-top: 6px; overflow: hidden; }
    .strength-fill { height: 100%; width: 0; border-radius: 4px; transition: all 0.3s; }
    .strength-label { font-size: 0.72rem; font-weight: 600; }

    .form-footer { margin-top: 8px; }

    .btn-save {
      background: #3b82f6;
      color: #fff;
      border: none;
      padding: 12px 24px;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.9rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      width: fit-content;
      transition: all 0.2s;
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
    }
    .btn-save:hover { background: #2563eb; transform: translateY(-1px); box-shadow: 0 6px 16px rgba(59, 130, 246, 0.3); }
    .btn-save:disabled { background: #94a3b8; cursor: not-allowed; transform: none; box-shadow: none; }

    @media (max-width: 640px) {
      .settings-page { max-width: 100%; }
    }
  </style>

  <script>
    import { authManager as auth, AuthManager } from '../../utils/auth.js';

    // Cargar datos iniciales
    function loadData() {
      const user = auth.getUser();
      if (user) {
        const nameInput = document.getElementById('profileInputName') as HTMLInputElement;
        const emailInput = document.getElementById('profileInputEmail') as HTMLInputElement;
        const roleInput = document.getElementById('profileInputRole') as HTMLInputElement;

        if (nameInput) nameInput.value = user.name_user || '';
        if (emailInput) emailInput.value = user.email || '';
        if (roleInput) roleInput.value = (user.role && user.role.name_rol) ? user.role.name_rol : 'Administrador Global';
      }
    }

    // Toggles de visibilidad de contraseña
    document.querySelectorAll('.eye-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const input = document.getElementById((btn as HTMLElement).dataset.target) as HTMLInputElement;
        const isPass = input.type === 'password';
        input.type = isPass ? 'text' : 'password';
        
        // Toggle icon visually
        const svg = btn.querySelector('svg');
        if (svg) {
          if (isPass) {
            svg.innerHTML = `
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
            `;
          } else {
            svg.innerHTML = `
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            `;
          }
        }
      });
    });

    // Medidor de fuerza de contraseña
    document.getElementById('newPwd')?.addEventListener('input', function(e) {
      const v = (e.target as HTMLInputElement).value;
      let score = 0;
      if (v.length >= 8) score++;
      if (/[A-Z]/.test(v)) score++;
      if (/[0-9]/.test(v)) score++;
      if (/[^A-Za-z0-9]/.test(v)) score++;

      const fill = document.getElementById('strengthFill');
      const label = document.getElementById('strengthLabel');
      const colors = ['#ef4444', '#f59e0b', '#22c55e', '#15803d'];
      const labels = ['Débil', 'Regular', 'Fuerte', 'Muy fuerte'];
      
      if (fill) {
        fill.style.width = `${(score / 4) * 100}%`;
        fill.style.background = colors[score - 1] || '#f1f5f9';
      }
      if (label) {
        label.textContent = score ? labels[score - 1] : '';
        label.style.color = colors[score - 1] || '#94a3b8';
      }
    });

    // Manejar actualización de información personal
    const infoForm = document.getElementById('personalInfoForm') as HTMLFormElement;
    infoForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btnSaveProfile') as HTMLButtonElement;
      const formData = new FormData(infoForm);
      const data = Object.fromEntries(formData.entries());

      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = 'Guardando...';

      try {
        const updatedUser = await AuthManager.fetch('/users/me', {
          method: 'PATCH',
          body: JSON.stringify(data)
        });

        const currentToken = auth.getToken();
        auth.setAuthData(currentToken, updatedUser);

        (window as any).Swal?.fire({
          title: '¡Perfil Actualizado!',
          text: 'Tus cambios han sido guardados con éxito.',
          icon: 'success',
          confirmButtonColor: '#3b82f6'
        });

        window.dispatchEvent(new CustomEvent('user-updated', { detail: updatedUser }));
      } catch (err) {
        console.error('Error updating profile:', err);
        (window as any).Swal?.fire('Error', 'No se pudieron guardar los cambios: ' + err.message, 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    });

    // Manejar cambio de contraseña
    const pwdForm = document.getElementById('pwdForm') as HTMLFormElement;
    pwdForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btnSavePwd') as HTMLButtonElement;
      const current = (document.getElementById('currentPwd') as HTMLInputElement).value;
      const newPwd = (document.getElementById('newPwd') as HTMLInputElement).value;
      const confirm = (document.getElementById('confirmPwd') as HTMLInputElement).value;

      if (newPwd !== confirm) {
        (window as any).Swal?.fire('Error', 'Las contraseñas nuevas no coinciden.', 'warning');
        return;
      }
      if (newPwd.length < 8) {
        (window as any).Swal?.fire('Aviso', 'La contraseña debe tener al menos 8 caracteres.', 'info');
        return;
      }

      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = 'Cambiando...';

      try {
        await AuthManager.fetch('/users/me/password', {
          method: 'PATCH',
          body: JSON.stringify({ current_password: current, new_password: newPwd }),
        });

        (window as any).Swal?.fire({
          title: '¡Contraseña Actualizada!',
          text: 'Tu acceso ha sido actualizado correctamente.',
          icon: 'success',
          confirmButtonColor: '#3b82f6'
        });

        pwdForm.reset();
        const fill = document.getElementById('strengthFill');
        const label = document.getElementById('strengthLabel');
        if (fill) fill.style.width = '0';
        if (label) label.textContent = '';
      } catch (err) {
        console.error('Error updating password:', err);
        (window as any).Swal?.fire('Error', err.message || 'Error al actualizar la contraseña.', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    });

    document.addEventListener('DOMContentLoaded', loadData);
    loadData();
  </script>
</AdminLayout>
