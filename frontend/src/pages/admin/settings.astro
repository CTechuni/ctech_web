---
import AdminLayout from '../../layouts/AdminLayout.astro';

const title = 'Ajustes';
const subtitle = 'Configuración de la plataforma';
---

<AdminLayout title={title} subtitle={subtitle}>
  <div class="settings-page">
    <div class="settings-nav glass-morphism">
      <nav class="settings-menu">
        <a href="#general" class="active">General</a>
        <a href="#notifications">Notificaciones</a>
        <a href="#api">API & Integraciones</a>
        <a href="#backup">Copias de Seguridad</a>
      </nav>
    </div>

    <div class="settings-content">
      <section id="general" class="settings-section glass-morphism">
        <header class="section-header">
          <h2>Configuración General</h2>
          <p>Ajustes básicos del sitio y la organización</p>
        </header>

        <form class="settings-form">
          <div class="form-group">
            <label>Email de Contacto</label>
            <input type="email" value="contacto@ctech.com" />
          </div>


          <div class="form-actions">
            <button type="submit" class="btn-primary">Guardar Cambios</button>
          </div>
        </form>
      </section>
    </div>
  </div>

  <style>
    .settings-page {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 2rem;
    }

    .glass-morphism {
      background: white;
      border-radius: 20px;
      border: 1px solid #e2e8f0;
      box-shadow: var(--card-shadow);
      padding: 1.5rem;
    }

    .settings-menu {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .settings-menu a {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      color: #64748b;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.2s;
    }

    .settings-menu a:hover {
      background: #f8fafc;
      color: #0f172a;
    }

    .settings-menu a.active {
      background: #eff6ff;
      color: #0073ff;
    }

    .settings-content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .section-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid #f1f5f9;
      padding-bottom: 1.5rem;
    }

    .section-header h2 {
      font-size: 1.25rem;
      font-weight: 800;
      margin: 0;
      color: #0f172a;
    }

    .section-header p {
      margin: 0.25rem 0 0;
      font-size: 0.9rem;
      color: #64748b;
    }

    .settings-form {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group label {
      font-size: 0.85rem;
      font-weight: 700;
      color: #1e293b;
    }

    .form-group input, .form-group textarea {
      padding: 0.85rem;
      border-radius: 12px;
      border: 1px solid #e2e8f0;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-group input:focus { border-color: #0073ff; }


    .btn-primary {
      background: #0073ff;
      color: white;
      border: none;
      padding: 0.85rem 2rem;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(0, 115, 255, 0.2);
    }


    @media (max-width: 768px) {
      .settings-page { grid-template-columns: 1fr; }
    }

    @media (max-width: 480px) {
      .settings-nav nav { flex-direction: row; overflow-x: auto; padding-bottom: 0.5rem; }
      .settings-nav nav a { white-space: nowrap; }
    }
  </style>
</AdminLayout>
