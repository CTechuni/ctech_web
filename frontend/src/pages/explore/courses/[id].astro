---
// src/pages/explore/courses/[id].astro
import UserLayout from "../../../layouts/UserLayout.astro";

// En dev: Astro sirve cualquier [id] dinámicamente.
// getStaticPaths vacío evita errores de build SSG (el script lee el ID del URL en runtime).
export function getStaticPaths() { return []; }
---

<UserLayout title="Detalle del Curso" subtitle="Explora los módulos y recursos de este curso.">
    <div id="courseDetailRoot">
        <div class="cd-loading">
            <div class="cd-spinner"></div>
            <span>Cargando curso...</span>
        </div>
    </div>
</UserLayout>

<style is:global>
/* ── Root ── */
#courseDetailRoot { display: flex; flex-direction: column; gap: 2rem; }

/* ── Loading ── */
.cd-loading {
    display: flex; flex-direction: column; align-items: center;
    padding: 6rem 0; gap: 1.25rem; color: #94a3b8;
}
.cd-spinner {
    width: 44px; height: 44px; border: 4px solid #f1f5f9;
    border-top-color: #007bff; border-radius: 50%;
    animation: cdSpin 1s linear infinite;
}
@keyframes cdSpin { to { transform: rotate(360deg); } }

/* ── Hero ── */
.cd-hero {
    background: #fff; border-radius: 24px; border: 1px solid #eef2f6;
    padding: 2.5rem; display: grid;
    grid-template-columns: 1fr 380px; gap: 3rem; align-items: center;
    box-shadow: 0 4px 12px rgba(0,0,0,.04);
}
.cd-hero-info { display: flex; flex-direction: column; gap: 1.25rem; }
.cd-specialty-tag {
    display: inline-flex; align-items: center; gap: 7px;
    background: #eff6ff; color: #2563eb;
    padding: 6px 14px; border-radius: 10px;
    font-size: .75rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: .05em; width: fit-content;
}
.cd-hero-info h1 {
    font-size: 2.2rem; font-weight: 900; color: #0f172a; margin: 0;
    line-height: 1.15; letter-spacing: -.02em;
}
.cd-mentor-chip {
    display: flex; align-items: center; gap: 10px;
    background: #f8fafc; border: 1px solid #eef2f6;
    border-radius: 14px; padding: 10px 16px; width: fit-content;
}
.cd-mentor-av {
    width: 32px; height: 32px; background: #007bff; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 800; font-size: .75rem; flex-shrink: 0;
}
.cd-mentor-name { font-size: .9rem; font-weight: 700; color: #334155; }
.cd-mentor-name span { color: #94a3b8; font-weight: 500; font-size: .82rem; }
.cd-desc { font-size: 1rem; color: #64748b; line-height: 1.7; margin: 0; }

.cd-meta-row { display: flex; flex-wrap: wrap; gap: 10px; }
.cd-badge {
    padding: 5px 12px; border-radius: 8px; font-size: .72rem;
    font-weight: 700; text-transform: uppercase; letter-spacing: .04em;
}
.cd-badge-level { background: #f0fdf4; color: #15803d; }
.cd-badge-modules { background: #f5f3ff; color: #7c3aed; }
.cd-badge-techs { background: #fffbeb; color: #d97706; }

.cd-thumbnail {
    border-radius: 20px; overflow: hidden;
    aspect-ratio: 16/10; background: #f1f5f9;
    border: 6px solid #fff;
    box-shadow: 0 20px 40px rgba(0,0,0,.12);
}
.cd-thumbnail img { width: 100%; height: 100%; object-fit: cover; display: block; }
.cd-thumb-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem; color: #c7d2fe;
    background: linear-gradient(135deg, #eff6ff 0%, #f5f3ff 100%);
}

/* ── Modules section ── */
.cd-modules-wrap {
    background: #fff; border-radius: 24px; border: 1px solid #eef2f6;
    padding: 2rem; box-shadow: 0 4px 12px rgba(0,0,0,.04);
}
.cd-section-head {
    display: flex; align-items: center; gap: 12px; margin-bottom: 1.5rem;
}
.cd-section-icon {
    width: 42px; height: 42px; background: #eff6ff; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: #2563eb; font-size: 1.1rem;
}
.cd-section-head h2 { font-size: 1.35rem; font-weight: 800; color: #0f172a; margin: 0; }
.cd-section-head .cd-count {
    background: #f1f5f9; color: #64748b; border-radius: 20px;
    padding: 2px 10px; font-size: .78rem; font-weight: 700; margin-left: auto;
}

.cd-modules-list { display: flex; flex-direction: column; gap: 12px; }

.cd-module-card {
    display: flex; align-items: center; gap: 16px;
    padding: 16px 20px; border-radius: 14px;
    border: 1px solid #f1f5f9; background: #fafbfc;
    transition: all .2s;
}
.cd-module-card:hover { border-color: #bfdbfe; background: #fff; transform: translateX(4px); }
.cd-module-card.has-link { cursor: pointer; }

.cd-mod-num {
    width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .8rem; font-weight: 800; background: #eff6ff; color: #2563eb;
}
.cd-mod-icon {
    width: 38px; height: 38px; border-radius: 12px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 1rem;
}
.cd-mod-icon.video    { background: #1e293b; color: #fff; }
.cd-mod-icon.pdf      { background: #fee2e2; color: #ef4444; }
.cd-mod-icon.book     { background: #fef3c7; color: #d97706; }
.cd-mod-icon.image    { background: #fdf4ff; color: #a855f7; }
.cd-mod-icon.link     { background: #eff6ff; color: #3b82f6; }

.cd-mod-info { flex: 1; min-width: 0; }
.cd-mod-info h4 { font-size: .95rem; font-weight: 700; color: #0f172a; margin: 0 0 3px; }
.cd-mod-info p {
    font-size: .8rem; color: #64748b; margin: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

.cd-mod-btn {
    flex-shrink: 0; padding: 7px 16px; border-radius: 9px;
    font-size: .8rem; font-weight: 700; text-decoration: none;
    border: none; cursor: pointer; transition: all .2s;
    display: flex; align-items: center; gap: 6px;
}
.cd-mod-btn.video-btn { background: #1e293b; color: #fff; }
.cd-mod-btn.video-btn:hover { background: #0f172a; }
.cd-mod-btn.pdf-btn { background: #fee2e2; color: #dc2626; }
.cd-mod-btn.pdf-btn:hover { background: #fecaca; }
.cd-mod-btn.book-btn { background: #fef3c7; color: #b45309; }
.cd-mod-btn.book-btn:hover { background: #fde68a; }
.cd-mod-btn.image-btn { background: #fdf4ff; color: #9333ea; }
.cd-mod-btn.image-btn:hover { background: #f3e8ff; }
.cd-mod-btn.link-btn { background: #eff6ff; color: #2563eb; }
.cd-mod-btn.link-btn:hover { background: #dbeafe; }

.cd-mod-locked {
    flex-shrink: 0; padding: 7px 14px; border-radius: 9px;
    background: #f1f5f9; color: #94a3b8; font-size: .78rem; font-weight: 600;
    display: flex; align-items: center; gap: 5px;
}

.cd-empty-modules {
    text-align: center; padding: 2.5rem 1rem; color: #94a3b8;
    font-size: .9rem; font-weight: 600;
}
.cd-empty-modules i { font-size: 2rem; display: block; margin-bottom: .75rem; color: #e2e8f0; }

/* ── Resources ── */
.cd-resources-wrap {
    background: #fff; border-radius: 24px; border: 1px solid #eef2f6;
    padding: 2rem; box-shadow: 0 4px 12px rgba(0,0,0,.04);
}
.cd-res-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; margin-top: .5rem; }
.cd-res-item {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 16px; background: #f8fafc;
    border: 1px solid #eef2f6; border-radius: 14px;
    text-decoration: none; transition: all .2s;
}
.cd-res-item:hover { border-color: #007bff; background: #eff6ff; transform: translateY(-2px); }
.cd-res-ic { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
.cd-res-ic.pdf  { background: #fee2e2; color: #ef4444; }
.cd-res-ic.book { background: #fef3c7; color: #d97706; }
.cd-res-ic.link { background: #eff6ff; color: #3b82f6; }
.cd-res-tx .name { font-size: .88rem; font-weight: 700; color: #334155; display: block; }
.cd-res-tx .meta { font-size: .7rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; }

.cd-error {
    text-align: center; padding: 3rem; background: #fff; border-radius: 20px;
    border: 2px dashed #e2e8f0; color: #94a3b8; font-weight: 600;
}

@media (max-width: 1100px) {
    .cd-hero { grid-template-columns: 1fr; gap: 2rem; padding: 1.75rem; }
    .cd-thumbnail { order: -1; max-width: 500px; margin: 0 auto; }
    .cd-hero-info h1 { font-size: 1.7rem; }
}
@media (max-width: 640px) {
    .cd-module-card { flex-wrap: wrap; }
}
</style>

<script>
import { AuthManager } from "../../../utils/auth.js";

const TYPE_META = {
    video: { icon: '<i class="fas fa-play"></i>', cls: 'video', label: 'Ver video',    btnCls: 'video-btn' },
    pdf:   { icon: '<i class="fas fa-file-pdf"></i>', cls: 'pdf', label: 'Abrir PDF',  btnCls: 'pdf-btn'   },
    book:  { icon: '<i class="fas fa-book-open"></i>', cls: 'book', label: 'Leer',     btnCls: 'book-btn'  },
    image: { icon: '<i class="fas fa-image"></i>', cls: 'image', label: 'Ver imagen',  btnCls: 'image-btn' },
    link:  { icon: '<i class="fas fa-link"></i>', cls: 'link', label: 'Abrir enlace',  btnCls: 'link-btn'  },
};

function esc(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderModules(modules) {
    if (!modules?.length) {
        return `<div class="cd-empty-modules"><i class="fas fa-cube"></i>Este curso aún no tiene módulos publicados.</div>`;
    }
    return modules.map((m, i) => {
        const type = (m.type || 'link').toLowerCase();
        const meta = TYPE_META[type] || TYPE_META.link;
        const hasUrl = !!m.url;
        const btnHtml = hasUrl
            ? `<a href="${esc(m.url)}" target="_blank" rel="noopener" class="cd-mod-btn ${meta.btnCls}">${meta.icon} ${meta.label}</a>`
            : `<span class="cd-mod-locked"><i class="fas fa-lock"></i> Próximamente</span>`;
        return `
        <div class="cd-module-card ${hasUrl ? 'has-link' : ''}">
            <div class="cd-mod-num">${i + 1}</div>
            <div class="cd-mod-icon ${meta.cls}">${meta.icon}</div>
            <div class="cd-mod-info">
                <h4>${esc(m.title)}</h4>
                ${m.description ? `<p>${esc(m.description)}</p>` : ''}
            </div>
            ${btnHtml}
        </div>`;
    }).join('');
}

function renderResources(links) {
    const pdfs  = (links?.pdfs  || []).map(url => `<a href="${esc(url)}" target="_blank" class="cd-res-item"><div class="cd-res-ic pdf"><i class="fas fa-file-pdf"></i></div><div class="cd-res-tx"><span class="name">Documento PDF</span><span class="meta">Recurso</span></div></a>`);
    const books = (links?.books || []).map(url => `<a href="${esc(url)}" target="_blank" class="cd-res-item"><div class="cd-res-ic book"><i class="fas fa-book-open"></i></div><div class="cd-res-tx"><span class="name">Lectura recomendada</span><span class="meta">E-Book</span></div></a>`);
    const videos = (links?.videos || []).map(url => `<a href="${esc(url)}" target="_blank" class="cd-res-item"><div class="cd-res-ic link"><i class="fas fa-video"></i></div><div class="cd-res-tx"><span class="name">Video externo</span><span class="meta">Enlace</span></div></a>`);
    const all = [...pdfs, ...books, ...videos];
    return all.length ? all.join('') : '';
}

async function init() {
    const root = document.getElementById('courseDetailRoot');
    const segments = window.location.pathname.split('/');
    const id = segments[segments.length - 1];

    if (!id || isNaN(parseInt(id))) {
        root.innerHTML = '<div class="cd-error">Referencia de curso no válida.</div>';
        return;
    }

    try {
        const c = await AuthManager.fetch(`/courses/${id}`);
        if (!c) throw new Error('no course');

        const modules = Array.isArray(c.modules) ? c.modules : [];
        const lvlMap  = { basico:'Básico', intermedio:'Intermedio', avanzado:'Avanzado' };
        const lvl     = lvlMap[c.level] || 'Básico';
        const techs   = (c.technologies || []).slice(0, 4).map(t => `<span class="cd-badge cd-badge-techs">${esc(t)}</span>`).join('');
        const initial = (c.mentor_name || 'M')[0].toUpperCase();
        const links   = c.content_links || {};
        const hasResources = (links.pdfs?.length || links.books?.length || links.videos?.length);

        root.innerHTML = `
        <!-- Hero -->
        <section class="cd-hero">
            <div class="cd-hero-info">
                <span class="cd-specialty-tag">
                    <i class="fas fa-tag"></i> ${esc(c.specialty_name || 'General')}
                </span>
                <h1>${esc(c.title)}</h1>
                <div class="cd-mentor-chip">
                    <div class="cd-mentor-av">${initial}</div>
                    <div class="cd-mentor-name"><span>Instructor · </span>${esc(c.mentor_name || 'CTech')}</div>
                </div>
                <p class="cd-desc">${esc(c.description || 'Sin descripción.')}</p>
                <div class="cd-meta-row">
                    <span class="cd-badge cd-badge-level"><i class="fas fa-signal"></i> ${lvl}</span>
                    <span class="cd-badge cd-badge-modules"><i class="fas fa-cubes"></i> ${modules.length} módulo${modules.length !== 1 ? 's' : ''}</span>
                    ${techs}
                </div>
            </div>
            <div class="cd-thumbnail">
                ${c.thumbnail_url
                    ? `<img src="${esc(c.thumbnail_url)}" alt="${esc(c.title)}" loading="lazy">`
                    : `<div class="cd-thumb-placeholder"><i class="fas fa-book-open"></i></div>`}
            </div>
        </section>

        <!-- Módulos -->
        <section class="cd-modules-wrap">
            <div class="cd-section-head">
                <div class="cd-section-icon"><i class="fas fa-layer-group"></i></div>
                <h2>Módulos del curso</h2>
                <span class="cd-count">${modules.length} módulo${modules.length !== 1 ? 's' : ''}</span>
            </div>
            <div class="cd-modules-list">
                ${renderModules(modules)}
            </div>
        </section>

        <!-- Recursos adicionales (content_links legacy) -->
        ${hasResources ? `
        <section class="cd-resources-wrap">
            <div class="cd-section-head">
                <div class="cd-section-icon"><i class="fas fa-folder-open"></i></div>
                <h2>Recursos adicionales</h2>
            </div>
            <div class="cd-res-grid">
                ${renderResources(links)}
            </div>
        </section>` : ''}
        `;
    } catch (err) {
        console.error('[CourseDetail]', err);
        root.innerHTML = '<div class="cd-error">No se pudo cargar el curso. Intenta de nuevo.</div>';
    }
}

if (document.readyState !== 'loading') {
    init();
} else {
    document.addEventListener('DOMContentLoaded', init);
}
</script>
