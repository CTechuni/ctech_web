---
import UserLayout from '../../layouts/UserLayout.astro';
---

<UserLayout title="Ajustes" subtitle="Configuración de tu cuenta y seguridad">
<div class="settings-page">
    <!-- Información Personal -->
    <div class="settings-card">
        <div class="card-header">
            <div class="header-icon icon-blue">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                </svg>
            </div>
            <div>
                <h3>Información Personal</h3>
                <p>Gestiona tu nombre y correo electrónico de acceso</p>
            </div>
        </div>

        <form id="personalInfoForm" class="settings-form">
            <div class="fg">
                <label>Nombre Completo</label>
                <input type="text" id="profileInputName" name="name_user" class="fi" placeholder="Tu nombre" />
            </div>
            <div class="fg">
                <label>Email de Acceso</label>
                <input type="email" id="profileInputEmail" name="email" class="fi" placeholder="correo@ejemplo.com" />
            </div>
            <div class="fg">
                <label>Comunidad</label>
                <input type="text" id="profileInputCommunity" class="fi" readonly value="General" style="opacity: 0.7; cursor: not-allowed;" title="La comunidad es asignada por la administración" />
            </div>
            <div class="form-footer">
                <button type="submit" class="btn-save" id="btnSaveProfile">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    Actualizar Información
                </button>
            </div>
        </form>
    </div>

    <!-- Cambiar contraseña -->
    <div class="settings-card">
        <div class="card-header">
            <div class="header-icon icon-blue">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                </svg>
            </div>
            <div>
                <h3>Cambiar contraseña</h3>
                <p>Actualiza tu clave de acceso a la plataforma</p>
            </div>
        </div>

        <form id="pwdForm" class="settings-form">
            <div class="fg">
                <label>Contraseña actual</label>
                <div class="input-eye">
                    <input type="password" id="currentPwd" class="fi" placeholder="Tu contraseña actual" required />
                    <button type="button" class="eye-btn" data-target="currentPwd">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="fg">
                <label>Nueva contraseña</label>
                <div class="input-eye">
                    <input type="password" id="newPwd" class="fi" placeholder="Mínimo 8 caracteres" required />
                    <button type="button" class="eye-btn" data-target="newPwd">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                    </button>
                </div>
                <div class="strength-bar" id="strengthBar">
                    <div class="strength-fill" id="strengthFill"></div>
                </div>
                <span class="strength-label" id="strengthLabel"></span>
            </div>
            <div class="fg">
                <label>Confirmar nueva contraseña</label>
                <div class="input-eye">
                    <input type="password" id="confirmPwd" class="fi" placeholder="Repite la nueva contraseña" required />
                    <button type="button" class="eye-btn" data-target="confirmPwd">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="form-footer">
                <button type="submit" class="btn-save" id="btnSavePwd">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    Actualizar contraseña
                </button>
            </div>
        </form>
    </div>

    <!-- Zona de peligro -->
    <div class="settings-card danger-card">
        <div class="card-header">
            <div class="header-icon icon-red">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
            </div>
            <div>
                <h3>Zona de peligro</h3>
                <p>Acciones permanentes e irreversibles sobre tu cuenta</p>
            </div>
        </div>

        <div class="danger-item">
            <div class="danger-text">
                <strong>Eliminar mi cuenta</strong>
                <span>Se borrarán permanentemente todos tus datos y participaciones.</span>
            </div>
            <button class="btn-danger-alt" id="btnDeleteAccount">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                Eliminar cuenta
            </button>
        </div>
    </div>
</div>

<!-- Modal confirmar eliminación -->
<div class="m-overlay" id="deleteModal">
    <div class="m-card">
        <div class="m-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
        </div>
        <h4>¿Eliminar tu cuenta?</h4>
        <p>Esta acción es permanente. Escribe <strong>ELIMINAR</strong> para confirmar:</p>
        <input type="text" id="deleteConfirmInput" class="fi" placeholder="ELIMINAR" autocomplete="off" style="text-align: center; margin: 15px 0;" />
        <div class="m-actions">
            <button class="btn-ghost" id="btnCancelDelete">Cancelar</button>
            <button class="btn-danger-confirm" id="btnConfirmDelete" disabled>Eliminar permanentemente</button>
        </div>
    </div>
</div>
</UserLayout>

<style>
    .settings-page {
        max-width: 640px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .settings-card {
        background: #fff;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        padding: 28px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
    }

    .danger-card { border-color: #fee2e2; }

    .card-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 1px solid #f1f5f9;
    }

    .header-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .icon-blue { background: #eff6ff; color: #0073ff; }
    .icon-red  { background: #fef2f2; color: #ef4444; }

    .card-header h3 { margin: 0 0 3px; font-size: 1rem; font-weight: 700; color: #0f172a; }
    .card-header p { margin: 0; font-size: 0.82rem; color: #64748b; }

    .settings-form { display: flex; flex-direction: column; gap: 16px; }
    .fg { display: flex; flex-direction: column; gap: 6px; }
    .fg label { font-size: 0.8rem; font-weight: 700; color: #475569; }
    .input-eye { position: relative; }

    .fi {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 40px 10px 13px;
        font-size: 0.88rem;
        color: #1e293b;
        font-family: inherit;
        outline: none;
        transition: all 0.2s;
        background: #f8fafc;
    }
    .fi:focus {
        border-color: #0073ff;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(0, 115, 255, 0.1);
    }

    .eye-btn {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    .strength-bar { height: 4px; background: #f1f5f9; border-radius: 4px; margin-top: 6px; overflow: hidden; }
    .strength-fill { height: 100%; width: 0; border-radius: 4px; transition: all 0.3s; }
    .strength-label { font-size: 0.72rem; font-weight: 600; margin-top: 4px; display: block; }

    .form-footer { margin-top: 8px; }

    .btn-save {
        background: #0073ff;
        color: #fff;
        border: none;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(0, 115, 255, 0.2);
    }
    .btn-save:hover { background: #0062cc; transform: translateY(-1px); box-shadow: 0 6px 16px rgba(0, 115, 255, 0.3); }
    .btn-save:disabled { background: #94a3b8; cursor: not-allowed; transform: none; box-shadow: none; }

    /* Danger section */
    .danger-item { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-top: 8px; }
    .danger-text { display: flex; flex-direction: column; gap: 2px; }
    .danger-text strong { font-size: 0.9rem; color: #0f172a; }
    .danger-text span { font-size: 0.78rem; color: #64748b; }

    .btn-danger-alt {
        background: #fef2f2;
        color: #ef4444;
        border: 1px solid #fee2e2;
        padding: 8px 16px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.8rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }
    .btn-danger-alt:hover { background: #ef4444; color: #fff; border-color: #ef4444; }

    /* Modal styles */
    .m-overlay {
        position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center;
        z-index: 5000; padding: 20px;
    }
    .m-overlay.open { display: flex; }
    .m-card {
        background: #fff; border-radius: 20px; width: 100%; max-width: 400px;
        padding: 32px; text-align: center; box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }
    .m-icon-wrap { width: 52px; height: 52px; background: #fef2f2; color: #ef4444; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
    .m-card h4 { margin: 0 0 8px; font-size: 1.1rem; font-weight: 800; color: #0f172a; }
    .m-card p { font-size: 0.88rem; color: #64748b; margin-bottom: 8px; line-height: 1.5; }
    .m-actions { display: flex; gap: 12px; margin-top: 24px; justify-content: center; }
    .btn-ghost { background: #f1f5f9; color: #475569; border: none; padding: 10px 16px; border-radius: 10px; font-weight: 600; cursor: pointer; }
    .btn-danger-confirm { background: #ef4444; color: #fff; border: none; padding: 10px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; }
    .btn-danger-confirm:disabled { opacity: 0.5; cursor: not-allowed; }

    @media (max-width: 640px) {
        .danger-item { flex-direction: column; align-items: flex-start; }
    }
</style>

<script>
    import { authManager as auth, AuthManager } from '../../utils/auth.js';

    // Cargar datos iniciales
    function loadData() {
        const user = auth.getUser();
        if (user) {
            const nameInput = document.getElementById('profileInputName') as HTMLInputElement;
            const emailInput = document.getElementById('profileInputEmail') as HTMLInputElement;
            const communityInput = document.getElementById('profileInputCommunity') as HTMLInputElement;

            if (nameInput) nameInput.value = user.name_user || '';
            if (emailInput) emailInput.value = user.email || '';
            if (communityInput) communityInput.value = user.community_name || 'General';
        }
    }

    // Toggles de visibilidad de contraseña
    document.querySelectorAll('.eye-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const input = document.getElementById((btn as HTMLElement).dataset.target) as HTMLInputElement;
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            
            const svg = btn.querySelector('svg');
            if (svg) {
                if (isHidden) {
                    svg.innerHTML = `
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
                    `;
                } else {
                    svg.innerHTML = `
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    `;
                }
            }
        });
    });

    // Medidor de fuerza de contraseña
    document.getElementById('newPwd')?.addEventListener('input', function(e) {
        const v = (e.target as HTMLInputElement).value;
        let score = 0;
        if (v.length >= 8) score++;
        if (/[A-Z]/.test(v)) score++;
        if (/[0-9]/.test(v)) score++;
        if (/[^A-Za-z0-9]/.test(v)) score++;

        const fill = document.getElementById('strengthFill');
        const label = document.getElementById('strengthLabel');
        const colors = ['#ef4444', '#f97316', '#22c55e', '#15803d'];
        const labels = ['Débil', 'Regular', 'Fuerte', 'Muy fuerte'];
        
        if (fill) {
            fill.style.width = `${(score / 4) * 100}%`;
            fill.style.background = score ? colors[score - 1] : '#f1f5f9';
        }
        if (label) {
            label.textContent = score ? labels[score - 1] : '';
            label.style.color = score ? colors[score - 1] : '#94a3b8';
        }
    });

    // Manejar actualización de información personal
    const infoForm = document.getElementById('personalInfoForm') as HTMLFormElement;
    infoForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('btnSaveProfile') as HTMLButtonElement;
        const formData = new FormData(infoForm);
        const data = Object.fromEntries(formData.entries());

        btn.disabled = true;
        const originalText = btn.innerHTML;
        btn.innerHTML = 'Guardando...';

        try {
            const updatedUser = await AuthManager.fetch('/users/me', {
                method: 'PATCH',
                body: JSON.stringify(data)
            });

            const currentToken = auth.getToken();
            auth.setAuthData(currentToken, updatedUser);

            (window as any).Swal?.fire({
                title: '¡Información Actualizada!',
                text: 'Tus cambios han sido guardados con éxito.',
                icon: 'success',
                confirmButtonColor: '#0073ff'
            });

            window.dispatchEvent(new CustomEvent('user-updated', { detail: updatedUser }));
        } catch (err) {
            console.error('Error updating profile:', err);
            (window as any).Swal?.fire('Error', 'No se pudieron guardar los cambios: ' + err.message, 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    });

    // Manejar cambio de contraseña
    const pwdForm = document.getElementById('pwdForm') as HTMLFormElement;
    pwdForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('btnSavePwd') as HTMLButtonElement;
        const current = (document.getElementById('currentPwd') as HTMLInputElement).value;
        const newPwd = (document.getElementById('newPwd') as HTMLInputElement).value;
        const confirm = (document.getElementById('confirmPwd') as HTMLInputElement).value;

        if (newPwd !== confirm) {
            (window as any).Swal?.fire('Aviso', 'Las contraseñas nuevas no coinciden.', 'warning');
            return;
        }
        if (newPwd.length < 8) {
            (window as any).Swal?.fire('Aviso', 'La contraseña debe tener al menos 8 caracteres.', 'info');
            return;
        }

        btn.disabled = true;
        const originalText = btn.innerHTML;
        btn.innerHTML = 'Procesando...';

        try {
            await AuthManager.fetch('/users/me/password', {
                method: 'PATCH',
                body: JSON.stringify({ current_password: current, new_password: newPwd }),
            });

            (window as any).Swal?.fire({
                title: '¡Contraseña Cambiada!',
                text: 'Tu acceso ha sido actualizado correctamente.',
                icon: 'success',
                confirmButtonColor: '#0073ff'
            });

            pwdForm.reset();
            const fill = document.getElementById('strengthFill');
            const label = document.getElementById('strengthLabel');
            if (fill) fill.style.width = '0';
            if (label) label.textContent = '';
        } catch (err) {
            console.error('Error updating password:', err);
            (window as any).Swal?.fire('Error', err.message || 'Error al actualizar la contraseña.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    });

    // Manejar eliminación de cuenta
    const modal = document.getElementById('deleteModal');
    const deleteBtn = document.getElementById('btnDeleteAccount');
    const cancelBtn = document.getElementById('btnCancelDelete');
    const confirmInput = document.getElementById('deleteConfirmInput') as HTMLInputElement;
    const confirmBtn = document.getElementById('btnConfirmDelete') as HTMLButtonElement;

    deleteBtn?.addEventListener('click', () => { modal?.classList.add('open'); confirmInput.value = ''; confirmBtn.disabled = true; });
    cancelBtn?.addEventListener('click', () => modal?.classList.remove('open'));
    confirmInput?.addEventListener('input', () => { confirmBtn.disabled = confirmInput.value !== 'ELIMINAR'; });

    confirmBtn?.addEventListener('click', async () => {
        confirmBtn.disabled = true;
        confirmBtn.textContent = 'Eliminando...';
        try {
            await AuthManager.fetch('/users/me', { method: 'DELETE' });
            auth.clearAuthData();
            window.location.href = '/';
        } catch (err) {
            (window as any).Swal?.fire('Error', 'No se pudo eliminar la cuenta: ' + err.message, 'error');
            confirmBtn.disabled = false;
            confirmBtn.textContent = 'Eliminar permanentemente';
        }
    });

    document.addEventListener('DOMContentLoaded', loadData);
    loadData();
</script>
