---
import UserLayout from "../../layouts/UserLayout.astro";
const title = "Ajustes";
---

<UserLayout title={title} subtitle="Configura tu experiencia de aprendizaje y notificaciones.">
    <div class="settings-page-grid">
        <!-- Dashboard Sidebar Nav -->
        <aside class="settings-nav-v2 glass-morphism">
            <nav class="settings-menu-v2">
                <a href="#general" class="active">General</a>
                <a href="#notifications">Notificaciones</a>
                <a href="#learning">Preferencias de Aprendizaje</a>
                <a href="#account" class="text-danger">Zona de Peligro</a>
            </nav>
        </aside>

        <div class="settings-content-v2">
            <!-- 1. General Settings -->
            <section id="general" class="settings-section-v2">
                <header class="section-header-v2">
                    <h2>Configuración General</h2>
                    <p>Ajustes básicos de tu cuenta de estudiante</p>
                </header>

                <div class="glass-morphism no-padding">
                    <form class="settings-form-v2">
                        <div class="form-group-v2">
                            <label>Nombre de Usuario</label>
                            <input type="text" id="settingsUserName" placeholder="Tu nombre" />
                        </div>
                        <div class="form-group-v2">
                            <label>Biografía corta</label>
                            <textarea rows="3" placeholder="Cuéntanos un poco sobre ti y tus intereses tecnológicos..."></textarea>
                        </div>
                        
                        <div class="toggle-group-v2">
                            <div class="toggle-info-v2">
                                <h4>Perfil Público</h4>
                                <p>Permitir que otros miembros vean tus cursos y progreso.</p>
                            </div>
                            <label class="switch-v2">
                                <input type="checkbox" checked>
                                <span class="slider-v2 round"></span>
                            </label>
                        </div>

                        <div class="form-actions-v2">
                            <button type="submit" class="btn-primary-v2">Guardar Cambios</button>
                        </div>
                    </form>
                </div>
            </section>

            <!-- 2. Learning Preferences -->
            <section id="learning" class="settings-section-v2">
                <header class="section-header-v2">
                    <h2>Preferencias de Aprendizaje</h2>
                    <p>Personaliza cómo quieres aprender en CTech</p>
                </header>

                <div class="glass-morphism">
                    <div class="learning-grid-v2">
                        <div class="choice-item-v2 active">
                            <div class="choice-icon">🚀</div>
                            <div class="choice-text">
                                <h4>Intensivo</h4>
                                <p>Enfoque rápido en proyectos reales</p>
                            </div>
                        </div>
                        <div class="choice-item-v2">
                            <div class="choice-icon">📅</div>
                            <div class="choice-text">
                                <h4>Flexible</h4>
                                <p>Aprende a tu propio ritmo</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <style>
        .settings-page-grid {
            display: grid;
            grid-template-columns: 240px 1fr;
            gap: 2rem;
            align-items: flex-start;
        }

        .glass-morphism {
            background: white;
            border-radius: 20px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            padding: 2.5rem;
        }

        .glass-morphism.no-padding {
            padding: 2.5rem;
        }

        /* ── internal sub-nav ── */
        .settings-nav-v2 {
            position: sticky;
            top: 2rem;
            padding: 1rem;
        }

        .settings-menu-v2 {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .settings-menu-v2 a {
            padding: 0.85rem 1.25rem;
            border-radius: 12px;
            color: #64748b;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        .settings-menu-v2 a:hover {
            background: #f8fafc;
            color: #0f172a;
        }

        .settings-menu-v2 a.active {
            background: #eff6ff;
            color: #007bff;
        }

        .settings-menu-v2 a.text-danger:hover {
            background: #fef2f2;
            color: #ef4444;
        }

        /* ── Content Area ── */
        .settings-content-v2 {
            display: flex;
            flex-direction: column;
            gap: 3rem;
        }

        .section-header-v2 {
            margin-bottom: 2rem;
        }

        .section-header-v2 h2 {
            font-size: 1.5rem;
            font-weight: 800;
            margin: 0;
            color: #0f172a;
        }

        .section-header-v2 p {
            margin: 0.4rem 0 0;
            font-size: 0.95rem;
            color: #64748b;
        }

        .settings-form-v2 {
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        .form-group-v2 {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .form-group-v2 label {
            font-size: 0.9rem;
            font-weight: 700;
            color: #1e293b;
        }

        .form-group-v2 input, .form-group-v2 textarea {
            padding: 0.9rem 1.25rem;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-group-v2 input:focus { border-color: #007bff; box-shadow: 0 0 0 4px rgba(0,123,255,0.05); }

        .toggle-group-v2 {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 1.75rem;
            background: #f9fafb;
            border-radius: 18px;
            border: 1px solid #f1f5f9;
        }

        .toggle-info-v2 h4 { margin: 0; font-size: 1rem; font-weight: 700; color: #1e293b; }
        .toggle-info-v2 p { margin: 0.3rem 0 0; font-size: 0.9rem; color: #64748b; }

        .btn-primary-v2 {
            background: #007bff;
            color: white;
            border: none;
            padding: 1rem 2.5rem;
            border-radius: 14px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            box-shadow: 0 8px 16px rgba(0, 123, 255, 0.15);
            transition: all 0.2s;
            width: fit-content;
        }
        .btn-primary-v2:hover { background: #0069d9; transform: translateY(-2px); box-shadow: 0 12px 20px rgba(0, 123, 255, 0.2); }

        /* Custom Switch */
        .switch-v2 { position: relative; display: inline-block; width: 48px; height: 26px; flex-shrink: 0; }
        .switch-v2 input { opacity: 0; width: 0; height: 0; }
        .slider-v2 { position: absolute; cursor: pointer; inset: 0; background-color: #cbd5e1; transition: .4s; border-radius: 26px; }
        .slider-v2:before { position: absolute; content: ""; height: 20px; width: 20px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider-v2 { background-color: #007bff; }
        input:checked + .slider-v2:before { transform: translateX(22px); }

        /* Learning Grid */
        .learning-grid-v2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .choice-item-v2 {
            display: flex;
            align-items: center;
            gap: 1.25rem;
            padding: 1.5rem;
            border: 2px solid #f1f5f9;
            border-radius: 18px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .choice-item-v2.active {
            border-color: #007bff;
            background: #f0f7ff;
        }

        .choice-icon { font-size: 1.8rem; }
        .choice-text h4 { margin: 0; font-size: 1.05rem; font-weight: 700; color: #0f172a; }
        .choice-text p { margin: 0.2rem 0 0; font-size: 0.9rem; color: #64748b; }

        @media (max-width: 1024px) {
            .settings-page-grid { grid-template-columns: 1fr; }
            .settings-nav-v2 { position: static; }
            .settings-menu-v2 { flex-direction: row; overflow-x: auto; padding: 0.5rem; }
            .settings-menu-v2 a { white-space: nowrap; }
        }


        @media (max-width: 640px) {
            .learning-grid-v2 { grid-template-columns: 1fr; }
            .v2-card-flat { padding: 1.5rem; }
        }
    </style>

    <script>
        import { authManager } from "../../utils/auth.js";
        
        function initSettings() {
            const user = authManager.getUser();
            if (user) {
                const nameInput = document.getElementById('settingsUserName') as HTMLInputElement;
                if (nameInput) nameInput.value = user.name_user || '';
            }
        }

        initSettings();
    </script>
</UserLayout>
