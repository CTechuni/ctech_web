---
import UserLayout from '../../layouts/UserLayout.astro';
---

<UserLayout title="Ajustes" subtitle="Seguridad y cuenta">
<div class="settings-page">

    <!-- Cambiar contraseña -->
    <div class="settings-card">
        <div class="card-header">
            <div class="header-icon icon-blue"><i class="fas fa-lock"></i></div>
            <div>
                <h3>Cambiar contraseña</h3>
                <p>Actualiza tu contraseña de acceso</p>
            </div>
        </div>

        <form id="pwdForm" class="settings-form">
            <div class="fg">
                <label>Contraseña actual</label>
                <div class="input-eye">
                    <input type="password" id="currentPwd" class="fi" placeholder="Tu contraseña actual" required />
                    <button type="button" class="eye-btn" data-target="currentPwd"><i class="fas fa-eye"></i></button>
                </div>
            </div>
            <div class="fg">
                <label>Nueva contraseña</label>
                <div class="input-eye">
                    <input type="password" id="newPwd" class="fi" placeholder="Mínimo 8 caracteres" required />
                    <button type="button" class="eye-btn" data-target="newPwd"><i class="fas fa-eye"></i></button>
                </div>
                <div class="pwd-strength" id="pwdStrength"></div>
            </div>
            <div class="fg">
                <label>Confirmar nueva contraseña</label>
                <div class="input-eye">
                    <input type="password" id="confirmPwd" class="fi" placeholder="Repite la nueva contraseña" required />
                    <button type="button" class="eye-btn" data-target="confirmPwd"><i class="fas fa-eye"></i></button>
                </div>
            </div>

            <div id="pwdAlert" class="alert-msg" style="display:none;"></div>

            <div class="form-footer">
                <button type="submit" class="btn-save" id="btnSavePwd">
                    <i class="fas fa-check"></i> Guardar contraseña
                </button>
            </div>
        </form>
    </div>

    <!-- Zona de peligro -->
    <div class="settings-card danger-card">
        <div class="card-header">
            <div class="header-icon icon-red"><i class="fas fa-triangle-exclamation"></i></div>
            <div>
                <h3>Zona de peligro</h3>
                <p>Estas acciones son permanentes e irreversibles</p>
            </div>
        </div>

        <div class="danger-item">
            <div class="danger-text">
                <strong>Eliminar mi cuenta</strong>
                <span>Se eliminarán permanentemente todos tus datos. Esta acción no se puede deshacer.</span>
            </div>
            <button class="btn-danger" id="btnDeleteAccount">
                <i class="fas fa-trash"></i> Eliminar cuenta
            </button>
        </div>
    </div>
</div>

<!-- Modal confirmar eliminación -->
<div class="m-overlay" id="deleteModal">
    <div class="m-card">
        <div class="m-icon-wrap"><i class="fas fa-triangle-exclamation"></i></div>
        <h4>¿Eliminar tu cuenta?</h4>
        <p>Esta acción es permanente. Todos tus datos serán eliminados. No podrás recuperarlos.</p>
        <p class="confirm-label">Escribe <strong>ELIMINAR</strong> para confirmar:</p>
        <input type="text" id="deleteConfirmInput" class="fi" placeholder="ELIMINAR" autocomplete="off" />
        <div class="m-actions">
            <button class="btn-ghost" id="btnCancelDelete">Cancelar</button>
            <button class="btn-danger" id="btnConfirmDelete" disabled>
                <i class="fas fa-trash"></i> Sí, eliminar
            </button>
        </div>
    </div>
</div>
</UserLayout>

<style>
.settings-page {
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.settings-card {
    background: #fff;
    border: 1px solid #e8ecf0;
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 1px 3px rgba(0,0,0,.05);
}

.danger-card { border-color: #fecaca; }

.card-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid #f1f5f9;
}
.danger-card .card-header { border-color: #fef2f2; }

.header-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; flex-shrink: 0;
}
.icon-blue { background: #dbeafe; color: #2563eb; }
.icon-red  { background: #fee2e2; color: #dc2626; }

.card-header h3 { margin: 0 0 3px; font-size: 1rem; font-weight: 700; color: #0f172a; }
.card-header p  { margin: 0; font-size: .82rem; color: #94a3b8; }

/* Form */
.settings-form { display: flex; flex-direction: column; gap: 16px; }

.fg { display: flex; flex-direction: column; gap: 6px; }
.fg label { font-size: .8rem; font-weight: 700; color: #475569; }

.input-eye { position: relative; }
.fi {
    width: 100%; box-sizing: border-box;
    border: 1px solid #e2e8f0; border-radius: 10px;
    padding: 10px 42px 10px 13px;
    font-size: .88rem; color: #1e293b;
    font-family: inherit; outline: none; transition: border-color .2s;
}
.fi:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.1); }

.eye-btn {
    position: absolute; right: 12px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none; color: #94a3b8;
    cursor: pointer; font-size: .9rem; padding: 2px;
    transition: color .2s;
}
.eye-btn:hover { color: #475569; }

/* Fortaleza contraseña */
.pwd-strength { height: 4px; border-radius: 4px; background: #f1f5f9; margin-top: 4px; overflow: hidden; }
.pwd-strength .bar { height: 100%; border-radius: 4px; transition: width .3s, background .3s; width: 0; }

.alert-msg {
    padding: 10px 14px;
    border-radius: 10px;
    font-size: .84rem;
    font-weight: 600;
}
.alert-msg.success { background: #dcfce7; color: #166534; }
.alert-msg.error   { background: #fee2e2; color: #991b1b; }

.form-footer { display: flex; justify-content: flex-end; padding-top: 4px; }
.btn-save {
    background: #0073ff; color: #fff; border: none;
    padding: 10px 22px; border-radius: 10px;
    font-weight: 700; font-size: .88rem; cursor: pointer;
    display: flex; align-items: center; gap: 7px; transition: background .2s;
}
.btn-save:hover    { background: #0062cc; }
.btn-save:disabled { background: #94a3b8; cursor: not-allowed; }

/* Danger zone */
.danger-item {
    display: flex; justify-content: space-between;
    align-items: center; gap: 16px; flex-wrap: wrap;
}
.danger-text { display: flex; flex-direction: column; gap: 3px; }
.danger-text strong { font-size: .92rem; color: #1e293b; font-weight: 700; }
.danger-text span   { font-size: .8rem; color: #94a3b8; max-width: 380px; }

.btn-danger {
    background: #fee2e2; color: #dc2626; border: 1px solid #fecaca;
    padding: 9px 18px; border-radius: 10px;
    font-weight: 700; font-size: .85rem; cursor: pointer;
    display: flex; align-items: center; gap: 7px;
    white-space: nowrap; transition: all .2s;
}
.btn-danger:hover    { background: #dc2626; color: #fff; border-color: #dc2626; }
.btn-danger:disabled { opacity: .5; cursor: not-allowed; }

/* Modal eliminar */
.m-overlay {
    position: fixed; inset: 0;
    background: rgba(15,23,42,.55); backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    z-index: 3000; padding: 20px;
}
.m-overlay.open { display: flex; }

.m-card {
    background: #fff; border-radius: 20px;
    width: 100%; max-width: 420px;
    padding: 32px 28px; text-align: center;
    box-shadow: 0 25px 50px rgba(0,0,0,.15);
}

.m-icon-wrap {
    width: 56px; height: 56px; border-radius: 50%;
    background: #fee2e2; color: #dc2626;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; margin: 0 auto 16px;
}

.m-card h4 { font-size: 1.1rem; font-weight: 800; color: #0f172a; margin: 0 0 8px; }
.m-card p  { font-size: .85rem; color: #64748b; margin: 0 0 12px; line-height: 1.5; }
.confirm-label { font-size: .83rem !important; color: #475569 !important; }

.m-card .fi {
    text-align: center; margin: 8px 0 20px;
    padding: 10px 13px;
}

.m-actions { display: flex; gap: 10px; justify-content: center; }
.btn-ghost {
    background: #f1f5f9; border: none; padding: 10px 20px;
    border-radius: 10px; font-weight: 600; font-size: .88rem;
    cursor: pointer; color: #64748b;
}
</style>

<script>
import { AuthManager } from '../../utils/auth.js';

// ── Mostrar/ocultar contraseña ────────────────────────────────────────────
document.querySelectorAll('.eye-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        const input = document.getElementById(btn.dataset.target);
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        btn.innerHTML = isHidden
            ? '<i class="fas fa-eye-slash"></i>'
            : '<i class="fas fa-eye"></i>';
    });
});

// ── Barra de fortaleza ────────────────────────────────────────────────────
document.getElementById('newPwd').addEventListener('input', function () {
    const v = this.value;
    const bar = document.querySelector('.pwd-strength .bar') || (() => {
        const b = document.createElement('div');
        b.className = 'bar';
        document.querySelector('.pwd-strength').appendChild(b);
        return b;
    })();

    let score = 0;
    if (v.length >= 8)              score++;
    if (/[A-Z]/.test(v))            score++;
    if (/[0-9]/.test(v))            score++;
    if (/[^A-Za-z0-9]/.test(v))     score++;

    const levels = [
        { w: '25%', bg: '#ef4444' },
        { w: '50%', bg: '#f97316' },
        { w: '75%', bg: '#eab308' },
        { w: '100%', bg: '#22c55e' },
    ];
    const l = levels[score - 1] || { w: '0%', bg: '#f1f5f9' };
    bar.style.width      = l.w;
    bar.style.background = l.bg;
});

// ── Cambiar contraseña ────────────────────────────────────────────────────
function showAlert(msg, type) {
    const el = document.getElementById('pwdAlert');
    el.textContent = msg;
    el.className   = `alert-msg ${type}`;
    el.style.display = 'block';
    setTimeout(() => { el.style.display = 'none'; }, 4000);
}

document.getElementById('pwdForm').addEventListener('submit', async e => {
    e.preventDefault();
    const newPwd     = document.getElementById('newPwd').value;
    const confirmPwd = document.getElementById('confirmPwd').value;

    if (newPwd !== confirmPwd) {
        showAlert('Las contraseñas nuevas no coinciden.', 'error');
        return;
    }
    if (newPwd.length < 8) {
        showAlert('La contraseña debe tener al menos 8 caracteres.', 'error');
        return;
    }

    const btn = document.getElementById('btnSavePwd');
    btn.disabled = true;

    try {
        const res = await AuthManager.fetch('/users/me/password', {
            method: 'PATCH',
            body: JSON.stringify({
                current_password: document.getElementById('currentPwd').value,
                new_password:     newPwd,
            }),
        });
        if (res) {
            showAlert('Contraseña actualizada correctamente.', 'success');
            document.getElementById('pwdForm').reset();
            const bar = document.querySelector('.pwd-strength .bar');
            if (bar) bar.style.width = '0';
        }
    } catch (err) {
        showAlert(err.message || 'Error al actualizar la contraseña.', 'error');
    } finally {
        btn.disabled = false;
    }
});

// ── Eliminar cuenta ───────────────────────────────────────────────────────
document.getElementById('btnDeleteAccount').addEventListener('click', () => {
    document.getElementById('deleteModal').classList.add('open');
    document.getElementById('deleteConfirmInput').value = '';
    document.getElementById('btnConfirmDelete').disabled = true;
});

document.getElementById('deleteConfirmInput').addEventListener('input', function () {
    document.getElementById('btnConfirmDelete').disabled = this.value !== 'ELIMINAR';
});

document.getElementById('btnCancelDelete').addEventListener('click', () => {
    document.getElementById('deleteModal').classList.remove('open');
});

document.getElementById('deleteModal').addEventListener('click', e => {
    if (e.target === e.currentTarget)
        document.getElementById('deleteModal').classList.remove('open');
});

document.getElementById('btnConfirmDelete').addEventListener('click', async () => {
    const btn = document.getElementById('btnConfirmDelete');
    btn.disabled = true;
    try {
        await AuthManager.fetch('/users/me', { method: 'DELETE' });
        localStorage.clear();
        window.location.href = '/';
    } catch (err) {
        alert('Error al eliminar la cuenta: ' + err.message);
        btn.disabled = false;
    }
});
</script>
