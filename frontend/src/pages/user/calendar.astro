---
// src/pages/user/calendar.astro - Pixel Perfect v2
import UserLayout from "../../layouts/UserLayout.astro";
---

<UserLayout title="Mi Calendario" subtitle="Eventos y actividades programadas para tu comunidad.">
    <div class="calendar-container glass-morphism">
        <div class="calendar-header">
            <div class="month-nav">
                <button class="nav-btn"><i class="fas fa-chevron-left"></i></button>
                <h2>Marzo 2026</h2>
                <button class="nav-btn"><i class="fas fa-chevron-right"></i></button>
            </div>
            <div class="calendar-legend">
                <div class="legend-item"><span class="dot online"></span> Online</div>
                <div class="legend-item"><span class="dot presencial"></span> Presencial</div>
            </div>
        </div>

        <div class="calendar-grid">
            <!-- Days of week -->
            <div class="day-name">Dom</div><div class="day-name">Lun</div><div class="day-name">Mar</div><div class="day-name">Mié</div>
            <div class="day-name">Jue</div><div class="day-name">Vie</div><div class="day-name">Sáb</div>

            <!-- Empty cells (example start on Sunday for March 2026) -->
            <div class="day-cell muted">1</div><div class="day-cell">2</div><div class="day-cell">3</div><div class="day-cell">4</div>
            <div class="day-cell">5</div><div class="day-cell">6</div><div class="day-cell">7</div>
            <div class="day-cell">8</div><div class="day-cell">9</div><div class="day-cell">10</div><div class="day-cell">11</div>
            <div class="day-cell">12</div><div class="day-cell">13</div><div class="day-cell">14</div>
            <div class="day-cell today">
                <span class="day-num">15</span>
                <div class="event-pill online">Hackathon</div>
            </div>
            <div class="day-cell">16</div><div class="day-cell">17</div><div class="day-cell">18</div>
            <div class="day-cell">19</div><div class="day-cell">20</div><div class="day-cell">21</div>
            <div class="day-cell">
                <span class="day-num">22</span>
                <div class="event-pill presencial">Charla IA</div>
            </div>
            <div class="day-cell">23</div><div class="day-cell">24</div><div class="day-cell">25</div>
            <div class="day-cell">26</div><div class="day-cell">27</div><div class="day-cell">28</div>
            <div class="day-cell">29</div><div class="day-cell">30</div><div class="day-cell">31</div>
        </div>
    </div>
</UserLayout>

<style is:global>
    .glass-morphism {
        background: white;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        padding: 2.5rem;
    }

    .calendar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
    }

    .month-nav { display: flex; align-items: center; gap: 1.5rem; }
    .month-nav h2 { font-size: 1.6rem; font-weight: 800; color: #0f172a; margin: 0; }
    .nav-btn { 
        width: 36px; 
        height: 36px; 
        border-radius: 10px; 
        border: 1px solid #e2e8f0; 
        background: white; 
        color: #64748b; 
        cursor: pointer; 
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .nav-btn:hover { background: #007bff; color: white; border-color: #007bff; transform: translateY(-1px); }

    .calendar-legend { display: flex; gap: 1.5rem; }
    .legend-item { display: flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; font-weight: 700; color: #64748b; }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot.online { background: #007bff; box-shadow: 0 0 10px rgba(0,123,255,0.2); }
    .dot.presencial { background: #f43f5e; box-shadow: 0 0 10px rgba(244,63,94,0.2); }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        border: 1px solid #f1f5f9;
        border-radius: 16px;
        overflow: hidden;
    }

    .day-name {
        background: #f8fafc;
        padding: 1rem;
        text-align: center;
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #94a3b8;
        border-bottom: 1px solid #f1f5f9;
        letter-spacing: 0.05em;
    }

    .day-cell {
        min-height: 120px;
        padding: 0.75rem;
        background: white;
        border-right: 1px solid #f1f5f9;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: background 0.2s;
    }
    .day-cell:hover { background: #fdfdfe; }

    .day-cell:nth-child(7n) { border-right: none; }
    
    .day-num { font-size: 1rem; font-weight: 700; color: #1e293b; }
    .day-cell.muted .day-num { color: #cbd5e1; }
    .day-cell.today .day-num { 
        background: #007bff; 
        color: white; 
        width: 28px; 
        height: 28px; 
        border-radius: 50%; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        box-shadow: 0 4px 10px rgba(0,123,255,0.3);
    }

    .event-pill {
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 800;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .event-pill.online { background: #eff6ff; color: #007bff; border-left: 3px solid #007bff; }
    .event-pill.presencial { background: #fff1f2; color: #f43f5e; border-left: 3px solid #f43f5e; }

    @media (max-width: 1024px) {
        .calendar-header { flex-direction: column; gap: 1.5rem; align-items: flex-start; }
        .day-cell { min-height: 100px; }
    }

    @media (max-width: 640px) {
        .day-cell { min-height: 70px; padding: 0.4rem; }
        .event-pill { font-size: 0.65rem; padding: 4px; border-left-width: 2px; }
        .month-nav h2 { font-size: 1.3rem; }
    }
</style>

</style>
