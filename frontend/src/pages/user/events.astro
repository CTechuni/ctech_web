import UserLayout from "../../layouts/UserLayout.astro";

const title = "Eventos";
---

<UserLayout title={title} subtitle="Descubre y participa en eventos de la comunidad">
    <div class="user-events-section">
        <div class="row g-4" id="userEventsContainer">
            <div class="loading-state">
                <div class="spinner"></div>
                <span>Buscando eventos disponibles...</span>
            </div>
        </div>
    </div>
</UserLayout>

<style>
.user-events-section {
    padding: 0;
}

:global(.event-card-modern) {
    background: white;
    border-radius: 16px;
    padding: 1.25rem;
    border: 1px solid #f1f5f9;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.2s ease;
    position: relative;
    height: 100%;
}

:global(.event-card-modern:hover) {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    border-color: #e2e8f0;
}

:global(.event-card-img) {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 12px;
}

:global(.card-header-flex) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

:global(.modal-badge) {
    font-size: 0.65rem;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 40px;
    text-transform: uppercase;
    width: fit-content;
}

:global(.badge-virtual) { background: rgba(0, 115, 255, 0.05); color: #007bff; }
:global(.badge-presencial) { background: #fff1f2; color: #db2777; }

:global(.date-badge) {
    text-align: left;
    line-height: 1;
}

:global(.date-day) {
    font-size: 1.4rem;
    font-weight: 800;
    color: #007bff;
    display: block;
}

:global(.date-month) {
    font-size: 0.75rem;
    font-weight: 700;
    color: #94a3b8;
    text-transform: uppercase;
}

:global(.card-content h3) {
    font-size: 1rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
}

:global(.card-desc) {
    font-size: 0.82rem;
    color: #64748b;
    line-height: 1.5;
    height: 2.5rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

:global(.card-footer-details) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.85rem;
    border-top: 1px solid #f1f5f9;
    margin-top: auto;
}

:global(.footer-detail-item) {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    color: #64748b;
    font-weight: 600;
}

.btn-reg-full {
    width: 100%;
    background: #007bff;
    color: white;
    border: none;
    padding: 10px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-reg-full:hover { background: #0062cc; transform: translateY(-1px); }
.btn-reg-full:disabled { background: #e2e8f0; color: #94a3b8; cursor: not-allowed; transform: none; }

.btn-cancel-full {
    width: 100%;
    background: white;
    color: #ef4444;
    border: 1.5px solid rgba(239, 68, 68, 0.2);
    padding: 10px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-cancel-full:hover { background: #fff5f5; border-color: #ef4444; }

.spinner { width: 28px; height: 28px; border: 3px solid #f1f5f9; border-top-color: #007bff; border-radius: 50%; animation: spin 1s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-state { grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 4rem; color: #94a3b8; }
</style>

<script>
    import { authManager, AuthManager } from '../../utils/auth.js';

    function optimizeImageUrl(url, width = 600) {
        if (!url || typeof url !== 'string' || !url.includes('cloudinary.com')) return url || '';
        const parts = url.split('/upload/');
        if (parts.length !== 2) return url;
        return `${parts[0]}/upload/f_auto,q_auto,w_${width},c_fill/${parts[1]}`;
    }

    let allEvents: any[] = [];

    document.addEventListener('DOMContentLoaded', async () => {
        loadEvents();
    });

    async function loadEvents() {
        const container = document.getElementById('userEventsContainer');
        if (!container) return;

        try {
            const events = await AuthManager.fetch('/events/');
            allEvents = events || [];
            renderEvents(allEvents);
        } catch (err) {
            console.error('Error loading events:', err);
            container.innerHTML = '<div class="loading-state"><span>Error al cargar los eventos.</span></div>';
        }
    }

    function renderEvents(events) {
        const container = document.getElementById('userEventsContainer');
        if (!container) return;

        if (events.length === 0) {
            container.innerHTML = '<div class="loading-state"><span>No hay eventos disponibles actualmente.</span></div>';
            return;
        }

        container.innerHTML = events.map(e => {
            const dateObj = new Date(e.event_date + 'T00:00:00');
            const day = dateObj.getDate();
            const month = dateObj.toLocaleDateString('es', { month: 'short' }).toUpperCase();

            const type = e.event_type?.toLowerCase() === 'presencial' ? 'presencial' : 'virtual';
            const badgeClass = type === 'virtual' ? 'badge-virtual' : 'badge-presencial';
            
            const optimizedImg = optimizeImageUrl(e.image_url, 600);
            const imgHtml = e.image_url ? `<img src="${optimizedImg}" class="event-card-img" alt="${e.title}" />` : '';

            const isRegistered = e.is_registered;
            const isFull = e.capacity && e.registered_count >= e.capacity;

            let actionButton = '';
            if (isRegistered) {
                actionButton = `<button class="btn-cancel-full" data-id="${e.id}">Cancelar Registro</button>`;
            } else if (isFull) {
                actionButton = `<button class="btn-reg-full" disabled>Sin Cupos</button>`;
            } else {
                actionButton = `<button class="btn-reg-full" data-id="${e.id}">Registrarme</button>`;
            }

            return `
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="event-card-modern">
                        ${imgHtml}
                        <div class="card-header-flex">
                            <span class="modal-badge ${badgeClass}">${type}</span>
                            <div class="date-badge">
                                <span class="date-day">${day}</span>
                                <span class="date-month">${month}</span>
                            </div>
                        </div>
                        <div class="card-content">
                            <h3>${e.title}</h3>
                            <p class="card-desc">${e.description || 'Sin descripción disponible.'}</p>
                        </div>
                        <div class="card-footer-details">
                            <div class="footer-detail-item">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:14px;height:14px;">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                                <span>${e.event_time?.slice(0, 5) || '18:30'}h</span>
                            </div>
                            <div class="footer-detail-item">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:14px;height:14px;">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                                </svg>
                                <span>${e.location || 'Virtual'}</span>
                            </div>
                        </div>
                        <div style="margin-top: 1rem;">
                            ${actionButton}
                        </div>
                    </div>
                </div>
            `;
        }).join('');

        // Listeners
        container.querySelectorAll('.btn-reg-full, .btn-cancel-full').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = (e.currentTarget as HTMLElement).dataset.id;
                const isCancel = (e.currentTarget as HTMLElement).classList.contains('btn-cancel-full');
                if (id) handleRegistration(parseInt(id), isCancel);
            });
        });
    }

    async function handleRegistration(eventId: number, isCancel: boolean) {
        try {
            if (isCancel) {
                const result = await (window as any).Swal?.fire({
                    title: '¿Confirmar cancelación?',
                    text: 'Se liberará tu cupo para otros miembros.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, cancelar',
                    cancelButtonText: 'Volver'
                });
                if (!result.isConfirmed) return;

                await AuthManager.fetch(`/events/${eventId}/register`, { method: 'DELETE' });
                (window as any).Swal?.fire('Registro cancelado', 'Ya no estás inscrito en este evento.', 'info');
            } else {
                await AuthManager.fetch(`/events/${eventId}/register`, { method: 'POST' });
                (window as any).Swal?.fire('¡Inscripción exitosa!', 'Te esperamos en el evento.', 'success');
            }
            loadEvents();
        } catch (error: any) {
            console.error('Error handling registration:', error);
            const msg = error.message || 'Error al procesar la solicitud.';
            (window as any).Swal?.fire('Error', msg, 'error');
        }
    }
</script>