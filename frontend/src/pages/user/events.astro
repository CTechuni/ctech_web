---
import MainLayout from "../../layouts/MainLayout.astro";
import { escapeHtml } from '../../utils/escape.js'; // if exists, else not needed
const title = "Eventos";
---

<MainLayout title={title}>
    <div class="user-events-container" id="userEventsContainer">
        <p>Cargando eventos...</p>
    </div>
</MainLayout>

<style>
.user-events-container {
    max-width: 1000px;
    margin: 2rem auto;
    padding: 0 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
    gap: 1.5rem;
}
.event-card {
    background: white;
    border-radius: 12px;
    border: 1px solid var(--color-light-grey);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
}
.event-card h3 {
    font-size: 1.1rem;
    margin: 0;
}
.event-card .register-btn {
    margin-top: auto;
}
</style>

<script>
    import { authManager, AuthManager } from '../../utils/auth.js';

    let allEvents = [];

    document.addEventListener('DOMContentLoaded', async () => {
        const user = authManager.getUser();
        if (!user) return;
        try {
            const events = await AuthManager.fetch('/events/');
            allEvents = events || [];
            const communityId = user.community_id;
            const filtered = allEvents.filter(e => e.status === 'approved');
            renderEvents(filtered);
        } catch (err) {
            console.error('Error loading events for user:', err);
            const c = document.getElementById('userEventsContainer');
            if (c) c.innerHTML = '<p>Error cargando eventos.</p>';
        }
    });

    function getRegistrationMap() {
        try {
            return JSON.parse(localStorage.getItem('eventRegs') || '{}');
        } catch {
            return {};
        }
    }

    function setRegistrationMap(map) {
        localStorage.setItem('eventRegs', JSON.stringify(map));
    }

    function renderEvents(events) {
        const container = document.getElementById('userEventsContainer');
        if (!container) return;
        if (events.length === 0) {
            container.innerHTML = '<p>No hay eventos disponibles para tu comunidad.</p>';
            return;
        }
        const regs = getRegistrationMap();
        container.innerHTML = '';
        events.forEach(ev => {
            const card = document.createElement('div');
            card.className = 'event-card';
            const reg = regs[ev.id_event] || 0;
            const available = (ev.capacity || 0) - reg;
            card.innerHTML = `
                <h3>${escapeHtml(ev.title)}</h3>
                <p><strong>Tipo:</strong> ${escapeHtml(ev.type_event)}</p>
                <p><strong>Fecha:</strong> ${escapeHtml(ev.date_events)} ${escapeHtml(ev.time_events || '')}</p>
                <p><strong>Cupos:</strong> ${available <= 0 ? '<span style="color:#ef4444;">0</span>' : available}</p>
                <button class="btn register-btn">${reg ? 'Cancelar Registro' : (available<=0 ? 'No hay disponibilidad' : 'Registrarme')}</button>
            `;
            const btn = card.querySelector('button.register-btn');
            if (btn) {
                if (available <= 0 && !reg) btn.disabled = true;
                btn.addEventListener('click', () => toggleRegistration(ev.id_event));
            }
            container.appendChild(card);
        });
    }

    function cancelRegistration(eventId) {
        const regs = getRegistrationMap();
        delete regs[eventId];
        setRegistrationMap(regs);
    }

    async function toggleRegistration(eventId) {
        const regs = getRegistrationMap();
        const already = regs[eventId] || 0;
        const ev = allEvents.find(e => e.id_event === eventId);
        if (!ev) return;
        
        const cap = ev.capacity || 0;
        
        if (!already) {
            if (cap <= 0) return; // no space
            
            try {
                // LLAMADA AL BACKEND PARA REGISTRO Y ENVÍO DE EMAIL
                const response = await AuthManager.fetch(`/events/${eventId}/register`, {
                    method: 'POST'
                });

                if (response && (response.message === "Registro exitoso" || response.event_title)) {
                    regs[eventId] = 1;
                    setRegistrationMap(regs);
                    alert(`¡Inscripción exitosa a "${ev.title}"! Se ha enviado una confirmación a tu correo.`);
                } else {
                    alert("No se pudo completar el registro en este momento.");
                }
            } catch (err) {
                console.error('Error registering for event:', err);
                alert("Error al procesar el registro. Intenta de nuevo.");
            }
        } else {
            // Cancelación (por ahora sigue siendo local)
            cancelRegistration(eventId);
            alert("Has cancelado tu registro al evento.");
        }
        
        setRegistrationMap(regs);
        
        // Re-renderizar lista filtrada
        const user = authManager.getUser();
        if (user) {
            const communityId = user.community_id;
            const filtered = allEvents.filter(e => e.status === 'approved');
            renderEvents(filtered);
        }
    }
</script>