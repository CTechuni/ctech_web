---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Restablecer Contraseña - CTech">
    <main class="reset-page">
        <!-- Decoración de fondo -->
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        
        <div class="reset-container">
            <div class="reset-card" id="reset-card-password-container">
                <div class="logo-container">
                    <a href="/">
                        <img src="/LogoCTech.svg" alt="CTech Logo" class="brand-logo" />
                    </a>
                </div>
                <h2>Crea tu nueva contraseña</h2>
                <p class="subtitle">Ingresa tu nueva contraseña para recuperar el acceso a tu cuenta de CTech.</p>

                <form id="resetPasswordForm" class="reset-form">
                    <input type="hidden" id="resetEmail" name="email" value="" />
                    
                    <div class="confirm-password-new">
                        <label for="newPassword">Nueva Contraseña</label>
                        <div class="password-wrapper">
                            <input 
                                type="password" 
                                id="newPassword" 
                                name="newPassword" 
                                placeholder="••••••••"
                                required
                            >
                            <button type="button" class="toggle-password" data-target="newPassword">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                            </button>
                        </div>
                        <span class="error-message" id="newPasswordError"></span>
                    </div>

                    <div class="confirm-password-new">
                        <label for="confirmPassword">Confirmar Nueva Contraseña</label>
                        <div class="password-wrapper">
                            <input 
                                type="password" 
                                id="confirmPassword" 
                                name="confirmPassword" 
                                placeholder="••••••••"
                                required
                            >
                            <button type="button" class="toggle-password" id="toggleConfirmPassword" data-target="confirmPassword">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                            </button>
                        </div>
                        <span class="error-message" id="confirmPasswordError"></span>
                    </div>

                    <div class="password-requirements">
                        <p>La contraseña debe contener al menos:</p>
                        <ul>
                            <li id="req-length" class="req-item">Entre 5 y 13 caracteres</li>
                            <li id="req-upper" class="req-item">Una letra mayúscula</li>
                            <li id="req-lower" class="req-item">Una letra minúscula</li>
                            <li id="req-number" class="req-item">Un número</li>
                            <li id="req-special" class="req-item">Un carácter especial (!@#$...)</li>
                        </ul>
                    </div>

                    <div id="resetErrorArea" style="display: none;">
                        <span class="error-message visible" style="display:block; text-align:center; margin-bottom: 1rem;" id="generalError"></span>
                    </div>

                    <button type="submit" class="btn-primary" id="resetSubmitBtn">
                        Actualizar Contraseña
                    </button>
                    
                    <a href="/" class="btn-cancel">Cancelar</a>
                </form>

                <div id="resetSuccessArea" style="display: none; text-align: center; margin-top: 1rem;">
                    <div class="alert alert-success" style="border-radius: 12px; font-size: 0.9rem; font-weight: 500; background-color: #dcfce7; color: #166534; padding: 1rem; border: 1px solid #bbf7d0; margin-bottom: 1rem;">
                        ¡Contraseña actualizada con éxito! Redirigiendo al inicio de sesión...
                    </div>
                </div>
            </div>
        </div>
    </main>
</MainLayout>

<style>
    /* Estilos Premium CTech (Glassmorphism + Modern UI) */
    .reset-page {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: radial-gradient(circle at top right, #0f172a, #020617);
        position: relative;
        overflow: hidden;
        font-family: 'Inter', sans-serif;
    }

    /* Background blobs */
    .blob {
        position: absolute;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.6;
        border-radius: 50%;
    }
    .blob-1 {
        top: -10%;
        left: -10%;
        width: 50vw;
        height: 50vw;
        background: linear-gradient(to right, #0073ff4d, #a42aff4d);
        animation: float 10s ease-in-out infinite alternate;
    }
    .blob-2 {
        bottom: -10%;
        right: -10%;
        width: 40vw;
        height: 40vw;
        background: linear-gradient(to right, #0ea5e94d, #3b82f64d);
        animation: float 12s ease-in-out infinite alternate-reverse;
    }

    @keyframes float {
        0% { transform: translateY(0) scale(1); }
        100% { transform: translateY(-20px) scale(1.05); }
    }

    .reset-container {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 480px;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .logo-container {
        margin-bottom: 2rem;
        display: flex;
        justify-content: center;
    }
    .brand-logo {
        height: 45px;
        width: auto;
        filter: brightness(0);
    }

    .reset-card {
    width: 100%;
    background: #fff;
    color: #000;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}

    .reset-card h2 {
        color: #1e293b;
        font-size: 1.75rem;
        font-weight: 700;
        margin-top: 0;
        margin-bottom: 0.5rem;
        text-align: center;
    }

    .subtitle {
        color: #94a3b8;
        font-size: 0.95rem;
        text-align: center;
        margin-bottom: 2rem;
        line-height: 1.5;
    }

    .reset-form {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .form-group, .confirm-password-new {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .confirm-password-new + .confirm-password-new {
        margin-top: 0.5rem;
    }

    .form-group label, .confirm-password-new label {
        color: var(--color-primary-dark);
        font-size: 0.9rem;
        font-weight: 500;
        margin-left: 1rem;
    }

    .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }
    
    .form-group input, .confirm-password-new input {
        width: 100%;
        padding: 0.6rem 1rem;
        border: 1px solid #dbdee1;
        border-radius: 25px;
        color: #000;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

    .form-group input:focus, .confirm-password-new input:focus {
        outline: none;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
    }
    
    .form-group input.error, .confirm-password-new input.error {
        border-color: #ef4444;
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2);
    }

    .toggle-password {
        position: absolute;
        right: 1.2rem;
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        transition: color 0.2s;
        z-index: 10;
        pointer-events: auto;
    }

    .toggle-password:hover {
        color: #e2e8f0;
    }

    .error-message {
        color: #ef4444;
        font-size: 0.8rem;
        margin-left: 1rem;
        display: none;
    }

    .error-message.visible {
        display: block;
    }

    .password-requirements {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 1rem 1.25rem;
        margin-top: 0.5rem;
    }

    .password-requirements p {
        color: #cbd5e1;
        font-size: 0.85rem;
        font-weight: 500;
        margin-top: 0;
        margin-bottom: 0.5rem;
    }

    .password-requirements ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.4rem;
    }

    .req-item {
        color: #64748b;
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: color 0.3s;
    }
    
    .req-item::before {
        content: '○';
        font-size: 0.7rem;
    }

    .req-item.valid {
        color: #10b981;
    }
    .req-item.valid::before {
        content: '●';
    }

    .btn-primary {
        background: var(--color-azure-radiant, #0073ff);
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 9999px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 0.5rem;
    }

    .btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -10px rgba(0, 115, 255, 0.5);
    }

    .btn-primary:disabled {
        background: #475569;
        cursor: not-allowed;
        opacity: 0.7;
    }
    
    .btn-cancel {
        text-align: center;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
        margin-top: 0.5rem;
    }
    .btn-cancel:hover {
        color: #fff;
    }

    @media (max-width: 480px) {
        .reset-container {
            padding: 1rem;
        }
        .reset-card {
            padding: 2rem 1.5rem;
        }
    }
</style>

<script>
    import { API_CONFIG, buildApiUrl } from '../config/api.js';

    // Global error logger for UI
    function showGeneralError(msg) {
        const errorArea = document.getElementById('resetErrorArea');
        const generalError = document.getElementById('generalError');
        if (errorArea && generalError) {
            errorArea.style.display = 'block';
            generalError.textContent = msg;
            console.error('UI Error shown:', msg);
        } else {
            alert(msg); // Fallback extreme
        }
    }

    function init() {
        try {
            console.log('>>> Secure Reset System Initialized <<<');
            
            const urlParams = new URLSearchParams(window.location.search);
            const email = urlParams.get('email');
            const token = urlParams.get('token');
            
            const form = document.getElementById('resetPasswordForm');
            const submitBtn = document.getElementById('resetSubmitBtn');
            const errorArea = document.getElementById('resetErrorArea');
            const generalError = document.getElementById('generalError');
            
            if (!form || !submitBtn) {
                console.error('CRITICAL: Form or Button missing in DOM');
                return;
            }

            // Validar parámetros iniciales
            if (!email || !token) {
                console.warn('Security parameters missing in URL');
                showGeneralError('Enlace de recuperación inválido o incompleto. Por favor, solicita uno nuevo.');
                submitBtn.disabled = true;
                return;
            }

            // Pre-fill email hidden field
            const emailInput = document.getElementById('resetEmail');
            if (emailInput) emailInput.value = email;
            console.log('Handshake: SUCCESS');

            // 2. Manejo de visibilidad de contraseña (Universal & Robust)
            document.querySelectorAll('.toggle-password').forEach(btn => {
                btn.onclick = function(e) {
                    e.preventDefault();
                    const targetId = this.getAttribute('data-target');
                    const input = document.getElementById(targetId);
                    
                    if (input) {
                        const isPassword = input.type === 'password';
                        input.type = isPassword ? 'text' : 'password';
                        
                        // Icon change (Eye vs Eye-slash)
                        this.innerHTML = isPassword ? 
                            `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>` : 
                            `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>`;
                    }
                };
            });

            // 3. Requisitos visuales (Feedback en tiempo real)
            const mainPassInput = document.getElementById('newPassword');
            if (mainPassInput) {
                mainPassInput.addEventListener('input', (e) => {
                    const val = e.target.value;
                    const reqs = {
                        length: document.getElementById('req-length'),
                        upper: document.getElementById('req-upper'),
                        lower: document.getElementById('req-lower'),
                        number: document.getElementById('req-number'),
                        special: document.getElementById('req-special')
                    };
                    if (val.length >= 5 && val.length <= 13) reqs.length?.classList.add('valid'); else reqs.length?.classList.remove('valid');
                    if (/[A-Z]/.test(val)) reqs.upper?.classList.add('valid'); else reqs.upper?.classList.remove('valid');
                    if (/[a-z]/.test(val)) reqs.lower?.classList.add('valid'); else reqs.lower?.classList.remove('valid');
                    if (/\d/.test(val)) reqs.number?.classList.add('valid'); else reqs.number?.classList.remove('valid');
                    if (/[!@#$%^&*(),.?":{}|<>]/.test(val)) reqs.special?.classList.add('valid'); else reqs.special?.classList.remove('valid');
                });
            }

            // 4. SUBMIT HANDLER (Lógica de validación robusta)
            form.onsubmit = async function(e) {
                e.preventDefault();
                console.log('>>> ATTEMPTING PASSWORD UPDATE <<<');

                // Obtener elementos SEGUROS (dentro del formulario para evitar duplicados en layouts)
                const p1El = form.querySelector('[name="newPassword"]');
                const p2El = form.querySelector('[name="confirmPassword"]');
                const errNew = document.getElementById('newPasswordError');
                const errConfirm = document.getElementById('confirmPasswordError');
                const errorArea = document.getElementById('resetErrorArea');
                const generalError = document.getElementById('generalError');
                
                if (!p1El || !p2El || !errorArea || !generalError) {
                    console.error('CRITICAL: Element selection failed', { p1El, p2El });
                    return;
                }

                // Normalización Agresiva (Unicode + Todos los tipos de espacio)
                const normalizeVal = (val) => val.replace(/^[\s\uFEFF\xA0]+|[\s\uFEFF\xA0]+$/g, '').normalize('NFC');
                
                const p1 = normalizeVal(p1El.value);
                const p2 = normalizeVal(p2El.value);
                
                console.warn(`VALIDATION - P1: ${p1.length} chars, P2: ${p2.length} chars`);
                const stringsMatch = (p1 === p2);
                console.warn('MATCH RESULT:', stringsMatch);

                // Limpieza TOTAL de estados previos
                [errNew, errConfirm].forEach(el => { if(el) { el.textContent = ''; el.classList.remove('visible'); }});
                [p1El, p2El].forEach(el => el.classList.remove('error'));
                if (errorArea) errorArea.style.display = 'none';
                if (generalError) generalError.textContent = '';

                let hasErrors = false;

                // A. Validar Complejidad básica
                const complexityOk = p1.length >= 5 && /[A-Z]/.test(p1) && /[a-z]/.test(p1) && /\d/.test(p1) && /[!@#$%^&*(),.?":{}|<>]/.test(p1);
                if (!complexityOk) {
                    console.warn('COMPLEXITY CHECK FAILED');
                    if (errNew) { 
                        errNew.textContent = "Requisitos mínimos no cumplidos (Mayúscula, minúscula, número y especial)."; 
                        errNew.classList.add('visible'); 
                    }
                    p1El.classList.add('error');
                    hasErrors = true;
                }

                // B. Validar Coincidencia (REQUERIMIENTO PRINCIPAL DEL USUARIO)
                if (!stringsMatch) {
                    console.error('MISMATCH DETECTED - Strings do not match');
                    
                    // Detalle del desajuste para consola (Hexadecimal)
                    const toHex = (s) => Array.from(s).map(c => c.charCodeAt(0).toString(16).padStart(4, '0')).join(' ');
                    console.warn(`P1 HEX: [ ${toHex(p1)} ]`);
                    console.warn(`P2 HEX: [ ${toHex(p2)} ]`);

                    if (errConfirm) { 
                        errConfirm.textContent = "Las contraseñas no coinciden."; 
                        errConfirm.classList.add('visible'); 
                    }
                    p2El.classList.add('error');
                    
                    // Alerta visual de error general
                    if (errorArea && generalError) {
                        errorArea.style.display = 'block';
                        generalError.textContent = 'Las contraseñas no coinciden. Revisa que ambas sean idénticas.';
                    }
                    hasErrors = true;
                }

                if (hasErrors) {
                    console.error('SUBMISSION ABORTED - Validation Failed');
                    return;
                }

                // C. Ejecutar Fetch si todo es OK (Requerimiento 4)
                const originalText = submitBtn.textContent;
                submitBtn.textContent = 'Actualizando...';
                submitBtn.disabled = true;

                try {
                    const url = buildApiUrl(API_CONFIG.AUTH.RESET_PASSWORD);
                    console.log('Calling API:', url);

                    const response = await fetch(url, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            email: email, 
                            token: token, 
                            new_password: p1 
                        })
                    });

                    const data = await response.json().catch(() => ({ detail: 'Error en el cuerpo de la respuesta' }));
                    console.log('Server Status:', response.status);

                    if (response.ok) {
                        console.log('PASSWORD UPDATED SUCCESSFULLY');
                        form.style.display = 'none';
                        const successArea = document.getElementById('resetSuccessArea');
                        if (successArea) {
                            successArea.style.display = 'block';
                            successArea.scrollIntoView({ behavior: 'smooth' });
                        }
                        setTimeout(() => window.location.href = '/?action=login', 3000);
                    } else {
                        throw new Error(data.detail || 'El servidor no pudo procesar la solicitud.');
                    }
                } catch (err) {
                    console.error('Fetch Error:', err);
                    showGeneralError(err.message || 'Error de conexión con el servidor.');
                    submitBtn.textContent = originalText;
                    submitBtn.disabled = false;
                }
            };

            console.log('System ready.');

        } catch (e) {
            console.error('Critical Init Exception:', e);
            showGeneralError('Ocurrió un error al cargar el formulario. Por favor, recarga la página.');
        }
    }

    // Auto-exec
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    // Catch globally
    window.onerror = function(msg, url, line) {
        console.error('Caught Global Error:', msg, 'at', url, ':', line);
        return false;
    };
</script>
</MainLayout>
