---
import LeaderLayout from '../../layouts/LeaderLayout.astro';
---

<LeaderLayout title="Categorías" subtitle="Categorías de cursos de tu comunidad">
<div class="page-wrap">

    <div class="page-header">
        <div>
            <h1 class="page-title"><i class="fa-solid fa-tag"></i> Categorías</h1>
            <p class="page-sub">Categorías disponibles para la creación de cursos</p>
        </div>
        <button class="btn-add" id="btnShowForm">
            <i class="fa-solid fa-plus"></i> Nueva Categoría
        </button>
    </div>

    <!-- Add form (hidden by default) -->
    <div class="add-form" id="addForm" style="display:none">
        <div class="form-card">
            <h3>Nueva categoría</h3>
            <form id="specialtyForm">
                <div class="fg">
                    <label>Nombre <span class="req">*</span></label>
                    <input type="text" id="fName" class="fi" placeholder="Ej: Desarrollo Web, Data Science..." required />
                </div>
                <div class="form-actions">
                    <button type="button" class="btn-ghost" id="btnCancel">Cancelar</button>
                    <button type="submit" class="btn-save" id="btnSave">
                        <i class="fa-solid fa-check"></i> Guardar
                    </button>
                </div>
            </form>
            <div id="formMsg" style="display:none"></div>
        </div>
    </div>

    <!-- Alert / info -->
    <div class="info-banner">
        <i class="fa-solid fa-circle-info"></i>
        Las categorías creadas aquí estarán disponibles para que los mentores las elijan al crear un curso.
    </div>

    <!-- Grid of specialties -->
    <div class="spec-grid" id="specGrid">
        <div class="loading-state">
            <div class="spinner"></div> Cargando categorías...
        </div>
    </div>
</div>
</LeaderLayout>

<style>
.page-wrap { max-width: 900px; display: flex; flex-direction: column; gap: 20px; }

.page-header { display: flex; justify-content: space-between; align-items: flex-start; }
.page-title { font-size: 1.5rem; font-weight: 800; color: #0f172a; margin: 0; display: flex; align-items: center; gap: 10px; }
.page-title i { color: #3b82f6; }
.page-sub { font-size: .85rem; color: #64748b; margin: 4px 0 0 0; }

.btn-add {
    background: #3b82f6; color: #fff; border: none;
    padding: 10px 18px; border-radius: 10px; font-weight: 700; font-size: .88rem;
    cursor: pointer; display: flex; align-items: center; gap: 7px; white-space: nowrap;
    box-shadow: 0 4px 12px rgba(59,130,246,.25); transition: all .2s;
}
.btn-add:hover { background: #2563eb; transform: translateY(-1px); }

.form-card {
    background: #fff; border-radius: 16px; border: 1.5px solid #3b82f6;
    padding: 24px; box-shadow: 0 4px 16px rgba(59,130,246,.1);
}
.form-card h3 { margin: 0 0 18px; font-size: 1rem; font-weight: 700; color: #0f172a; }
.fg { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.fg label { font-size: .8rem; font-weight: 700; color: #475569; }
.fi {
    border: 1px solid #e2e8f0; border-radius: 10px;
    padding: 10px 13px; font-size: .88rem; color: #1e293b;
    font-family: inherit; outline: none; width: 100%; box-sizing: border-box;
}
.fi:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.1); }
.req  { color: #ef4444; }
.hint { font-weight: 400; color: #94a3b8; }
.form-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 18px; }
.btn-ghost { background: #f1f5f9; border: none; padding: 9px 20px; border-radius: 10px; font-weight: 600; font-size: .87rem; cursor: pointer; color: #64748b; }
.btn-save { background: #3b82f6; color: #fff; border: none; padding: 9px 20px; border-radius: 10px; font-weight: 700; font-size: .87rem; cursor: pointer; display: flex; align-items: center; gap: 6px; }
.btn-save:disabled { background: #94a3b8; cursor: not-allowed; }

#formMsg { padding: 10px 14px; border-radius: 8px; font-size: .85rem; font-weight: 600; margin-top: 12px; }
#formMsg.success { background: #dcfce7; color: #15803d; }
#formMsg.error   { background: #fee2e2; color: #dc2626; }

.info-banner {
    background: #eff6ff; color: #1d4ed8; border-radius: 10px;
    padding: 12px 16px; font-size: .83rem; font-weight: 500;
    display: flex; align-items: center; gap: 10px;
}

.spec-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.spec-card {
    background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
    padding: 20px; display: flex; align-items: flex-start; gap: 14px;
    transition: all .2s;
}
.spec-card:hover { box-shadow: 0 8px 20px rgba(0,0,0,.06); transform: translateY(-2px); }
.spec-icon {
    width: 42px; height: 42px; border-radius: 12px; background: #eff6ff;
    color: #3b82f6; display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; flex-shrink: 0;
}
.spec-info h4 { margin: 0 0 4px; font-size: .95rem; font-weight: 700; color: #0f172a; }
.spec-info p  { margin: 0; font-size: .78rem; color: #64748b; }

.loading-state { grid-column: 1/-1; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 3rem; color: #94a3b8; }
.spinner { width: 20px; height: 20px; border: 3px solid #f1f5f9; border-top-color: #3b82f6; border-radius: 50%; animation: spin 1s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty { grid-column: 1/-1; text-align: center; padding: 2.5rem; color: #94a3b8; }

@media(max-width: 768px) { .spec-grid { grid-template-columns: repeat(2,1fr); } }
@media(max-width: 480px) { .spec-grid { grid-template-columns: 1fr; } }
</style>

<script>
import { AuthManager } from '../../utils/auth.js';

const ICONS = [
    'fa-code','fa-database','fa-mobile-screen','fa-cloud','fa-robot',
    'fa-chart-line','fa-shield-halved','fa-palette','fa-server','fa-microchip'
];

let specialties = [];

async function loadSpecialties() {
    try {
        const res = await fetch('http://localhost:8000/api/v1/specialties/');
        specialties = await res.json();
        renderGrid(specialties);
    } catch(e) {
        document.getElementById('specGrid').innerHTML = '<div class="empty">Error al cargar categorías.</div>';
    }
}

function renderGrid(list) {
    const grid = document.getElementById('specGrid');
    if (!list.length) {
        grid.innerHTML = '<div class="empty">No hay categorías. ¡Crea la primera!</div>';
        return;
    }
    grid.innerHTML = list.map((s, i) => `
    <div class="spec-card">
        <div class="spec-icon"><i class="fa-solid ${ICONS[i % ICONS.length]}"></i></div>
        <div class="spec-info">
            <h4>${s.name}</h4>
            <p>Categoría de curso</p>
        </div>
    </div>`).join('');
}

// Show/hide form
document.getElementById('btnShowForm').addEventListener('click', () => {
    const form = document.getElementById('addForm');
    form.style.display = form.style.display === 'none' ? 'block' : 'none';
    if (form.style.display === 'block') {
        document.getElementById('fName').focus();
    }
});

document.getElementById('btnCancel').addEventListener('click', () => {
    document.getElementById('addForm').style.display = 'none';
    document.getElementById('specialtyForm').reset();
    hideMsg();
});

function showMsg(text, type) {
    const el = document.getElementById('formMsg');
    el.textContent = text;
    el.className = type;
    el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 3000);
}
function hideMsg() { document.getElementById('formMsg').style.display = 'none'; }

document.getElementById('specialtyForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn  = document.getElementById('btnSave');
    const name = document.getElementById('fName').value.trim();
    if (!name) return;
    btn.disabled = true;

    try {
        const res = await AuthManager.fetch('/specialties/', {
            method: 'POST',
            body: JSON.stringify({ name }),
        });
        if (res) {
            specialties.push(res);
            renderGrid(specialties);
            document.getElementById('specialtyForm').reset();
            document.getElementById('addForm').style.display = 'none';
            showMsg('✓ Categoría creada correctamente', 'success');
        }
    } catch(e) {
        showMsg('Error: ' + e.message, 'error');
    } finally {
        btn.disabled = false;
    }
});

loadSpecialties();
</script>
