---
import LeaderLayout from '../../layouts/LeaderLayout.astro';
---

<LeaderLayout title="Mentores" subtitle="Gestión de mentores de tu comunidad">
<div class="page-wrap">

    <div class="page-header">
        <div>
            <h1 class="page-title"><i class="fa-solid fa-user-graduate"></i> Mentores</h1>
            <p class="page-sub">Mentores activos de tu comunidad</p>
        </div>
        <div class="stat-pill" id="mentorCount"><span id="mentorCountNum">0</span> mentores</div>
    </div>

    <!-- Search -->
    <div class="search-bar">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="mentorSearch" placeholder="Buscar por nombre o email..." />
    </div>

    <!-- Table -->
    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>MENTOR</th>
                    <th class="tc">ESPECIALIDAD</th>
                    <th class="tc">CURSOS</th>
                    <th class="tc">REGISTRO</th>
                    <th class="tc">ACCIONES</th>
                </tr>
            </thead>
            <tbody id="mentorsBody">
                <tr><td colspan="5" class="loading-cell">
                    <div class="spinner"></div> Cargando mentores...
                </td></tr>
            </tbody>
        </table>
    </div>
</div>
</LeaderLayout>

<style>
.page-wrap { max-width: 1100px; display: flex; flex-direction: column; gap: 20px; }

.page-header { display: flex; justify-content: space-between; align-items: flex-start; }
.page-title { font-size: 1.5rem; font-weight: 800; color: #0f172a; margin: 0; display: flex; align-items: center; gap: 10px; }
.page-title i { color: #3b82f6; }
.page-sub { font-size: .85rem; color: #64748b; margin: 4px 0 0 0; }
.stat-pill {
    background: #eff6ff; color: #3b82f6; border-radius: 20px;
    padding: 6px 16px; font-size: .85rem; font-weight: 700;
}

.search-bar {
    position: relative; max-width: 420px;
}
.search-bar i {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; font-size: .9rem;
}
.search-bar input {
    width: 100%; box-sizing: border-box;
    padding: 10px 14px 10px 40px;
    border: 1.5px solid #e2e8f0; border-radius: 50px;
    font-size: .88rem; outline: none; background: #fff;
    transition: border-color .2s;
}
.search-bar input:focus { border-color: #3b82f6; }

.table-card {
    background: #fff; border-radius: 16px; border: 1px solid #e2e8f0;
    overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.03);
}
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead { background: #f8fafc; }
.data-table th {
    padding: 14px 20px; font-size: .75rem; font-weight: 700;
    color: #475569; text-transform: uppercase; letter-spacing: .03em;
    border-bottom: 1px solid #e2e8f0; text-align: left;
}
.tc { text-align: center !important; }
.data-table td {
    padding: 16px 20px; border-bottom: 1px solid #f8fafc;
    font-size: .88rem; color: #1e293b;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover { background: #fafbfc; }

.loading-cell { text-align: center; padding: 3rem !important; color: #94a3b8; }
.spinner {
    display: inline-block; width: 20px; height: 20px;
    border: 3px solid #f1f5f9; border-top-color: #3b82f6;
    border-radius: 50%; animation: spin 1s linear infinite; margin-right: 8px;
    vertical-align: middle;
}
@keyframes spin { to { transform: rotate(360deg); } }

.user-cell { display: flex; align-items: center; gap: 12px; }
.avatar {
    width: 38px; height: 38px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: .82rem; flex-shrink: 0;
}
.user-name  { font-weight: 600; color: #0f172a; font-size: .9rem; }
.user-email { font-size: .78rem; color: #64748b; }

.badge-specialty {
    background: #f0f7ff; color: #0073ff; border-radius: 20px;
    padding: 3px 10px; font-size: .75rem; font-weight: 600;
}
.course-count {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: .82rem; font-weight: 600; color: #475569;
}
.date-cell { font-size: .82rem; color: #64748b; }

.btn-demote {
    background: #fff7ed; border: 1px solid #fed7aa; color: #c2410c;
    padding: 6px 14px; border-radius: 20px; font-size: .78rem; font-weight: 700;
    cursor: pointer; transition: all .2s; display: inline-flex; align-items: center; gap: 5px;
}
.btn-demote:hover { background: #ffedd5; border-color: #c2410c; }
</style>

<script>
import { AuthManager, authManager } from '../../utils/auth.js';

let mentors   = [];
let courses   = [];
let communityId = null;

const AVATAR_COLORS = ['#3b82f6','#8b5cf6','#10b981','#f59e0b','#ef4444','#06b6d4'];

async function init() {
    const user = authManager.getUser();
    if (!user?.community_id) { setTimeout(init, 400); return; }
    communityId = user.community_id;

    const [members, coursesData] = await Promise.all([
        AuthManager.fetch(`/users/community/${communityId}`),
        AuthManager.fetch('/courses/pending'),
    ]);

    mentors = (Array.isArray(members) ? members : []).filter(m => m.rol_id === 2);
    courses = Array.isArray(coursesData) ? coursesData : [];

    document.getElementById('mentorCountNum').textContent = mentors.length;
    render(mentors);
}

function courseCountFor(mentorId) {
    return courses.filter(c => c.mentor_id === mentorId).length;
}

function render(list) {
    const tbody = document.getElementById('mentorsBody');
    if (!list.length) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:2.5rem;color:#94a3b8;">No hay mentores en tu comunidad.</td></tr>';
        return;
    }
    tbody.innerHTML = list.map(m => {
        const initials = (m.name_user || '?').substring(0, 2).toUpperCase();
        const color    = AVATAR_COLORS[m.id % AVATAR_COLORS.length];
        const regDate  = m.created_at ? new Date(m.created_at).toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' }) : '—';
        const count    = courseCountFor(m.id);
        const spec     = m.specialty_name || m.specialty || '—';
        return `
        <tr>
            <td>
                <div class="user-cell">
                    <div class="avatar" style="background:${color}">${initials}</div>
                    <div>
                        <div class="user-name">${m.name_user}</div>
                        <div class="user-email">${m.email}</div>
                    </div>
                </div>
            </td>
            <td class="tc"><span class="badge-specialty">${spec}</span></td>
            <td class="tc">
                <span class="course-count">
                    <i class="fa-solid fa-book" style="color:#3b82f6;font-size:.75rem"></i> ${count}
                </span>
            </td>
            <td class="tc"><span class="date-cell">${regDate}</span></td>
            <td class="tc">
                <button class="btn-demote" data-id="${m.id}" data-name="${m.name_user}">
                    <i class="fa-solid fa-user-minus"></i> Designar a usuario
                </button>
            </td>
        </tr>`;
    }).join('');

    // Demote buttons
    tbody.querySelectorAll('.btn-demote').forEach(btn => {
        btn.addEventListener('click', async () => {
            if (!confirm(`¿Designar a ${btn.dataset.name} como usuario estándar?`)) return;
            try {
                const res = await AuthManager.fetch(`/users/${btn.dataset.id}/demote`, { method: 'PATCH' });
                if (res) { await init(); }
            } catch(e) { alert('Error: ' + e.message); }
        });
    });
}

// Search
document.getElementById('mentorSearch').addEventListener('input', function() {
    const term = this.value.toLowerCase();
    const filtered = mentors.filter(m =>
        m.name_user.toLowerCase().includes(term) || m.email.toLowerCase().includes(term)
    );
    render(filtered);
});

init();
</script>
