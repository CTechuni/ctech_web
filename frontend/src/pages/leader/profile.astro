---
import LeaderLayout from '../../layouts/LeaderLayout.astro';
---

<LeaderLayout title="Mi Perfil" subtitle="Información personal y de comunidad">
<div class="profile-wrap">

    <div class="profile-card">
        <!-- Avatar + name -->
        <div class="profile-top">
            <div class="avatar-circle" id="profileAvatar">--</div>
            <div>
                <h2 id="profileName">Cargando...</h2>
                <span class="role-badge">Líder de Comunidad</span>
            </div>
        </div>

        <!-- Info -->
        <div class="info-grid">
            <div class="info-item">
                <label><i class="fa-solid fa-envelope"></i> Email</label>
                <span id="profileEmail">—</span>
            </div>
            <div class="info-item">
                <label><i class="fa-solid fa-users"></i> Comunidad</label>
                <span id="profileCommunity">—</span>
            </div>
            <div class="info-item">
                <label><i class="fa-solid fa-shield-halved"></i> Rol</label>
                <span>Líder</span>
            </div>
            <div class="info-item">
                <label><i class="fa-solid fa-calendar-check"></i> Miembro desde</label>
                <span id="profileDate">—</span>
            </div>
        </div>

        <div class="profile-actions">
            <a href="/leader/settings" class="btn-settings">
                <i class="fa-solid fa-gear"></i> Ajustes de cuenta
            </a>
        </div>
    </div>

    <!-- Community summary -->
    <div class="community-card" id="communityCard">
        <h3><i class="fa-solid fa-building-columns"></i> Tu comunidad</h3>
        <div class="comm-stats">
            <div class="cs-item">
                <span class="cs-num" id="csMentors">—</span>
                <span class="cs-lbl">Mentores</span>
            </div>
            <div class="cs-item">
                <span class="cs-num" id="csUsers">—</span>
                <span class="cs-lbl">Usuarios</span>
            </div>
            <div class="cs-item">
                <span class="cs-num" id="csCourses">—</span>
                <span class="cs-lbl">Cursos</span>
            </div>
            <div class="cs-item">
                <span class="cs-num" id="csEvents">—</span>
                <span class="cs-lbl">Eventos</span>
            </div>
        </div>
    </div>
</div>
</LeaderLayout>

<style>
.profile-wrap { max-width: 860px; display: flex; flex-direction: column; gap: 24px; }

.profile-card {
    background: #fff; border-radius: 20px; border: 1px solid #e2e8f0;
    padding: 32px; box-shadow: 0 4px 16px rgba(0,0,0,.04);
}
.profile-top {
    display: flex; align-items: center; gap: 20px; margin-bottom: 28px;
    padding-bottom: 24px; border-bottom: 1px solid #f1f5f9;
}
.avatar-circle {
    width: 72px; height: 72px; border-radius: 50%;
    background: #3b82f6; color: #fff; font-size: 1.5rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.profile-top h2 { margin: 0 0 6px; font-size: 1.4rem; font-weight: 800; color: #0f172a; }
.role-badge { background: #eff6ff; color: #3b82f6; border-radius: 20px; padding: 4px 12px; font-size: .78rem; font-weight: 700; }

.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 28px; }
.info-item { display: flex; flex-direction: column; gap: 4px; }
.info-item label { font-size: .75rem; font-weight: 700; color: #94a3b8; display: flex; align-items: center; gap: 5px; }
.info-item span  { font-size: .92rem; font-weight: 600; color: #1e293b; }

.profile-actions { display: flex; gap: 10px; }
.btn-settings {
    background: #f1f5f9; color: #475569; border-radius: 10px;
    padding: 10px 18px; font-weight: 700; font-size: .88rem;
    text-decoration: none; display: flex; align-items: center; gap: 7px;
    transition: all .2s;
}
.btn-settings:hover { background: #e2e8f0; color: #1e293b; }

.community-card {
    background: #fff; border-radius: 20px; border: 1px solid #e2e8f0;
    padding: 28px; box-shadow: 0 4px 16px rgba(0,0,0,.04);
}
.community-card h3 { margin: 0 0 20px; font-size: 1rem; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px; }
.community-card h3 i { color: #3b82f6; }
.comm-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
.cs-item { text-align: center; background: #f8fafc; border-radius: 12px; padding: 16px 10px; }
.cs-num { display: block; font-size: 1.6rem; font-weight: 800; color: #0073ff; }
.cs-lbl { display: block; font-size: .78rem; font-weight: 600; color: #64748b; margin-top: 2px; }

@media(max-width:640px) {
    .info-grid { grid-template-columns: 1fr; }
    .comm-stats { grid-template-columns: repeat(2,1fr); }
}
</style>

<script>
import { authManager, AuthManager } from '../../utils/auth.js';

async function init() {
    const user = authManager.getUser();
    if (!user) return;

    // Avatar
    const initials = (user.name_user || '?').substring(0, 2).toUpperCase();
    document.getElementById('profileAvatar').textContent = initials;
    document.getElementById('profileName').textContent   = user.name_user || '—';
    document.getElementById('profileEmail').textContent  = user.email || '—';

    // Comunidad
    const me = await AuthManager.fetch('/users/me').catch(() => null);
    if (me?.created_at) {
        const d = new Date(me.created_at).toLocaleDateString('es-ES', { day:'numeric', month:'long', year:'numeric' });
        document.getElementById('profileDate').textContent = d;
    }

    // Cargar métricas de comunidad
    if (user.community_id) {
        try {
            const metrics = await AuthManager.fetch(`/metrics/community/${user.community_id}`);
            if (metrics) {
                document.getElementById('csMentors').textContent = metrics.total_mentors ?? '—';
                document.getElementById('csUsers').textContent   = metrics.total_users ?? '—';
                document.getElementById('csCourses').textContent = metrics.total_courses ?? '—';
                document.getElementById('csEvents').textContent  = metrics.active_events ?? '—';
            }
        } catch(e) { console.warn('Error cargando métricas:', e); }

        // Nombre de comunidad
        try {
            const communities = await fetch('http://localhost:8000/api/v1/communities/').then(r => r.json());
            const comm = Array.isArray(communities)
                ? communities.find(c => c.id_community === user.community_id)
                : null;
            if (comm) document.getElementById('profileCommunity').textContent = comm.name_community;
        } catch(e) {}
    }
}

init();
</script>
