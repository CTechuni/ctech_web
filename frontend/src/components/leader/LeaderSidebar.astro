---

<aside class="leader-sidebar">
    <!-- Logo -->
    <div class="sidebar-brand">
        <div class="brand-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="20" height="20">
                <path fill-rule="evenodd" d="M9.315 7.584C12.195 3.883 16.695 1.5 21.75 1.5a.75.75 0 01.75.75c0 5.056-2.383 9.555-6.084 12.436A6.75 6.75 0 019.75 22.5a.75.75 0 01-.75-.75v-4.131A15.838 15.838 0 016.382 15H2.25a.75.75 0 01-.75-.75 6.75 6.75 0 017.815-6.666zM15 6.75a2.25 2.25 0 100 4.5 2.25 2.25 0 000-4.5z" clip-rule="evenodd"/>
                <path d="M5.26 17.242a.75.75 0 10-.897-1.203 5.243 5.243 0 00-2.05 5.022.75.75 0 00.625.627 5.243 5.243 0 005.022-2.051.75.75 0 10-1.202-.897 3.744 3.744 0 01-3.008 1.51c0-1.23.592-2.323 1.51-3.008z"/>
            </svg>
        </div>
        <span class="brand-name">CTech</span>
        <button class="collapse-btn" id="collapseBtn" title="Colapsar sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                <path fill-rule="evenodd" d="M7.72 12.53a.75.75 0 010-1.06l7.5-7.5a.75.75 0 111.06 1.06L9.31 12l6.97 6.97a.75.75 0 11-1.06 1.06l-7.5-7.5z" clip-rule="evenodd"/>
            </svg>
        </button>
    </div>

    <!-- Profile Card -->
    <div class="profile-card">
        <div class="profile-avatar" id="sidebarAvatar">--</div>
        <div class="profile-info">
            <span class="profile-name" id="sidebarName">Cargando...</span>
            <span class="profile-community" id="sidebarCommunity">--</span>
        </div>
        <div class="profile-badge">Líder</div>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav">
        {menuItems.map(item => (
            <a href={item.path} class="nav-item" data-path={item.path}>
                <span class="nav-icon"><Fragment set:html={item.icon} /></span>
                <span class="nav-label">{item.label}</span>
            </a>
        ))}
    </nav>

    <!-- Footer -->
    <div class="sidebar-footer">
        <button id="logoutBtn" class="logout-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path fill-rule="evenodd" d="M7.5 3.75A1.5 1.5 0 006 5.25v13.5a1.5 1.5 0 001.5 1.5h6a1.5 1.5 0 001.5-1.5V15a.75.75 0 011.5 0v3.75a3 3 0 01-3 3h-6a3 3 0 01-3-3V5.25a3 3 0 013-3h6a3 3 0 013 3V9A.75.75 0 0115 9V5.25a1.5 1.5 0 00-1.5-1.5h-6zm10.72 4.72a.75.75 0 011.06 0l3 3a.75.75 0 010 1.06l-3 3a.75.75 0 11-1.06-1.06l1.72-1.72H9a.75.75 0 010-1.5h10.94l-1.72-1.72a.75.75 0 010-1.06z" clip-rule="evenodd"/>
            </svg>
            <span>Salir</span>
        </button>
    </div>
</aside>

<style>
    .leader-sidebar {
        width: 260px;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        background: #0d1117;
        display: flex;
        flex-direction: column;
        z-index: 1000;
        overflow: hidden;
        transition: width 0.3s ease, transform 0.3s ease;
    }

    /* ── Collapsed State ───────────────────────── */
    :global(.sidebar-collapsed) .leader-sidebar {
        width: 70px;
    }

    :global(.sidebar-collapsed) .brand-name,
    :global(.sidebar-collapsed) .profile-info,
    :global(.sidebar-collapsed) .profile-badge,
    :global(.sidebar-collapsed) .nav-label,
    :global(.sidebar-collapsed) .logout-btn span {
        display: none;
    }

    :global(.sidebar-collapsed) .sidebar-brand { justify-content: center; padding: 20px 0; }
    :global(.sidebar-collapsed) .collapse-btn { position: absolute; right: -10px; top: 25px; transform: rotate(180deg); background: #007bff; color: white; border: 2px solid #0d1117; }
    :global(.sidebar-collapsed) .profile-card { grid-template-columns: 1fr; justify-items: center; padding: 10px 0; }
    :global(.sidebar-collapsed) .nav-item { justify-content: center; padding: 12px 0; }

    /* ── Mobile State ─────────────────────────── */
    @media (max-width: 1024px) {
        .leader-sidebar {
            transform: translateX(-100%);
        }
        :global(.sidebar-open) .leader-sidebar {
            transform: translateX(0);
        }
        .collapse-btn { display: none; }
    }

    /* ── Brand ─────────────────────────────────── */
    .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 20px 16px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        position: relative;
    }

    .brand-icon {
        width: 34px;
        height: 34px;
        background: #007bff;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .brand-name {
        font-size: 1.1rem;
        font-weight: 800;
        color: white;
        letter-spacing: -0.02em;
        flex: 1;
    }

    .collapse-btn {
        width: 22px;
        height: 22px;
        background: rgba(255,255,255,0.08);
        border: none;
        border-radius: 50%;
        color: rgba(255,255,255,0.5);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-shrink: 0;
    }
    .collapse-btn:hover { background: rgba(255,255,255,0.15); color: white; }

    /* ── Profile Card ──────────────────────────── */
    .profile-card {
        margin: 14px 12px;
        background: #007bff;
        border-radius: 12px;
        padding: 12px 14px;
        display: grid;
        grid-template-columns: 40px 1fr;
        grid-template-rows: auto auto;
        column-gap: 10px;
        align-items: center;
    }

    .profile-avatar {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.25);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        color: white;
        grid-row: 1 / 3;
        letter-spacing: 0.5px;
    }

    .profile-info {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .profile-name {
        font-size: 0.88rem;
        font-weight: 700;
        color: white;
        line-height: 1.2;
    }

    .profile-community {
        font-size: 0.72rem;
        color: rgba(255,255,255,0.75);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .profile-badge {
        grid-column: 2;
        background: rgba(255,255,255,0.2);
        color: white;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        width: fit-content;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        margin-top: 4px;
    }

    /* ── Navigation ────────────────────────────── */
    .sidebar-nav {
        flex: 1;
        padding: 6px 10px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow-y: auto;
        scrollbar-width: none;
    }
    .sidebar-nav::-webkit-scrollbar { display: none; }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        color: #8b9ab4;
        text-decoration: none;
        border-radius: 8px;
        font-size: 0.855rem;
        font-weight: 500;
        transition: all 0.18s ease;
        cursor: pointer;
    }

    .nav-icon {
        width: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .nav-icon :global(svg) {
        width: 17px;
        height: 17px;
    }

    .nav-item:hover {
        color: #e2e8f0;
        background: rgba(255,255,255,0.06);
    }

    .nav-item.active {
        background: var(--color-azure-radiant);
        color: white;
        font-weight: 600;
    }

    .nav-item.active .nav-icon :global(svg) {
        color: white;
    }

    /* ── Footer / Logout ───────────────────────── */
    .sidebar-footer {
        padding: 12px 10px 20px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .logout-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 9px 12px;
        background: transparent;
        border: none;
        color: #8b9ab4;
        cursor: pointer;
        border-radius: 8px;
        font-size: 0.855rem;
        font-weight: 500;
        transition: all 0.18s;
        font-family: inherit;
    }

    .logout-btn:hover {
        background: rgba(255,255,255,0.06);
        color: #f87171;
    }
</style>

<script>
    import { authManager } from "../../utils/auth.js";

    // 1. Cargar datos del perfil
    function loadSidebarProfile() {
        const user = authManager.getUser();
        if (user) {
            const avatar = document.getElementById('sidebarAvatar');
            const name = document.getElementById('sidebarName');
            const community = document.getElementById('sidebarCommunity');

            if (avatar) avatar.textContent = user.name_user ? user.name_user.substring(0, 2).toUpperCase() : '--';
            if (name) name.textContent = user.name_user || 'Usuario';
            if (community) community.textContent = user.community_name || 'Sin Comunidad';
        }
    }

    // 2. Logout Real
    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        authManager.logout();
        window.location.href = '/';
    });

    // 3. Marcar link activo
    const currentPath = window.location.pathname;
    document.querySelectorAll('.nav-item').forEach(link => {
        const href = link.getAttribute('href')?.split('?')[0];
        const isActive = href === currentPath || (href !== '/leader' && currentPath.startsWith(href));
        if (isActive) link.classList.add('active');
    });

    // 4. Toggle Sidebar Event
    document.getElementById('collapseBtn')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('toggleSidebar'));
    });

    // Inicializar
    loadSidebarProfile();
</script>
