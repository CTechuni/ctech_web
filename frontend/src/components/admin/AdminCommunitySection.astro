    // ═══════════ MODAL OPEN/CLOSE ═══════════
    function openModal(mode: 'create' | 'edit' = 'create', data: any = null) {
        editingId = mode === 'edit' ? data.id_community : null;
        originalData = mode === 'edit' ? { ...data } : null;
        modalTitle.textContent = mode === 'edit' ? 'Editar Comunidad' : 'Nueva Comunidad';
        modalSubmitBtn.textContent = mode === 'edit' ? 'Guardar Cambios' : 'Crear Comunidad';
        
        // Hide leader selection in edit mode if already assigned (simplified for now, following request)
        // Actually request says "precargado", so we show it.
        
        statusGroup.style.display = mode === 'edit' ? '' : 'none';
        
        // Toggle mandatory indicators (*) based on mode
        const requiredIndicators = modal.querySelectorAll<HTMLElement>('.comm-required');
        requiredIndicators.forEach(span => {
            span.style.display = mode === 'edit' ? 'none' : '';
        });

        logoCleared = false;
        if (mode === 'edit') {
            nameInput.value = data.name_community;
            codeInput.value = data.code;
            if (data.logo_url) {
                previewImg.style.display = 'block';
                previewImg.src = data.logo_url;
                previewInitials.style.display = 'none';
                uploadPlaceholder.style.display = 'none';
                uploadPreview.style.display = '';
            } else {
                previewImg.style.display = 'none';
                updateInitialsPreview();
                previewInitials.style.display = 'flex';
                uploadPlaceholder.style.display = 'none';
                uploadPreview.style.display = '';
            }
            // Temporarily set leader option so it's visible while loading list
            leaderSelect.innerHTML = `<option value="${data.leader_id || ''}" selected>${data.leader_name || 'Sin líder'}</option>`;
            // Normalize status to 'Activo'/'Inactivo' for pre-loading
            let currentStatus = data.status_community || 'Activo';
            if (currentStatus.toLowerCase() === 'active') currentStatus = 'Activo';
            if (currentStatus.toLowerCase() === 'inactive') currentStatus = 'Inactivo';
            statusSelect.value = currentStatus;
        } else {
            resetForm();
        }

        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        // Robustness: ensure fields are enabled
        modalSubmitBtn.disabled = false;
        nameInput.disabled = false;
        codeInput.disabled = false;
        statusSelect.disabled = false;
        
        loadLeaders(editingId !== null);
        
        // Auto-focus the name field
        setTimeout(() => nameInput.focus(), 100);
    }

    // ═══════════ DETAIL MODAL LOGIC ═══════════
    const detailModal = document.getElementById('communityDetailModal')!;
    const detailAvatar = document.getElementById('detailAvatarContainer')!;
    const detailName = document.getElementById('detailName')!;
    const detailStatusBadge = document.getElementById('detailStatusBadge')!;
    const detailStatusDot = document.getElementById('detailStatusDot')!;
    const detailStatusText = document.getElementById('detailStatusText')!;
    const detailCode = document.getElementById('detailCode')!;
    const detailLeader = document.getElementById('detailLeader')!;
    const detailCreatedAt = document.getElementById('detailCreatedAt')!;

    function formatDate(dateStr: string) {
        if (!dateStr) return 'No disponible';
        try {
            const date = new Date(dateStr);
            return new Intl.DateTimeFormat('es-ES', {
                day: '2-digit',
                month: 'long',
                year: 'numeric'
            }).format(date);
        } catch {
            return dateStr;
        }
    }

    function openDetailModal(data: any) {
        detailName.textContent = data.name_community;
        detailCode.textContent = data.code;
        detailLeader.textContent = data.leader_name || 'Sin asignar';
        detailCreatedAt.textContent = formatDate(data.created_at);

        // Status
        const isActive = data.status_community !== 'Inactivo';
        detailStatusText.textContent = isActive ? 'Activo' : 'Inactivo';
        detailStatusBadge.className = `d-inline-flex align-items-center gap-2 px-2 py-1 rounded-pill ${isActive ? 'bg-success-subtle' : 'bg-danger-subtle'}`;
        detailStatusDot.className = `comm-status-dot ${isActive ? 'bg-success' : 'bg-danger'}`;

        // Avatar
        const config = visualConfig[listStore.indexOf(data) % visualConfig.length] || visualConfig[0];
        if (data.logo_url) {
            detailAvatar.innerHTML = `<img src="${data.logo_url}" alt="${data.name_community}">`;
            detailAvatar.className = 'comm-detail-avatar-container mx-auto bg-white';
        } else {
            const initials = data.name_community ? data.name_community.substring(0, 2).toUpperCase() : 'CT';
            detailAvatar.innerHTML = initials;
            detailAvatar.className = `comm-detail-avatar-container mx-auto ${config.theme}`;
        }

        detailModal.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeDetailModal() {
        detailModal.classList.remove('active');
        document.body.style.overflow = '';
    }

    document.getElementById('detailModalCloseX')?.addEventListener('click', closeDetailModal);
    document.getElementById('detailModalCloseBtn')?.addEventListener('click', closeDetailModal);
    detailModal.addEventListener('click', (e) => {
        if (e.target === detailModal) closeDetailModal();
    });

    function closeModal() {
        modal.classList.remove('active');
        document.body.style.overflow = '';
        resetForm();
    }

    function resetForm() {
        form.reset();
        selectedFile = null;
        logoCleared = false;
        logoInput.value = '';
        uploadPlaceholder.style.display = '';
        uploadPreview.style.display = 'none';
        previewImg.src = '';
        previewInitials.textContent = '';
        editingId = null;
        statusSelect.value = 'Activo';
        clearErrors();
    }

    function updateInitialsPreview() {
        const name = nameInput.value.trim();
        const initials = name ? name.substring(0, 2).toUpperCase() : 'CT';
        previewInitials.textContent = initials;
    }

    nameInput.addEventListener('input', () => {
        if (!selectedFile && (previewInitials.style.display !== 'none' || uploadPlaceholder.style.display !== 'none')) {
            updateInitialsPreview();
            if (nameInput.value.trim()) {
                uploadPlaceholder.style.display = 'none';
                uploadPreview.style.display = '';
                previewInitials.style.display = 'flex';
                previewImg.style.display = 'none';
            }
        }
    });

    document.getElementById('addCommunityBtn')?.addEventListener('click', () => openModal('create'));
    document.getElementById('modalCloseX')?.addEventListener('click', closeModal);
    document.getElementById('modalCancelBtn')?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });

    // ═══════════ IMAGE UPLOAD ═══════════
    uploadArea.addEventListener('click', () => logoInput.click());

    document.getElementById('removePreview')?.addEventListener('click', (e) => {
        e.stopPropagation();
        selectedFile = null;
        logoCleared = true; // El usuario quiere eliminar el logo en DB
        logoInput.value = '';
        previewImg.src = '';
        previewImg.style.display = 'none';
        
        const name = nameInput.value.trim();
        if (name) {
            updateInitialsPreview();
            previewInitials.style.display = 'flex';
        } else {
            uploadPreview.style.display = 'none';
            uploadPlaceholder.style.display = 'flex';
        }
    });

    logoInput.addEventListener('change', () => {
        const file = logoInput.files?.[0];
        if (!file) return;

        const validTypes = ['image/svg+xml', 'image/jpeg', 'image/jpg'];
        const isValidExt = /\.(svg|jpg|jpeg)$/i.test(file.name);

        if (!validTypes.includes(file.type) && !isValidExt) {
            alert('Formato no válido. Solo se permiten archivos .svg o .jpg');
            logoInput.value = '';
            return;
        }

        selectedFile = file;
        logoCleared = false; // Al elegir archivo nuevo, ya no estamos "clearing"
        const reader = new FileReader();
        reader.onload = (ev) => {
            previewImg.src = ev.target?.result as string;
            previewImg.style.display = 'block';
            previewInitials.style.display = 'none';
            uploadPlaceholder.style.display = 'none';
            uploadPreview.style.display = '';
        };
        reader.readAsDataURL(file);
    });

    // ═══════════ LOAD LEADERS ═══════════
    async function loadLeaders(isEdit = false) {
        try {
            console.debug('Loading leaders (Auth Bypassed)...');
            const leaders = await AuthManager.fetch('/users/leaders?available=true');
            
            if (leaders === null) {
                console.warn('Network error or endpoint unreachable');
                leaderSelect.innerHTML = '<option value="">Error al cargar líderes</option>';
                return;
            }

            const currentVal = leaderSelect.value;
            const currentText = leaderSelect.options[0]?.textContent;

            leaderSelect.innerHTML = '<option value="">Seleccionar líder...</option>';
            
            if (isEdit && currentVal) {
                const opt = document.createElement('option');
                opt.value = currentVal;
                opt.textContent = currentText || 'Líder actual';
                opt.selected = true;
                leaderSelect.appendChild(opt);
            }

            if (Array.isArray(leaders)) {
                leaders.forEach((l: any) => {
                    if (String(l.id) !== currentVal) {
                        const opt = document.createElement('option');
                        opt.value = l.id;
                        opt.textContent = `${l.name_user || l.email}`;
                        leaderSelect.appendChild(opt);
                    }
                });
            } else {
                 console.warn('Leaders API returned non-array or unauthorized:', leaders);
                 if (!isEdit) {
                    leaderSelect.innerHTML = '<option value="">Sin acceso a líderes</option>';
                 }
            }
        } catch (err: any) {
            console.error('Error loading leaders:', err);
            if (!isEdit) {
                leaderSelect.innerHTML = `<option value="">${err.message.includes('401') ? 'No autorizado (Login expirado)' : 'Error al cargar'}</option>`;
            }
        }
    }

    // ═══════════ VALIDATION ═══════════
    const CODE_REGEX = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z0-9]).{7,15}$/;

    function clearErrors() {
        nameError.textContent = '';
        codeError.textContent = '';
        leaderError.textContent = '';
        nameInput.classList.remove('is-invalid');
        codeInput.classList.remove('is-invalid');
        leaderSelect.classList.remove('is-invalid');
    }

    function validateForm(): boolean {
        clearErrors();
        let valid = true;
        const isEdit = editingId !== null;

        const name = nameInput.value.trim();
        // Required only in create mode. 
        if (!isEdit && !name) {
            nameError.textContent = 'El nombre es obligatorio';
            nameInput.classList.add('is-invalid');
            valid = false;
        } else if (name !== "") {
            if (name.length < 4 || name.length > 25) {
                nameError.textContent = 'Entre 4 y 25 caracteres';
                nameInput.classList.add('is-invalid');
                valid = false;
            }
        }

        const code = codeInput.value.trim();
        if (!isEdit && !code) {
            codeError.textContent = 'El código es obligatorio';
            codeInput.classList.add('is-invalid');
            valid = false;
        } else if (code !== "") {
            const item = listStore.find(c => c.id_community === editingId);
            const isOriginal = isEdit && item && item.code === code;

            if (!isOriginal) {
                if (code.length < 7 || code.length > 15) {
                    codeError.textContent = 'Debe tener entre 7 y 15 caracteres';
                    valid = false;
                } else if (!/[A-Z]/.test(code)) {
                    codeError.textContent = 'Falta una letra mayúscula';
                    valid = false;
                } else if (!/[a-z]/.test(code)) {
                    codeError.textContent = 'Falta una letra minúscula';
                    valid = false;
                } else if (!/\d/.test(code)) {
                    codeError.textContent = 'Falta un número';
                    valid = false;
                } else if (!/[^a-zA-Z0-9]/.test(code)) {
                    codeError.textContent = 'Falta un signo especial (ej: #, $, !)';
                    valid = false;
                }
                
                if (!valid) codeInput.classList.add('is-invalid');
            }
        }

        // Leader optional

        if (!valid) {
            alert('Por favor, revisa los errores en el formulario antes de continuar.');
        }
        return valid;
    }

    // ═══════════ ACTIONS (DELETE/EDIT) ═══════════
    async function deleteCommunity(id: number, name: string) {
        console.debug('Attempting to delete community:', id, name);
        if (!confirm(`¿Está seguro de eliminar la comunidad "${name}"? Esta acción no se puede deshacer.`)) return;

        try {
            await AuthManager.fetch(`/communities/${id}`, { method: 'DELETE' });
            listStore = listStore.filter(c => c.id_community !== id);
            render();
            console.log('Community deleted successfully:', id);
        } catch (err: any) {
            console.error('Delete error:', err);
            alert('Error al eliminar: ' + err.message);
        }
    }

    // Event delegation for grid actions
    grid.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        
        // Action buttons
        const editBtn = target.closest('.comm-edit-btn');
        const deleteBtn = target.closest('.comm-delete-btn');

        if (editBtn) {
            e.stopPropagation();
            const idStr = editBtn.getAttribute('data-id');
            const id = idStr ? parseInt(idStr) : null;
            const item = listStore.find(c => c.id_community === id);
            if (item) openModal('edit', item);
            return;
        }

        if (deleteBtn) {
            e.stopPropagation();
            const idStr = deleteBtn.getAttribute('data-id');
            const id = idStr ? parseInt(idStr) : null;
            const item = listStore.find(c => c.id_community === id);
            if (item && id !== null) deleteCommunity(id, item.name_community);
            return;
        }

        // Card click (Detail view)
        const card = target.closest('.comm-card');
        if (card) {
            const idStr = card.getAttribute('data-id');
            const id = idStr ? parseInt(idStr) : null;
            const item = listStore.find(c => c.id_community === id);
            if (item) openDetailModal(item);
        }
    });

    // ═══════════ SUBMIT ═══════════
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!validateForm()) return;

        modalSubmitBtn.disabled = true;
        
        try {
            const currentName = nameInput.value.trim();
            const currentCode = codeInput.value.trim();
            const currentStatus = statusSelect.value;
            const leadVal = parseInt(leaderSelect.value);
            const currentLeaderId = isNaN(leadVal) ? null : leadVal;
            let logoUrl = editingId ? (originalData.logo_url || '') : '';

            // Si el usuario borró el logo en modo edición, forzar logoUrl vacío
            if (editingId && logoCleared) {
                logoUrl = '';
            }

            // Handle Cloudinary Upload if a new file is selected
            if (selectedFile) {
                const formData = new FormData();
                formData.append('file', selectedFile);
                
                const uploadData = await AuthManager.fetch('/communities/upload', {
                    method: 'POST',
                    body: formData
                });
                
                if (!uploadData || !uploadData.url) throw new Error('Fallo al subir la imagen a Cloudinary');
                logoUrl = uploadData.url;
            }

            // Define payload based on mode
            let payload: any = {};
            let hasChanges = false;

            if (editingId && originalData) {
                // DIRTY CHECKING (Edit Mode)
                if (currentName !== originalData.name_community) {
                    payload.name_community = currentName;
                    hasChanges = true;
                }
                if (currentCode !== originalData.code) {
                    payload.code = currentCode;
                    payload.access_code = currentCode; // Sincronizar siempre ambos campos
                    hasChanges = true;
                }
                
                let origStatus = originalData.status_community || 'Activo';
                if (origStatus.toLowerCase() === 'active') origStatus = 'Activo';
                if (origStatus.toLowerCase() === 'inactive') origStatus = 'Inactivo';
                
                if (currentStatus !== origStatus) {
                    payload.status_community = currentStatus;
                    hasChanges = true;
                }

                if (currentLeaderId !== originalData.leader_id) {
                    payload.leader_id = currentLeaderId;
                    hasChanges = true;
                }

                if (logoUrl !== originalData.logo_url) {
                    payload.logo_url = logoUrl;
                    hasChanges = true;
                }

                if (!hasChanges) {
                    console.log('No modifications detected. Closing modal.');
                    closeModal();
                    return;
                }
            } else {
                // Create Mode
                payload = {
                    name_community: currentName,
                    code: currentCode,
                    status_community: 'Activo',
                    access_code: currentCode,
                    description_community: '',
                    logo_url: logoUrl,
                    leader_id: currentLeaderId
                };
            }

            console.debug('Optimized payload:', payload);

            const url = editingId ? `/communities/${editingId}` : '/communities/';
            const method = editingId ? 'PATCH' : 'POST';

            const result = await AuthManager.fetch(url, {
                method,
                body: JSON.stringify(payload)
            });

            // SUCCESS FLOW: Sync with server and then close
            await setup(); 
            closeModal();
            alert('¡Cambios guardados con éxito!');
            
            // Helpful visual feedback could be added here if needed, but alert is what user asked for error.
            // For success, closing the modal is the standard indicator.
        } catch (err: any) {
            console.error('Submit execution failed:', err);
            alert('Error al guardar cambios: ' + (err.message || 'Error desconocido'));
        } finally {
            modalSubmitBtn.disabled = false;
        }
    });

    // ═══════════ SETUP & RENDER ═══════════
    async function setup() {
        try {
            // Add timestamp to avoid browser cache
            const data = await AuthManager.fetch(`/communities/?t=${Date.now()}`);
            if (Array.isArray(data)) {
                console.log('Setup: Refreshing listStore with', data.length, 'items');
                listStore = [...data];
                render();
            }
 else if (listStore.length === 0) {
                // Only use fallback if we have NO data at all
                listStore = [
                    { id_community: 1, name_community: 'DevFront Colombia', code: 'DFC#2024c', leader_name: 'Laura Méndez', member_count: 142, status_community: 'Activo' },
                    { id_community: 2, name_community: 'Backend Masters', code: 'BKM#2024m', leader_name: 'Pedro Salas', member_count: 98, status_community: 'Activo' },
                    { id_community: 3, name_community: 'DataScience Hub', code: 'DSH#2024h', leader_name: 'Sofía Castro', member_count: 75, status_community: 'Activo' }
                ];
                render();
            }
        } catch (err) {
            console.error('Setup error:', err);
            // If we already have data, don't overwrite with fallback on error
            if (listStore.length === 0) {
                listStore = [
                    { id_community: 1, name_community: 'DevFront Colombia', code: 'DFC#2024c', leader_name: 'Laura Méndez', member_count: 142, status_community: 'Activo' },
                    { id_community: 2, name_community: 'Backend Masters', code: 'BKM#2024m', leader_name: 'Pedro Salas', member_count: 98, status_community: 'Activo' },
                    { id_community: 3, name_community: 'DataScience Hub', code: 'DSH#2024h', leader_name: 'Sofía Castro', member_count: 75, status_community: 'Activo' }
                ];
                render();
            }
        }
    }

    function render(data = listStore) {
        if (!grid) return;
        if (data.length === 0) {
            grid.innerHTML = `<div class="col-12 text-center py-5"><p class="text-muted">No hay comunidades registradas.</p></div>`;
            return;
        }

        grid.innerHTML = data.map((item, idx) => {
            const config = visualConfig[idx % visualConfig.length];
            const initials = item.name_community ? item.name_community.substring(0, 2).toUpperCase() : 'CT';
            const avatarHtml = item.logo_url 
                ? `<img src="${item.logo_url}" alt="${item.name_community}">`
                : `<span class="comm-initials">${initials}</span>`;

            return `
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="comm-card" data-id="${item.id_community}">
                        <div class="comm-card-header">
                            <div class="comm-card-identity">
                                <div class="comm-icon-box ${item.logo_url ? 'bg-white' : config.theme}">
                                    ${avatarHtml}
                                </div>
                                <div>
                                    <div class="comm-name">
                                        ${item.name_community}
                                        <span class="comm-status-dot ${item.status_community === 'Inactivo' ? 'bg-danger' : 'bg-success'}"></span>
                                    </div>
                                    <span class="comm-code">${item.code}</span>
                                </div>
                            </div>
                            <div class="comm-actions">
                                <button class="comm-action-btn comm-edit-btn" data-id="${item.id_community}" title="Editar">${editIcon}</button>
                                <button class="comm-action-btn comm-delete-btn" data-id="${item.id_community}" title="Eliminar">${deleteIcon}</button>
                            </div>
                        </div>
                        <div class="comm-card-footer">
                            <div class="comm-leader">
                                ${item.leader_name || 'Sin asignar'} <span class="comm-leader-label">· Líder</span>
                            </div>
                            <span class="comm-members">${item.member_count || 0} miembros</span>
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    }

    document.getElementById('communitySearch')?.addEventListener('input', (e) => {
        const q = (e.target as HTMLInputElement).value.toLowerCase();
        render(listStore.filter(c => c.name_community.toLowerCase().includes(q) || c.code.toLowerCase().includes(q)));
    });

    setup();
</script>
