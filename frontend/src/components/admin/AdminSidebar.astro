---

<aside class="admin-sidebar">
    <!-- Logo -->
    <div class="sidebar-brand">
        <div class="brand-icon">
            <img src="/LogoCTech.svg" alt="CTech Logo" class="logo-white" />
        </div>
        <span class="brand-name">CTech</span>
        <button class="collapse-btn" id="collapseBtn" title="Colapsar sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                <path fill-rule="evenodd" d="M7.72 12.53a.75.75 0 010-1.06l7.5-7.5a.75.75 0 111.06 1.06L9.31 12l6.97 6.97a.75.75 0 11-1.06 1.06l-7.5-7.5z" clip-rule="evenodd"/>
            </svg>
        </button>
    </div>

    <!-- Profile Card -->
    <div class="profile-card">
        <div class="profile-info">
            <span class="profile-name" id="userNameSide">Cargando...</span>
            <span class="profile-community" id="userCommSide">Administrador</span>
        </div>
        <div class="profile-badge">Admin</div>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav">
        {menuItems.map(item => (
            <a href={item.path} class="nav-item" data-path={item.path}>
                <span class="nav-icon"><Fragment set:html={item.icon} /></span>
                <span class="nav-label">{item.label}</span>
            </a>
        ))}
    </nav>

    <!-- Footer -->
    <div class="sidebar-footer">
        <button id="logoutBtn" class="logout-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path fill-rule="evenodd" d="M7.5 3.75A1.5 1.5 0 006 5.25v13.5a1.5 1.5 0 001.5 1.5h6a1.5 1.5 0 001.5-1.5V15a.75.75 0 011.5 0v3.75a3 3 0 01-3 3h-6a3 3 0 01-3-3V5.25a3 3 0 013-3h6a3 3 0 013 3V9A.75.75 0 0115 9V5.25a1.5 1.5 0 00-1.5-1.5h-6zm10.72 4.72a.75.75 0 011.06 0l3 3a.75.75 0 010 1.06l-3 3a.75.75 0 11-1.06-1.06l1.72-1.72H9a.75.75 0 010-1.5h10.94l-1.72-1.72a.75.75 0 010-1.06z" clip-rule="evenodd"/>
            </svg>
            <span>Salir</span>
        </button>
    </div>
</aside>

<style>
    .admin-sidebar {
        width: var(--sidebar-width);
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        background: #0d1117;
        display: flex;
        flex-direction: column;
        z-index: 1000;
        overflow: hidden;
        transition: width 0.3s ease, transform 0.3s ease;
    }

    /* ── Collapsed State (Desktop Only) ────────── */
    @media (min-width: 1025px) {
        :global(.sidebar-collapsed) .admin-sidebar {
            width: 70px;
        }

        :global(.sidebar-collapsed) .brand-name,
        :global(.sidebar-collapsed) .profile-info,
        :global(.sidebar-collapsed) .profile-badge,
        :global(.sidebar-collapsed) .nav-label,
        :global(.sidebar-collapsed) .logout-btn span {
            display: none;
        }

        :global(.sidebar-collapsed) .sidebar-brand { justify-content: center; padding: 20px 0; }
        :global(.sidebar-collapsed) .collapse-btn { 
            position: absolute; 
            right: -12px; 
            top: 25px; 
            transform: rotate(180deg); 
            background: #007bff; 
            color: white; 
            border: 2px solid #007bff;
            z-index: 2000;
            width: 24px;
            height: 24px;
        }
        :global(.sidebar-collapsed) .collapse-btn:hover {
            background: #007bff;
            border-color: #007bff;
            color: white;
            box-shadow: 0 0 10px rgba(0, 123, 255, 0.5);
        }

        :global(.sidebar-collapsed) .admin-sidebar {
            overflow: visible;
        }
    :global(.sidebar-collapsed) .profile-card { 
        display: none; /* Ocultar card completa cuando está colapsado para mayor limpieza */
    }
        :global(.sidebar-collapsed) .nav-item { justify-content: center; padding: 12px 0; }
    }

    /* ── Mobile State ─────────────────────────── */
    @media (max-width: 1024px) {
        .admin-sidebar {
            transform: translateX(-100%);
            width: 260px; /* Always fixed width on mobile when open */
            box-shadow: 10px 0 30px rgba(0,0,0,0.5);
        }
        :global(.sidebar-open) .admin-sidebar {
            transform: translateX(0);
        }
        .collapse-btn { display: none; }
    }

    /* ── Brand ─────────────────────────────────── */
    .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 20px 16px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        position: relative;
        overflow: visible; /* Asegurar que el botón no se corte */
    }

    .brand-icon {
        width: 42px;
        height: 42px;
        background: #0d1117; /* Mismo color que el sidebar */
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .logo-white {
        width: 32px;
        height: 32px;
        filter: brightness(0) invert(1); /* Hace que el logo sea blanco */
    }

    .brand-name {
        font-size: 1.1rem;
        font-weight: 800;
        color: white;
        letter-spacing: -0.02em;
        flex: 1;
    }

    .collapse-btn {
        width: 22px;
        height: 22px;
        background: rgba(255,255,255,0.08);
        border: none;
        border-radius: 50%;
        color: rgba(255,255,255,0.5);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-shrink: 0;
    }
    .collapse-btn:hover { background: rgba(255,255,255,0.15); color: white; }

    /* ── Profile Card ──────────────────────────── */
    .profile-card {
        margin: 14px 12px;
        background: #007bff;
        border-radius: 12px;
        padding: 12px 14px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: flex-start;
    }

    .profile-avatar {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.25);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        color: white;
        grid-row: 1 / 3;
        letter-spacing: 0.5px;
        overflow: hidden;
    }
    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-info {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .profile-name {
        font-size: 0.88rem;
        font-weight: 700;
        color: white;
        line-height: 1.2;
    }

    .profile-community {
        font-size: 0.72rem;
        color: rgba(255,255,255,0.75);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .profile-badge {
        background: rgba(255,255,255,0.2);
        color: white;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        width: fit-content;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        margin-top: 2px;
    }

    /* ── Navigation ────────────────────────────── */
    .sidebar-nav {
        flex: 1;
        padding: 6px 10px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow-y: auto;
        scrollbar-width: none;
    }
    .sidebar-nav::-webkit-scrollbar { display: none; }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        color: #8b9ab4;
        text-decoration: none;
        border-radius: 8px;
        font-size: 0.855rem;
        font-weight: 500;
        transition: all 0.18s ease;
        cursor: pointer;
    }

    .nav-icon {
        width: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .nav-icon :global(svg) {
        width: 17px;
        height: 17px;
    }

    .nav-item:hover {
        color: #e2e8f0;
        background: rgba(255,255,255,0.06);
    }

    .nav-item.active {
        background: #007bff;
        color: white;
        font-weight: 600;
    }

    .nav-item.active .nav-icon :global(svg) {
        color: white;
    }

    /* ── Footer / Logout ───────────────────────── */
    .sidebar-footer {
        padding: 12px 10px 20px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .logout-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 9px 12px;
        background: transparent;
        border: none;
        color: #8b9ab4;
        cursor: pointer;
        border-radius: 8px;
        font-size: 0.855rem;
        font-weight: 500;
        transition: all 0.18s;
        font-family: inherit;
    }

    .logout-btn:hover {
        background: rgba(255,255,255,0.06);
        color: #f87171;
    }
</style>

<script>
    import { authManager as auth, AuthManager } from "../../utils/auth.js";

    document.addEventListener('DOMContentLoaded', async () => {
        // Populate profile name — siempre refrescar desde el servidor
        try {
            const cached = auth.getUser();
            const nameEl = document.getElementById('userNameSide');
            if (cached && nameEl) nameEl.textContent = cached.name_user || 'Admin';
            // Refrescar desde API
            const fresh = await AuthManager.fetch('/users/me').catch(() => null);
            if (fresh && nameEl) {
                nameEl.textContent = fresh.name_user || 'Admin';
                auth.setAuthData(auth.getToken(), { ...fresh, role: 'admin' });
            }
        } catch (e) {
            console.warn('Could not read user info in AdminSidebar:', e);
        }

        // Sincronizar cambios de perfil en tiempo real
        window.addEventListener('user-updated', (e: any) => {
            const fresh = e.detail;
            const nameEl = document.getElementById('userNameSide');
            if (fresh && nameEl) {
                nameEl.textContent = fresh.name_user || 'Admin';
            }
        });

        // Logout
        const logoutBtn = document.getElementById('logoutBtn');
        logoutBtn?.addEventListener('click', () => {
            try { auth.logout(); } catch (e) { console.warn('Logout failed', e); }
        });

        // Toggle Sidebar Event
        const collapseBtn = document.getElementById('collapseBtn');
        collapseBtn?.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('toggleAdminSidebar'));
        });

        // Mark active nav item - favoring exact match
        try {
            const currentPath = window.location.pathname.replace(/\/$/, "");
            const navItems = document.querySelectorAll('.nav-item');
            let exactMatchFound = false;

            navItems.forEach(link => {
                const linkPath = link.getAttribute('data-path')?.replace(/\/$/, "");
                if (linkPath === currentPath) {
                    link.classList.add('active');
                    exactMatchFound = true;
                }
            });

            if (!exactMatchFound) {
                navItems.forEach(link => {
                    const linkPath = link.getAttribute('data-path')?.replace(/\/$/, "");
                    if (linkPath && linkPath !== '/admin' && currentPath.startsWith(linkPath)) {
                        link.classList.add('active');
                    }
                });
            }
        } catch (e) {
            console.warn('Nav highlight failed:', e);
        }
    });
</script>
