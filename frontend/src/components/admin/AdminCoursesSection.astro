---
/* AdminCoursesSection.astro - Admin: ver y gestionar TODOS los cursos */
---

<div class="admin-courses-section">

    <!-- Pending approval (admin can also approve/reject) -->
    <div id="pendingSection" style="display:none">
        <div class="section-block-header">
            <h3 class="block-title">
                <i class="fas fa-hourglass-half text-warning"></i>
                Pendientes de aprobación
                <span class="count-pill" id="pendingCount">0</span>
            </h3>
        </div>
        <div id="pendingList" class="pending-list"></div>
    </div>

    <!-- All courses -->
    <div>
        <div class="toolbar d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
            <div class="input-group" style="max-width:320px">
                <span class="input-group-text bg-white border-end-0" style="border-radius:12px 0 0 12px;border-color:#e2e8f0">
                    <i class="fas fa-search text-muted" style="font-size:.85rem"></i>
                </span>
                <input type="text" class="form-control border-start-0" placeholder="Buscar curso o mentor..." id="courseSearch" style="border-radius:0 12px 12px 0;border-color:#e2e8f0;box-shadow:none;font-size:.88rem">
            </div>
            <div class="d-flex gap-2 align-items-center">
                <select id="statusFilter" class="form-select" style="max-width:180px;border-radius:12px;border-color:#e2e8f0;font-size:.88rem;box-shadow:none">
                    <option value="">Todos los estados</option>
                    <option value="pending">Pendiente</option>
                    <option value="approved">Aprobado</option>
                    <option value="draft">Borrador</option>
                    <option value="rejected">Rechazado</option>
                </select>
                <select id="specialtyFilter" class="form-select" style="max-width:200px;border-radius:12px;border-color:#e2e8f0;font-size:.88rem;box-shadow:none">
                    <option value="">Todas las especialidades</option>
                </select>
            </div>
        </div>

        <div class="courses-grid" id="coursesGrid">
            <div class="loading-state">
                <div class="spinner"></div>
                <span>Cargando cursos...</span>
            </div>
        </div>
    </div>
</div>

<style>
.admin-courses-section { display: flex; flex-direction: column; gap: 2rem; }

.section-block-header { margin-bottom: 14px; }
.block-title { font-size: 1rem; font-weight: 700; color: #1e293b; margin: 0; display: flex; align-items: center; gap: 8px; }
.count-pill { background: #fef3c7; color: #d97706; font-size: .7rem; font-weight: 800; padding: 2px 9px; border-radius: 20px; }

/* Pending list */
.pending-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 8px; }
.pending-card {
    background: #fff; border-radius: 12px; border: 1.5px solid #fde68a;
    padding: 16px 18px; display: flex; align-items: flex-start; gap: 14px;
}
.pc-info { flex: 1; min-width: 0; }
.pc-info h4 { margin: 0 0 3px; font-size: .92rem; font-weight: 700; color: #0f172a; }
.pc-info p  { margin: 0 0 6px; font-size: .78rem; color: #64748b;
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.pc-meta { display: flex; gap: 10px; flex-wrap: wrap; }
.pc-m { font-size: .72rem; color: #94a3b8; font-weight: 500; display: flex; align-items: center; gap: 3px; }
.pc-actions { display: flex; gap: 7px; flex-shrink: 0; align-self: center; }
.btn-approve { background: #22c55e; color: #fff; border: none; padding: 6px 14px; border-radius: 7px; font-weight: 700; font-size: .78rem; cursor: pointer; display: flex; align-items: center; gap: 5px; }
.btn-approve:hover { background: #16a34a; }
.btn-reject  { background: #fff; color: #ef4444; border: 1.5px solid #fca5a5; padding: 6px 14px; border-radius: 7px; font-weight: 700; font-size: .78rem; cursor: pointer; }
.btn-reject:hover { background: #fee2e2; }

/* Course grid */
.courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.25rem;
}

.course-card {
    background: white; border-radius: 16px; border: 1px solid #f1f5f9;
    overflow: hidden; display: flex; flex-direction: column;
    box-shadow: 0 2px 8px rgba(0,0,0,.03); transition: all .25s;
}
.course-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,.07); }

.cc-thumb {
    height: 140px; background: linear-gradient(135deg, #eff6ff, #f5f3ff);
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
}
.cc-thumb-icon { font-size: 2.5rem; color: #c7d2fe; }
.cc-thumb img  { width: 100%; height: 100%; object-fit: cover; }
.status-abs {
    position: absolute; top: 10px; left: 10px;
    font-size: .63rem; font-weight: 800; padding: 3px 9px;
    border-radius: 20px; text-transform: uppercase; letter-spacing: .03em;
}
.st-pending  { background: #fef3c7; color: #d97706; }
.st-approved { background: #dcfce7; color: #15803d; }
.st-rejected { background: #fee2e2; color: #dc2626; }
.st-draft    { background: #f1f5f9; color: #64748b; }

.cc-body { padding: 16px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
.cc-spec { font-size: .68rem; font-weight: 800; color: #6366f1; text-transform: uppercase; letter-spacing: .04em; }
.cc-title { font-size: 1rem; font-weight: 700; color: #1e293b; margin: 0; line-height: 1.3; }
.cc-desc  { font-size: .82rem; color: #64748b; margin: 0; line-height: 1.5;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.cc-mentor { font-size: .78rem; color: #94a3b8; display: flex; align-items: center; gap: 5px; margin-top: auto; }
.tech-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.tech-tag { background: #f1f5f9; color: #475569; padding: 2px 8px; border-radius: 5px; font-size: .72rem; font-weight: 600; }
.level-tag { font-size: .68rem; font-weight: 700; padding: 2px 8px; border-radius: 5px; text-transform: capitalize; }
.lv-basico    { background: #dcfce7; color: #15803d; }
.lv-intermedio { background: #fef3c7; color: #d97706; }
.lv-avanzado  { background: #fee2e2; color: #dc2626; }

.cc-footer {
    padding: 12px 16px; border-top: 1px solid #f8fafc;
    display: flex; justify-content: space-between; align-items: center;
}
.cc-mods { font-size: .78rem; color: #94a3b8; display: flex; align-items: center; gap: 4px; font-weight: 500; }
.cc-actions { display: flex; gap: 6px; }
.btn-ic {
    width: 30px; height: 30px; border-radius: 8px;
    border: 1px solid #e2e8f0; background: #fff; cursor: pointer;
    font-size: .72rem; color: #94a3b8;
    display: flex; align-items: center; justify-content: center; transition: all .2s;
}
.btn-ic:hover     { color: #3b82f6; border-color: #3b82f6; }
.btn-ic.del:hover { color: #ef4444; border-color: #ef4444; }
.btn-ic.approve:hover { color: #22c55e; border-color: #22c55e; }
.btn-ic.reject:hover  { color: #f59e0b; border-color: #f59e0b; }

/* Loading */
.loading-state {
    grid-column: 1/-1; display: flex; flex-direction: column;
    align-items: center; gap: 1rem; padding: 4rem; color: #94a3b8;
}
.spinner { width: 28px; height: 28px; border: 3px solid #f1f5f9; border-top-color: #0073ff; border-radius: 50%; animation: spin 1s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-state { grid-column: 1/-1; text-align: center; padding: 3rem; color: #94a3b8; font-size: .9rem; }

@media(max-width:768px) {
    .courses-grid { grid-template-columns: 1fr; }
    .pending-card { flex-direction: column; }
}
</style>

<script>
import { AuthManager } from "../../utils/auth.js";

let allCourses     = [];
let pendingCourses = [];

async function init() {
    try {
        const data = await AuthManager.fetch('/courses/all');
        allCourses     = Array.isArray(data) ? data : [];
        pendingCourses = allCourses.filter(c => c.status === 'pending');
        populateSpecialties();
        renderPending();
        renderGrid(allCourses);
    } catch(e) {
        document.getElementById('coursesGrid').innerHTML = '<div class="empty-state">Error al cargar cursos.</div>';
    }
}

function populateSpecialties() {
    const sel = document.getElementById('specialtyFilter');
    const specs = [...new Set(allCourses.map(c => c.specialty_name).filter(Boolean))].sort();
    specs.forEach(s => {
        const opt = document.createElement('option');
        opt.value = s; opt.textContent = s;
        sel.appendChild(opt);
    });
}

function renderPending() {
    const section = document.getElementById('pendingSection');
    const list    = document.getElementById('pendingList');
    const badge   = document.getElementById('pendingCount');
    badge.textContent = pendingCourses.length;
    if (!pendingCourses.length) { section.style.display = 'none'; return; }
    section.style.display = 'block';
    list.innerHTML = pendingCourses.map(c => `
    <div class="pending-card" id="pc-${c.id}">
        <div class="pc-info">
            <h4>${c.title}</h4>
            <p>${c.description || 'Sin descripción.'}</p>
            <div class="pc-meta">
                <span class="pc-m"><i class="fas fa-user-tie"></i> ${c.mentor_name || '—'}</span>
                <span class="pc-m"><i class="fas fa-layer-group"></i> ${(c.modules||[]).length} módulos</span>
                <span class="pc-m"><i class="fas fa-signal"></i> ${c.level || 'básico'}</span>
            </div>
        </div>
        <div class="pc-actions">
            <button class="btn-approve" onclick="adminApprove(${c.id})"><i class="fas fa-check"></i> Aprobar</button>
            <button class="btn-reject"  onclick="adminReject(${c.id})"><i class="fas fa-times"></i> Rechazar</button>
        </div>
    </div>`).join('');
}

window.adminApprove = async function(id) {
    if (!confirm('¿Aprobar este curso?')) return;
    const res = await AuthManager.fetch(`/courses/${id}/approve`, { method: 'PATCH' });
    if (res) {
        updateLocalStatus(id, 'approved');
        renderPending();
        applyFilters();
    }
};
window.adminReject = async function(id) {
    if (!confirm('¿Rechazar este curso?')) return;
    const res = await AuthManager.fetch(`/courses/${id}/reject`, { method: 'PATCH' });
    if (res) {
        updateLocalStatus(id, 'rejected');
        renderPending();
        applyFilters();
    }
};
window.adminDelete = async function(id) {
    if (!confirm('¿Eliminar este curso permanentemente?')) return;
    const res = await AuthManager.fetch(`/courses/${id}`, { method: 'DELETE' });
    if (res !== null) {
        allCourses     = allCourses.filter(c => c.id !== id);
        pendingCourses = pendingCourses.filter(c => c.id !== id);
        renderPending();
        applyFilters();
    }
};

function updateLocalStatus(id, status) {
    const c = allCourses.find(c => c.id === id);
    if (c) c.status = status;
    pendingCourses = allCourses.filter(c => c.status === 'pending');
}

function renderGrid(list) {
    const grid = document.getElementById('coursesGrid');
    if (!list.length) {
        grid.innerHTML = '<div class="empty-state">No hay cursos con los filtros actuales.</div>';
        return;
    }
    const stCls = { pending:'st-pending', approved:'st-approved', rejected:'st-rejected', draft:'st-draft' };
    const stLbl = { pending:'Pendiente', approved:'Aprobado', rejected:'Rechazado', draft:'Borrador' };
    const lvCls = { basico:'lv-basico', intermedio:'lv-intermedio', avanzado:'lv-avanzado' };

    grid.innerHTML = list.map(c => {
        const techs = (c.technologies || []).slice(0, 4).map(t => `<span class="tech-tag">${t}</span>`).join('');
        const status = c.status || 'pending';
        const isPending = status === 'pending';
        return `
        <div class="course-card">
            <div class="cc-thumb">
                ${c.thumbnail_url
                    ? `<img src="${c.thumbnail_url}" alt="${c.title}" loading="lazy">`
                    : `<i class="fas fa-book-open cc-thumb-icon"></i>`}
                <span class="status-abs ${stCls[status] || 'st-draft'}">${stLbl[status] || status}</span>
            </div>
            <div class="cc-body">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="cc-spec">${c.specialty_name || 'General'}</span>
                    <span class="level-tag ${lvCls[c.level] || 'lv-basico'}">${c.level || 'básico'}</span>
                </div>
                <h3 class="cc-title">${c.title}</h3>
                <p class="cc-desc">${c.description || 'Sin descripción.'}</p>
                ${techs ? `<div class="tech-tags">${techs}</div>` : ''}
                <div class="cc-mentor"><i class="fas fa-user-tie"></i> ${c.mentor_name || '—'}</div>
            </div>
            <div class="cc-footer">
                <span class="cc-mods"><i class="fas fa-layer-group"></i> ${(c.modules||[]).length} módulos</span>
                <div class="cc-actions">
                    ${isPending ? `
                    <button class="btn-ic approve" onclick="adminApprove(${c.id})" title="Aprobar"><i class="fas fa-check"></i></button>
                    <button class="btn-ic reject"  onclick="adminReject(${c.id})"  title="Rechazar"><i class="fas fa-times"></i></button>
                    ` : ''}
                    <button class="btn-ic del" onclick="adminDelete(${c.id})" title="Eliminar"><i class="fas fa-trash"></i></button>
                </div>
            </div>
        </div>`;
    }).join('');
}

function applyFilters() {
    const term    = (document.getElementById('courseSearch') as HTMLInputElement).value.toLowerCase();
    const status  = (document.getElementById('statusFilter')   as HTMLSelectElement).value;
    const spec    = (document.getElementById('specialtyFilter') as HTMLSelectElement).value;

    const filtered = allCourses.filter(c => {
        const matchTerm   = c.title.toLowerCase().includes(term) || (c.mentor_name || '').toLowerCase().includes(term);
        const matchStatus = !status || c.status === status;
        const matchSpec   = !spec   || c.specialty_name === spec;
        return matchTerm && matchStatus && matchSpec;
    });
    renderGrid(filtered);
}

document.getElementById('courseSearch').addEventListener('input', applyFilters);
document.getElementById('statusFilter').addEventListener('change', applyFilters);
document.getElementById('specialtyFilter').addEventListener('change', applyFilters);

init();
</script>
