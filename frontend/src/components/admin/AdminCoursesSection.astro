---
/* AdminCoursesSection.astro */
---

<div class="admin-courses-section">
    <!-- Toolbar: Búsqueda y Especialidad -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <!-- Buscador -->
        <div class="input-group" style="max-width: 320px;">
            <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px; border-color: #e2e8f0;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:18px;height:18px;color:#94a3b8;">
                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
                </svg>
            </span>
            <input type="text" class="form-control border-start-0" placeholder="Buscar curso o mentor..." id="courseSearch" style="border-radius: 0 12px 12px 0; border-color: #e2e8f0; box-shadow: none; font-size: 0.88rem;">
        </div>

        <!-- Filtro Especialidad -->
        <div class="input-group" style="max-width: 240px;">
            <select id="specialtyFilter" class="form-select" style="border-radius: 12px; border-color: #e2e8f0; font-size: 0.88rem; box-shadow: none; cursor: pointer;">
                <option value="">Todas las especialidades</option>
                <!-- Dinámico -->
            </select>
        </div>
    </div>

    <div class="courses-grid-premium" id="coursesGrid">
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Organizando currículo académico...</span>
        </div>
    </div>
</div>

<!-- Modal Structure Simplificada para UI -->
<div class="modal-backdrop" id="courseModal">
    <div class="modal-card">
        <h3>Gestionar Programa</h3>
        <p>Editor de cursos, módulos y recursos didácticos.</p>
        <button class="btn-close-modal" id="closeCourseModal">Volver al panel</button>
    </div>
</div>

<style>
    .admin-courses-section {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .section-top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-text h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1E293B;
        margin: 0;
    }

    .header-text p {
        font-size: 0.9rem;
        color: #94A3B8;
        margin: 0.2rem 0 0 0;
        font-weight: 500;
    }

    .header-actions { display: flex; gap: 1rem; }

    .btn-add-course {
        background: #0073ff;
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(0, 115, 255, 0.2);
    }

    .btn-secondary-action {
        background: white;
        color: #64748B;
        border: 1px solid #E2E8F0;
        padding: 0.75rem 1.25rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
    }

    /* FILTERS */
    .filter-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .search-input-wrap {
        position: relative;
        flex: 1;
        max-width: 450px;
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94A3B8;
    }

    .search-input-wrap input {
        width: 100%;
        padding: 0.85rem 1rem 0.85rem 2.8rem;
        border-radius: 12px;
        border: 1px solid #E2E8F0;
        background: white;
        font-size: 0.9rem;
        outline: none;
    }

    .quick-filters { display: flex; gap: 0.5rem; }
    .q-filter {
        padding: 0.5rem 1rem;
        border-radius: 10px;
        border: 1px solid #E2E8F0;
        background: white;
        color: #64748B;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
    }
    .q-filter.active { background: #F1F5F9; color: #0073ff; border-color: #0073ff; }

    /* GRID */
    .courses-grid-premium {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 1.5rem;
    }

    @media (max-width: 768px) {
        .admin-courses-section .input-group {
            max-width: 100% !important;
        }
        .courses-grid-premium {
            grid-template-columns: 1fr;
        }
        .course-card-premium {
            max-width: 100%;
        }
    }

    /* COURSE CARD */
    .course-card-premium {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
        border: 1px solid #F1F5F9;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
    }

    .course-card-premium:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.06);
    }

    .thumb-wrap {
        height: 180px;
        background: #F8FAFC;
        position: relative;
    }

    .thumb-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .premium-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: linear-gradient(135deg, #F59E0B, #D97706);
        color: white;
        padding: 0.35rem 0.75rem;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        box-shadow: 0 4px 8px rgba(217, 119, 6, 0.2);
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        flex: 1;
    }

    .course-type {
        font-size: 0.7rem;
        font-weight: 800;
        color: #6366F1;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .card-content h3 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #1E293B;
        margin: 0;
        line-height: 1.3;
    }

    .card-content p {
        font-size: 0.9rem;
        color: #64748B;
        margin: 0;
        line-height: 1.5;
    }

    .tech-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: auto;
    }

    .tech-tag {
        background: #F1F5F9;
        color: #475569;
        padding: 0.25rem 0.65rem;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .card-footer {
        padding: 1.25rem 1.5rem;
        border-top: 1px solid #F1F5F9;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .price-tag { font-weight: 800; color: #1E293B; font-size: 1.1rem; }
    .price-tag.free { color: #10B981; }

    .action-group { display: flex; gap: 0.5rem; }

    .btn-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1px solid #E2E8F0;
        background: white;
        color: #94A3B8;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .btn-circle:hover { color: #0073ff; border-color: #0073ff; }

    /* LOADING */
    .loading-state {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 4rem;
        color: #94A3B8;
        gap: 1rem;
    }

    .spinner {
        width: 32px;
        height: 32px;
        border: 3px solid #F1F5F9;
        border-top-color: #0073ff;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* MODAL */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 2000;
    }
    .modal-card {
        background: white;
        padding: 3rem;
        border-radius: 24px;
        max-width: 550px;
        width: 90%;
        text-align: center;
    }
    .btn-close-modal {
        background: #0073ff;
        color: white;
        border: none;
        padding: 0.85rem 2rem;
        border-radius: 12px;
        font-weight: 700;
        margin-top: 1.5rem;
        cursor: pointer;
    }
</style>

<script>
    import { AuthManager, authManager } from "../../utils/auth.js";
    const auth = authManager;

    let allCourses = [];

    async function fetchData() {
        try {
            const data = await AuthManager.fetch('/courses');
            allCourses = Array.isArray(data) ? data : [];

            // Mock if empty
            if (allCourses.length === 0) {
                allCourses = [
                    { title: 'Intro a la Web3 con Solidity', description: 'Fundamentos de smart contracts y dApps.', specialty_name: 'Blockchain', mentor_name: 'Diego Torres', price: 49.99, is_premium: true, image: 'https://images.unsplash.com/photo-1639762681485-074b7f938ba0?auto=format&fit=crop&q=80&w=400' },
                    { title: 'Arquitectura de Microservicios', description: 'Escalamiento de aplicaciones con Docker y K8s.', specialty_name: 'Back-end', mentor_name: 'Ana Martínez', price: 0, is_premium: false, image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc51?auto=format&fit=crop&q=80&w=400' },
                    { title: 'UX/UI Design System Pro', description: 'Crea sistemas de diseño escalables y modernos.', specialty_name: 'Design', mentor_name: 'Carlos Ruiz', price: 79.99, is_premium: true, image: 'https://images.unsplash.com/photo-1586717791821-3f44a563eb4c?auto=format&fit=crop&q=80&w=400' }
                ];
            }

            populateSpecialties(allCourses);
            renderCourses(allCourses);
        } catch (error) {
            console.error('Error fetching courses:', error);
        }
    }

    function populateSpecialties(courses) {
        const select = document.getElementById('specialtyFilter');
        if (!select) return;
        select.innerHTML = '<option value="">Todas las especialidades</option>';

        const specialties = [...new Set(courses.map(c => c.specialty_name).filter(Boolean))].sort();

        specialties.forEach(spec => {
            const option = document.createElement('option');
            option.value = spec;
            option.textContent = spec;
            select.appendChild(option);
        });
    }

    function renderCourses(list) {
        const grid = document.getElementById('coursesGrid');
        if (!grid) return;

        grid.innerHTML = list.map(c => `
            <div class="course-card-premium">
                <div class="thumb-wrap">
                    <img src="${c.image || 'https://via.placeholder.com/400x200'}" alt="${c.title}">
                    ${c.is_premium ? '<span class="premium-badge">PREMIUM</span>' : ''}
                </div>
                <div class="card-content">
                    <span class="course-type">${c.specialty_name || 'Especialidad'}</span>
                    <h3>${c.title}</h3>
                    <p>${c.description || 'Sin descripción disponible.'}</p>
                    <div class="tech-stack">
                        <span class="tech-tag">Next.js</span>
                        <span class="tech-tag">Tailwind</span>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="price-tag ${c.price === 0 ? 'free' : ''}">
                        ${c.price === 0 ? 'GRATIS' : `$${c.price}`}
                    </div>
                    <div class="action-group">
                        <button class="btn-circle"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" /><path fill-rule="evenodd" d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 0 1 0-1.113ZM17.25 12a5.25 5.25 0 1 1-10.5 0 5.25 5.25 0 0 1 10.5 0Z" clip-rule="evenodd" /></svg></button>
                        <button class="btn-circle"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712-12.15 12.15a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32L19.513 8.199Z" /></svg></button>
                        <button class="btn-circle"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5 0v8.25a.75.75 0 0 0 1.5 0v-8.25Zm2.25 0a.75.75 0 0 0-1.5 0v8.25a.75.75 0 0 0 1.5 0v-8.25Zm2.25 0a.75.75 0 1 0-1.5 0v8.25a.75.75 0 0 0 1.5 0v-8.25Z" clip-rule="evenodd" /></svg></button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    function applyFilters() {
        const searchEl = document.getElementById('courseSearch');
        const selectEl = document.getElementById('specialtyFilter');
        const term = (searchEl && searchEl.value) ? searchEl.value.toLowerCase() : '';
        const specialty = selectEl ? selectEl.value : '';

        const filtered = allCourses.filter(c => {
            const title = (c.title || '').toString().toLowerCase();
            const mentor = (c.mentor_name || '').toString().toLowerCase();
            const matchesSearch = title.includes(term) || mentor.includes(term);
            const matchesSpecialty = !specialty || c.specialty_name === specialty;
            return matchesSearch && matchesSpecialty;
        });

        renderCourses(filtered);
    }

    document.addEventListener('DOMContentLoaded', () => {
        const searchEl = document.getElementById('courseSearch');
        const selectEl = document.getElementById('specialtyFilter');
        searchEl?.addEventListener('input', applyFilters);
        selectEl?.addEventListener('change', applyFilters);
        fetchData();
    });
</script>

