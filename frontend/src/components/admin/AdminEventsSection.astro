    .btn-ghost:hover { background: #e2e8f0; }

    .btn-save { 
        background: var(--color-azure-radiant); 
        color: #fff; border: none; 
        padding: 10px 22px; border-radius: 10px; 
        font-weight: 700; font-size: .88rem; 
        cursor: pointer; display: flex; 
        align-items: center; gap: 7px;
        transition: all 0.2s;
    }
    .btn-save:hover { background: #0062cc; transform: translateY(-1px); }
    .btn-save:disabled { background: #94a3b8; cursor: not-allowed; transform: none; }

    .spinner { width: 28px; height: 28px; border: 3px solid #f1f5f9; border-top-color: var(--color-azure-radiant); border-radius: 50%; animation: spin 1s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-state { grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 4rem; color: #94a3b8; }

    :global(.btn-delete-event) { position: absolute; top: 12px; right: 12px; width: 32px; height: 32px; border-radius: 50%; background: #fee2e2; color: #ef4444; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; opacity: 0; transition: all 0.2s; }
    :global(.event-card-modern:hover .btn-delete-event) { opacity: 1; }
    :global(.btn-delete-event:hover) { background: #ef4444; color: white; transform: scale(1.1); }

    /* ══ Info Modal Styles ══ */
    .info-card { max-width: 550px; border-radius: 24px; overflow: hidden; position: relative; }
    .info-header-img { 
        width: 100%; 
        height: 280px; 
        position: relative; 
        background: #0e0f17; /* Fondo oscuro para resaltar la imagen */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    .info-header-img img { 
        max-width: 100%; 
        max-height: 100%; 
        object-fit: contain; 
        display: block;
        margin: auto;
        border-radius: 12px;
    }
    .info-header-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.3), transparent 40%); pointer-events: none; }
    .info-close { position: absolute; top: 18px; right: 18px; background: rgba(255,255,255,0.9); pointer-events: auto; }
    
    .info-body { padding: 30px; }
    .info-meta-top { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .info-date-text { font-size: 0.85rem; font-weight: 700; color: #64748b; }
    .info-title { font-size: 1.5rem; font-weight: 850; color: #0f172a; margin-bottom: 24px; line-height: 1.2; }
    
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    .info-item { display: flex; align-items: flex-start; gap: 12px; }
    .info-item.full-width { grid-column: 1 / -1; }
    
    .info-icon-box { min-width: 36px; height: 36px; background: #f0f7ff; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--color-azure-radiant); }
    .info-icon-box svg { width: 20px; height: 20px; }
    
    .info-text { display: flex; flex-direction: column; }
    .info-text label { font-size: 0.72rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; }
    .info-text span { font-size: 0.92rem; font-weight: 600; color: #334155; }
    .info-link { font-size: 0.92rem; font-weight: 700; color: var(--color-azure-radiant); text-decoration: none; word-break: break-all; }
    .info-link:hover { text-decoration: underline; }
    
    .info-description { background: #f8fafc; padding: 20px; border-radius: 16px; border: 1px solid #f1f5f9; }
    .info-description label { font-size: 0.72rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; margin-bottom: 8px; display: block; }
    .info-description p { font-size: 0.9rem; color: #475569; line-height: 1.6; margin: 0; white-space: pre-wrap; }
    
    .info-footer { padding: 18px 30px 24px; }

    .info-close-fixed {
        position: absolute; top: 16px; right: 16px;
        background: white; color: #475569;
