    /* ══ Lightbox Styles ══ */
    .lightbox-overlay {
        position: fixed; inset: 0;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(10px);
        display: none; align-items: center; justify-content: center;
        z-index: 4000; padding: 40px;
        opacity: 0; transition: opacity 0.3s ease;
    }
    .lightbox-overlay.open { display: flex; opacity: 1; }
    .lightbox-close {
        position: absolute; top: 30px; right: 30px;
        background: rgba(255,255,255,0.1); border: none;
        width: 44px; height: 44px; border-radius: 50%;
        color: white; cursor: pointer; display: flex;
        align-items: center; justify-content: center;
        transition: all 0.2s; z-index: 10;
        border: 1px solid rgba(255,255,255,0.2);
    }
    .lightbox-close:hover { background: rgba(255,255,255,0.2); transform: rotate(90deg); color: #ef4444; }
    .lightbox-content {
        max-width: 100%; max-height: 100%;
        display: flex; align-items: center; justify-content: center;
        transform: scale(0.95); transition: transform 0.3s ease;
    }
    .lightbox-overlay.open .lightbox-content { transform: scale(1); }
    .lightbox-content img {
        max-width: 90vw; max-height: 85vh;
        border-radius: 12px; box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        object-fit: contain;
    }
    .info-header-img { cursor: zoom-in; }

    /* ══ Skeletons ══ */
    .skeleton {
        background: linear-gradient(90deg, #f1f5f9 25%, #f8fafc 50%, #f1f5f9 75%);
        background-size: 200% 100%;
        animation: skeleton-loading 1.5s infinite;
    }
    @keyframes skeleton-loading {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
    .skeleton-card { height: 380px; border-radius: 20px; width: 100%; }

    :global(.event-card-img) {
        width: 100%; height: 160px; object-fit: cover;
        border-radius: 12px; margin-bottom: 0.5rem;
    }

    :global(.event-card-img) {
        width: 100%; height: 160px; object-fit: cover;
        border-radius: 12px; margin-bottom: 0.5rem;
    }
</style>

<script>
    import { AuthManager, authManager } from "../../utils/auth.js";

    /**
     * Optimiza URLs de Cloudinary inyectando parámetros de transformación.
     */
    function optimizeImageUrl(url, width = 600) {
        if (!url || typeof url !== 'string') return '';
        if (url.includes('cloudinary.com')) {
            const parts = url.split('/upload/');
            if (parts.length === 2) {
                return `${parts[0]}/upload/f_auto,q_auto,w_${width},c_fill/${parts[1]}`;
            }
        }
        return url;
    }

    let allEvents = [];
    let pendingEvents = [];
    let currentFilter = 'all';

    async function fetchData() {
        const grid = document.getElementById('eventsGrid');
        if (grid) {
            grid.innerHTML = Array.from({ length: 6 }).map(() => `
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="skeleton skeleton-card"></div>
                </div>
            `).join('');
        }

        try {
            const [eventsRes, pendingRes] = await Promise.all([
                AuthManager.fetch('/events/'),
                AuthManager.fetch('/events/pending').catch(() => [])
            ]);
            allEvents = Array.isArray(eventsRes) ? eventsRes : [];
            pendingEvents = Array.isArray(pendingRes) ? pendingRes : [];
            
            // Log para debug detallado
            console.log('Admin Events Data:', { 
                allApproved: allEvents.length, 
                pending: pendingEvents.length,
                pendingDetails: pendingEvents.map(e => ({ id: e.id, status: e.status, title: e.title }))
            });
            
            updatePendingBadge();
            applyFilters();
        } catch (error) {
            console.error('Error fetching events:', error);
        }
    }

    function updatePendingBadge() {
        const btn = document.getElementById('pendingFilterBtn');
        const badge = document.getElementById('pendingBadge');
        if (!btn || !badge) return;

        if (pendingEvents.length > 0) {
            btn.style.display = 'flex';
            badge.textContent = String(pendingEvents.length);
        } else {
            btn.style.display = 'none';
        }
    }

    function renderPendingList(list) {
        const grid = document.getElementById('eventsGrid');
        if (!grid) return;

        if (list.length === 0) {
            grid.innerHTML = '<div class="loading-state"><span>No hay eventos pendientes de revisión.</span></div>';
            return;
        }

        grid.innerHTML = list.map(e => {
            const dateObj = new Date(e.event_date + 'T00:00:00');
            const day = dateObj.getDate();
            const month = dateObj.toLocaleDateString('es', { month: 'short' }).toUpperCase();

            let typeRaw = `${e.event_type || ''} ${e.type_event || ''} ${e.location || ''}`.toLowerCase();
            let type = typeRaw.includes('presencial') ? 'presencial' : 'virtual';
            const typeLabel = type === 'virtual' ? 'Virtual' : 'Presencial';
            const badgeClass = type === 'virtual' ? 'badge-virtual' : 'badge-presencial';

            const optimizedImg = optimizeImageUrl(e.image_url, 600);
            const imgHtml = optimizedImg 
                ? `<img src="${optimizedImg}" class="event-card-img" alt="${e.title}" loading="lazy" onerror="this.style.display='none';" />` 
                : '';

            const currentUser = authManager.getUser() || {};
            const isCreator = Number(e.creator_id) === Number(currentUser.id);
            const isAdmin = currentUser.rol_id === 1;

            return `
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="event-card-modern" data-id="${e.id}" data-status="pending">
                        ${imgHtml}
                        <div class="card-header-flex">
                            <span class="modal-badge ${badgeClass}">${typeLabel}</span>
                            <div class="date-badge">
                                <span class="date-day">${day}</span>
                                <span class="date-month">${month}</span>
                            </div>
                        </div>
                        <div class="card-content">
                            <h3>${e.title}</h3>
                            <p class="card-desc">${e.description || 'Revisión pendiente...'}</p>
                            <div style="margin-top: 0.5rem;">
                                <span class="modal-badge" style="background: rgba(0, 115, 255, 0.05); color: var(--color-azure-radiant); display: inline-block;">${e.leader_name || e.community_name || 'Sin asignar'}</span>
                            </div>
                        </div>
                        <div class="card-footer-details">
                            <div class="footer-detail-item">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                                <span>${e.event_time || '18:30'}h</span>
                            </div>
                            <div class="footer-detail-item">
                                ${type === 'virtual' ? `
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" style="width: 14px; height: 14px;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
                                    </svg>
                                ` : `
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" style="width: 14px; height: 14px;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                                    </svg>
                                `}
                                <span>${e.location || 'Local'}</span>
                            </div>
                        </div>
                        <div class="modal-footer" style="padding-top: 1rem; border-top: 1px dashed #f1f5f9; display: flex; gap: 12px;">
                            ${(isCreator || isAdmin) ? `
                                <button class="btn-approve-adm" data-id="${e.id}">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" style="width: 14px; height: 14px;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                                    </svg>
                                    Aprobar
                                </button>
                                <button class="btn-reject-adm" data-id="${e.id}">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                                    </svg>
                                    Rechazar
                                </button>
                                ${isCreator ? `
                                    <button class="btn-edit-adm" data-id="${e.id}" style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0; padding: 6px 10px; border-radius: 8px; display: flex; align-items: center; gap: 5px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.2s;">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                        </svg>
                                        Editar
                                    </button>
                                ` : ''}
                            ` : `
                                <span style="font-size: 0.75rem; color: #94a3b8; font-weight: 600;">Esperando aprobación del Admin</span>
                            `}
                        </div>
                    </div>
                </div>
            `;
        }).join('');

        // Listeners for Approve/Reject
        grid.querySelectorAll('.btn-approve-adm').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const id = (e.currentTarget as HTMLElement).dataset.id;
                try {
                    await AuthManager.fetch(`/events/${id}/approve`, { method: 'PATCH' });
                    (window as any).Swal?.fire('Aprobado', 'El evento ha sido publicado.', 'success');
                    fetchData();
                } catch (err) {
                    alert('Error: ' + err.message);
                }
            });
        });

        grid.querySelectorAll('.btn-reject-adm').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const id = (e.currentTarget as HTMLElement).dataset.id;
                const result = await (window as any).Swal.fire({
                    title: '¿Rechazar evento?',
                    text: 'El líder será notificado.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, rechazar'
                });

                if (result.isConfirmed) {
                    try {
                        await AuthManager.fetch(`/events/${id}/reject`, { method: 'PATCH' });
                        fetchData();
                    } catch (err) {
                        alert('Error: ' + err.message);
                    }
                }
            });
        });
    }

    function applyFilters() {
        const searchTerm = (document.getElementById('eventSearch') as HTMLInputElement)?.value.toLowerCase() || '';
        const monthNames = ["enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];
        
        // Vista de Pendientes
        if (currentFilter === 'pending') {
            const filteredPending = pendingEvents.filter(ev => {
                const currentUser = authManager.getUser() || {};
                const dateObj = new Date(ev.event_date + 'T00:00:00');
                const monthName = monthNames[dateObj.getMonth()];
                
                const matchesSearch = 
                    ev.title.toLowerCase().includes(searchTerm) || 
                    (ev.location || '').toLowerCase().includes(searchTerm) ||
                    (ev.leader_name || '').toLowerCase().includes(searchTerm) ||
                    (ev.community_name || '').toLowerCase().includes(searchTerm) ||
                    monthName.includes(searchTerm);

                const matchesType = currentFilter !== 'mine' || Number(ev.creator_id) === Number(currentUser.id);

                return matchesSearch && matchesType;
            });
            renderPendingList(filteredPending);
            return;
        }

        // Vista de Aprobados (Filtros: Todos, Virtual, Presencial)
        const filtered = allEvents.filter(ev => {
            if (ev.status !== 'approved') return false;

            const dateObj = new Date(ev.event_date + 'T00:00:00');
            const monthName = monthNames[dateObj.getMonth()];

            const matchesSearch = 
                ev.title.toLowerCase().includes(searchTerm) || 
                (ev.location || '').toLowerCase().includes(searchTerm) ||
                (ev.leader_name || '').toLowerCase().includes(searchTerm) ||
                (ev.community_name || '').toLowerCase().includes(searchTerm) ||
                monthName.includes(searchTerm);
            
            let typeRaw = `${ev.event_type || ''} ${ev.type_event || ''} ${ev.location || ''}`.toLowerCase();
            let normalizedType = typeRaw.includes('presencial') ? 'presencial' : 'virtual';
            
            const currentUser = authManager.getUser() || {};
            const isMine = Number(ev.creator_id) === Number(currentUser.id);

            const matchesType = 
                currentFilter === 'all' || 
                (currentFilter === 'mine' && isMine) ||
                (currentFilter !== 'mine' && normalizedType === currentFilter);

            return matchesSearch && matchesType;
        });

        renderEvents(filtered);
    }

    function renderEvents(list) {
        const grid = document.getElementById('eventsGrid');
        if (!grid) return;

        if (list.length === 0) {
            grid.innerHTML = '<div class="loading-state"><span>No se encontraron eventos globales</span></div>';
            return;
        }

        grid.innerHTML = list.map(e => {
            const dateObj = new Date(e.event_date + 'T00:00:00');
            const day = dateObj.getDate();
            const month = dateObj.toLocaleString('es', { month: 'short' }).toUpperCase();
            
            let typeRaw = `${e.event_type || ''} ${e.type_event || ''} ${e.location || ''}`.toLowerCase();
            let type = typeRaw.includes('presencial') ? 'presencial' : 'virtual';
            
            const typeLabel = type === 'virtual' ? 'Virtual' : 'Presencial';
            const badgeClass = type === 'virtual' ? 'badge-virtual' : 'badge-presencial';
            const isVirtual = type === 'virtual';

            const optimizedImg = optimizeImageUrl(e.image_url, 600);
            const imgHtml = optimizedImg 
                ? `<img src="${optimizedImg}" class="event-card-img" alt="${e.title}" loading="lazy" onerror="this.style.display='none';" />` 
                : '';

            const currentUser = authManager.getUser() || {};
            const isCreator = Number(e.creator_id) === Number(currentUser.id);
            const isAdmin = currentUser.rol_id === 1;

            return `
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="event-card-modern" data-id="${e.id}" data-status="approved" style="position: relative;">
                        ${imgHtml}
                        ${(isCreator || isAdmin) ? `
                            <div class="card-actions-top" style="position: absolute; top: 12px; right: 12px; display: flex; gap: 8px; z-index: 10;">
                                ${isCreator ? `
                                    <button class="leader-action-btn edit-btn btn-edit-event" data-id="${e.id}" title="Editar evento" style="background: white; border: none; padding: 6px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); color: #64748b; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s;">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 16px; height: 16px;">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                        </svg>
                                    </button>
                                ` : ''}
                                <button class="leader-action-btn delete-btn btn-delete-event" data-id="${e.id}" title="Eliminar evento" style="background: white; border: none; padding: 6px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); color: #ef4444; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s;">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" style="width: 17px; height: 17px;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                    </svg>
                                </button>
                            </div>
                        ` : ''}
                        <div class="card-header-flex">
                            <span class="modal-badge ${badgeClass}">${typeLabel}</span>
                            <div class="date-badge">
                                <span class="date-day">${day}</span>
                                <span class="date-month">${month}</span>
                            </div>
                        </div>
                        <div class="card-content">
                            <h3>${e.title}</h3>
                            <p class="card-desc">${e.description || 'Evento global organizado por CTech.'}</p>
                            <div style="margin-top: 0.5rem;">
                                <span class="modal-badge" style="background: rgba(0, 115, 255, 0.05); color: var(--color-azure-radiant); display: inline-block;">${e.leader_name || e.community_name || 'Sin asignar'}</span>
                            </div>
                        </div>
                        <div class="card-footer-details">
                            <div class="footer-detail-item">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                                <span>${e.event_time || '18:30'}h</span>
                            </div>
                            <div class="footer-detail-item">
                                ${isVirtual ? `
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" style="width: 14px; height: 14px;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
                                    </svg>
                                ` : `
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" style="width: 14px; height: 14px;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                                    </svg>
                                `}
                                <span>${e.location || 'CTech Hub'}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }).join('');

        // Re-attach delete listeners
        document.querySelectorAll('.btn-delete-event').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const id = (e.currentTarget as HTMLElement).dataset.id;
                
                // Usar Swal de CalendarShared (inyectado globalmente en layout)
                const result = await (window as any).Swal.fire({
                    title: '¿Eliminar evento?',
                    text: 'Esta acción no se puede deshacer.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar'
                });

                if (result.isConfirmed) {
                    try {
                        await AuthManager.fetch(`/events/${id}`, { method: 'DELETE' });
                        (window as any).Swal?.fire('Eliminado', 'El evento ha sido borrado.', 'success') || alert('Evento eliminado.');
                        fetchData();
                    } catch (err) {
                        (window as any).Swal?.fire('Error', 'Hubo un fallo al eliminar el evento.', 'error') || alert('Error al eliminar.');
                    }
                }
            });
        });
    }

    // ── Lógica de Modal y Formulario ──────────────────────────────────────────
    const modal = document.getElementById('eventModal');
    const eventForm = document.getElementById('eventForm') as HTMLFormElement;
    let pendingImageFile = null;

    // Configuración de Imágenes
    function setupImageUpload() {
        const area = document.getElementById('imgUploadArea');
        const fileInput = document.getElementById('fImage') as HTMLInputElement;
        const placeholder = document.getElementById('imgPlaceholder');
        const preview = document.getElementById('imgPreview') as HTMLImageElement;
        const actions = document.getElementById('imgActions');
        const changeBtn = document.getElementById('btnChangeImg');
        const removeBtn = document.getElementById('btnRemoveImg');

        function showPreview(file) {
            const reader = new FileReader();
            reader.onload = e => {
                preview.src = e.target.result as string;
                preview.style.display = 'block';
                placeholder.style.display = 'none';
                actions.style.display = 'flex';
            };
            reader.readAsDataURL(file);
            pendingImageFile = file;
        }

        function clearImage() {
            pendingImageFile = null;
            if (fileInput) fileInput.value = '';
            preview.src = '';
            preview.style.display = 'none';
            placeholder.style.display = 'flex';
            actions.style.display = 'none';
            (document.getElementById('fImageUrl') as HTMLInputElement).value = '';
        }

        area?.addEventListener('click', e => {
            if ((e.target as HTMLElement).closest('.img-actions')) return;
            fileInput.click();
        });

        fileInput?.addEventListener('change', () => {
            const file = fileInput.files?.[0];
            if (file) showPreview(file);
        });

        changeBtn?.addEventListener('click', e => { e.stopPropagation(); fileInput.click(); });
        removeBtn?.addEventListener('click', e => { e.stopPropagation(); clearImage(); });

        return clearImage;
    }

    const clearImageFn = setupImageUpload();

    // Toggles y Ubicación Dinámica
    function updateLocationUI(type) {
        const label = document.getElementById('locationLabel');
        const iconContainer = document.getElementById('locationIcon');
        const input = document.getElementById('fLocation') as HTMLInputElement;
        const hint = document.getElementById('locationHint');

        if (type === 'virtual') {
            if (label) label.innerHTML = 'Link de la reunión <span class="req">*</span>';
            if (iconContainer) iconContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="fi-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>`;
            if (input) input.placeholder = 'https://meet.google.com/abc-xyz';
            if (hint) hint.textContent = 'Debe ser una URL válida (https://...)';
        } else {
            if (label) label.innerHTML = 'Ubicación física (Link de Maps) <span class="req">*</span>';
            if (iconContainer) iconContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="fi-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`;
            if (input) input.placeholder = 'https://goo.gl/maps/...';
            if (hint) hint.textContent = 'Ingresa el link de Google Maps para que los asistentes puedan llegar.';
        }
    }

    document.querySelectorAll('.type-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const val = btn.getAttribute('data-val');
            const fType = document.getElementById('fType') as HTMLInputElement;
            if (fType) fType.value = val;
            updateLocationUI(val);
        });
    });

    const openModal = (eventObj = null) => {
        if(modal) {
            modal.classList.add('open');
            const mTitle = document.getElementById('mTitle');
            const btnSubmit = document.getElementById('btnSubmit');
            const fId = document.getElementById('fId') as HTMLInputElement;
            const fTitle = document.getElementById('fTitle') as HTMLInputElement;
            const fDesc = document.getElementById('fDesc') as HTMLTextAreaElement;
            const fDate = document.getElementById('fDate') as HTMLInputElement;
            const fTime = document.getElementById('fTime') as HTMLInputElement;
            const fCapacity = document.getElementById('fCapacity') as HTMLInputElement;
            const fLocation = document.getElementById('fLocation') as HTMLInputElement;
            const fImageUrl = document.getElementById('fImageUrl') as HTMLInputElement;
            const fType = document.getElementById('fType') as HTMLInputElement;

            eventForm.reset();
            clearImageFn();

            if (eventObj) {
                if (mTitle) mTitle.textContent = 'Editar Evento';
                if (btnSubmit) btnSubmit.textContent = 'Guardar Cambios';
                if (fId) fId.value = eventObj.id;
                if (fTitle) fTitle.value = eventObj.title;
                if (fDesc) fDesc.value = eventObj.description || '';
                if (fDate) fDate.value = eventObj.event_date;
                if (fTime) fTime.value = eventObj.event_time || '';
                if (fCapacity) fCapacity.value = eventObj.capacity || '';
                if (fLocation) fLocation.value = eventObj.location || '';
                if (fImageUrl) {
                    fImageUrl.value = eventObj.image_url || '';
                    if (eventObj.image_url) {
                        const preview = document.getElementById('imgPreview') as HTMLImageElement;
                        const placeholder = document.getElementById('imgPlaceholder');
                        const actions = document.getElementById('imgActions');
                        if (preview) { preview.src = optimizeImageUrl(eventObj.image_url, 600); preview.style.display = 'block'; }
                        if (placeholder) placeholder.style.display = 'none';
                        if (actions) actions.style.display = 'flex';
                    }
                }
                
                const type = (eventObj.event_type || eventObj.type_event || 'virtual').toLowerCase();
                const currentType = type.includes('presencial') ? 'presencial' : 'virtual';
                if (fType) fType.value = currentType;
                
                document.querySelectorAll('.type-btn').forEach(b => {
                    b.classList.toggle('active', b.getAttribute('data-val') === currentType);
                });
                updateLocationUI(currentType);

                // Visibility
                document.querySelectorAll('input[name="visibility"]').forEach((r: HTMLInputElement) => {
                    r.checked = r.value === eventObj.visibility;
                });

            } else {
                if (mTitle) mTitle.textContent = 'Nuevo Evento Global';
                if (btnSubmit) btnSubmit.textContent = 'Crear Evento';
                if (fId) fId.value = '';
                
                // Restringir fechas pasadas solo para nuevos
                const dateInput = document.getElementById('fDate') as HTMLInputElement;
                if (dateInput) {
                    dateInput.min = new Date().toISOString().split('T')[0];
                }
                
                if (fType) fType.value = 'virtual';
                const typeBtnVirtual = document.querySelector('.type-btn[data-val="virtual"]');
                document.querySelectorAll('.type-btn').forEach(b => b.classList.toggle('active', b === typeBtnVirtual));
                updateLocationUI('virtual');

                document.querySelectorAll('input[name="visibility"]').forEach((r: HTMLInputElement) => {
                    r.checked = r.value === 'publico';
                });
            }
        }
    };

    const closeModal = () => { if(modal) modal.classList.remove('open'); };

    document.getElementById('openNewEventBtn')?.addEventListener('click', () => openModal());
    document.getElementById('btnCloseModal')?.addEventListener('click', closeModal);
    document.getElementById('closeEventModal')?.addEventListener('click', closeModal);

    // Cierre al hacer clic fuera
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });

    // Subida de imagen
    async function uploadImageIfNeeded() {
        if (!pendingImageFile) return null;
        const progress = document.getElementById('uploadProgress');
        const progressBar = document.getElementById('progressBar');
        const statusTxt = document.getElementById('uploadStatus');

        progress.style.display = 'flex';
        progressBar.style.width = '30%';
        statusTxt.textContent = 'Subiendo imagen...';

        const form = new FormData();
        form.append('file', pendingImageFile);

        try {
            const data = await AuthManager.fetch('/events/upload-image', {
                method: 'POST',
                body: form,
            });
            progressBar.style.width = '100%';
            statusTxt.textContent = '¡Imagen lista!';
            return data.url;
        } catch (e) {
            progress.style.display = 'none';
            throw e;
        }
    }

    // Submit del Formulario
    eventForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btnSave = document.getElementById('btnSubmit') as HTMLButtonElement;
        btnSave.disabled = true;
        btnSave.textContent = 'Procesando...';

        try {
            // 1. Subir imagen si existe
            const imageUrl = await uploadImageIfNeeded();
            if (imageUrl) {
                (document.getElementById('fImageUrl') as HTMLInputElement).value = imageUrl;
            }

            // 2. Recopilar datos
            const formData = new FormData(eventForm);
            const jsonData: any = Object.fromEntries(formData.entries());

            // Asegurar que image_url se tome del campo oculto si no se acaba de subir una nueva
            const fImageUrlInput = document.getElementById('fImageUrl') as HTMLInputElement;
            if (fImageUrlInput.value) {
                jsonData.image_url = fImageUrlInput.value;
            } else {
                jsonData.image_url = null; // Enviar null si no hay imagen
            }

            // 3. Conversión de tipos críticos
            if (jsonData.capacity) jsonData.capacity = Number(jsonData.capacity);
            if (jsonData.community_id) jsonData.community_id = Number(jsonData.community_id);
            if (jsonData.id) delete jsonData.id; // No enviar ID en el body

            // 4. Enviar a API
            const id = (document.getElementById('fId') as HTMLInputElement).value;
            const method = id ? 'PUT' : 'POST';
            const url = id ? `/events/${id}` : '/events/';

            console.log('Sending data:', jsonData);

            await AuthManager.fetch(url, {
                method: method,
                body: JSON.stringify(jsonData)
            });

            (window as any).Swal?.fire({
                title: id ? '¡Evento Actualizado!' : '¡Evento Creado!',
                text: id ? 'Los cambios han sido guardados.' : 'La actividad global ha sido publicada con éxito.',
                icon: 'success',
                confirmButtonColor: '#0073ff'
            }) || alert(id ? 'Evento actualizado.' : 'Evento creado.');

            closeModal();
            fetchData();
        } catch (err) {
            console.error('Error al crear evento:', err);
            (window as any).Swal?.fire('Error', 'No se pudo programar el evento: ' + err.message, 'error');
        } finally {
            btnSave.disabled = false;
            btnSave.textContent = 'Crear Evento';
            document.getElementById('uploadProgress').style.display = 'none';
        }
    });

    document.getElementById('eventSearch')?.addEventListener('input', applyFilters);
    document.querySelectorAll('.seg-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.seg-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentFilter = btn.getAttribute('data-filter') || 'all';
            applyFilters();
        });
    });

    // ══ Lógica de Ficha Informativa ══
    const infoModal = document.getElementById('infoModal');

    function closeInfoModal() {
        infoModal?.classList.remove('open');
    }

    function openInfoSheet(eventObj) {
        if (!eventObj) return;

        const titleEl = document.getElementById('infoTitle');
        const descEl = document.getElementById('infoDesc');
        const imgEl = document.getElementById('infoImg') as HTMLImageElement;
        const badgeEl = document.getElementById('infoBadge');
        const dateEl = document.getElementById('infoDateFull');
        const timeEl = document.getElementById('infoTime');
        const organizerEl = document.getElementById('infoOrganizer');
        const locationLink = document.getElementById('infoLocationLink') as HTMLAnchorElement;
        const locationLabel = document.getElementById('infoLocationLabel');
        const locIconBox = document.getElementById('infoLocationIcon');

        const heroEl = document.getElementById('infoHero');
        if (titleEl) titleEl.textContent = eventObj.title;
        if (descEl) descEl.textContent = eventObj.description || 'Sin descripción disponible.';

        if (imgEl && heroEl) {
            if (eventObj.image_url) {
                // Para el modal usamos una calidad mayor (1200px)
                imgEl.src = optimizeImageUrl(eventObj.image_url, 1200);
                heroEl.style.display = 'block';
            } else {
                imgEl.src = '';
                heroEl.style.display = 'none';
            }
        }
        
        // Tipo / Badge
        const type = (eventObj.event_type || eventObj.type_event || '').toLowerCase();
        const isVirtual = type.includes('virtual') || !type.includes('presencial');
        
        if (badgeEl) {
            badgeEl.className = `modal-badge ${isVirtual ? 'badge-virtual' : 'badge-presencial'}`;
            badgeEl.textContent = isVirtual ? 'VIRTUAL' : 'PRESENCIAL';
        }

        // Fecha Formateada
        const dateObj = new Date(eventObj.event_date + 'T00:00:00');
        const monthNames = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
        if (dateEl) dateEl.textContent = `${dateObj.getDate()} de ${monthNames[dateObj.getMonth()]} de ${dateObj.getFullYear()}`;
        
        if (timeEl) timeEl.textContent = eventObj.event_time || '--:--';
        if (organizerEl) organizerEl.textContent = eventObj.leader_name || eventObj.community_name || 'Admin CTech';

        // Ubicación / Link
        if (locationLabel) locationLabel.textContent = isVirtual ? 'Link de la reunión' : 'Ubicación / Punto de encuentro';
        if (locationLink) {
            const locText = eventObj.location || (isVirtual ? 'No hay link' : 'No hay ubicación');
            locationLink.textContent = locText;
            
            // Si es una URL, hacerla clicable siempre, sin importar si es virtual o presencial
            if (locText.startsWith('http')) {
                locationLink.href = locText;
                locationLink.setAttribute('target', '_blank');
                locationLink.style.textDecoration = 'underline';
            } else {
                locationLink.href = '#';
                locationLink.removeAttribute('target');
                locationLink.style.textDecoration = 'none';
            }
        }

        if (locIconBox) {
            locIconBox.innerHTML = isVirtual ? 
                `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 20px; height: 20px;"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>` :
                `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 20px; height: 20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`;
        }

        infoModal?.classList.add('open');
    }

    // Delegación de clics en la grid
    document.getElementById('eventsGrid')?.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const card = target.closest('.event-card-modern') as HTMLElement;
        if (!card) return;

        const isActionBtn = target.closest('.btn-delete-event, .btn-approve-adm, .btn-reject-adm, .btn-edit-event, .btn-edit-adm');
        if (isActionBtn) {
            if (target.closest('.btn-edit-event, .btn-edit-adm')) {
                const eventId = card.getAttribute('data-id');
                const status = card.getAttribute('data-status');
                const list = status === 'pending' ? pendingEvents : allEvents;
                const eventObj = list.find(ev => String(ev.id) === eventId);
                if (eventObj) openModal(eventObj);
            }
            return;
        }

        const eventId = card.getAttribute('data-id');
        const status = card.getAttribute('data-status');
        const isPending = status === 'pending';
        
        const eventObj = isPending ? 
            pendingEvents.find(ev => String(ev.id) === eventId) : 
            allEvents.find(ev => String(ev.id) === eventId);
        
        if (eventObj) openInfoSheet(eventObj);
    });

    document.getElementById('btnCloseInfo')?.addEventListener('click', closeInfoModal);
    document.getElementById('btnExitInfo')?.addEventListener('click', closeInfoModal);
    infoModal?.addEventListener('click', (e) => {
        if (e.target === infoModal) closeInfoModal();
    });

    // ══ Lógica de Lightbox ══
    const lightbox = document.getElementById('imageLightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
    const infoImg = document.getElementById('infoImg') as HTMLImageElement;

    function openLightbox() {
        if (!infoImg.src) return;
        lightboxImg.src = infoImg.src;
        lightbox?.classList.add('open');
        document.body.style.overflow = 'hidden'; // Evitar scroll
    }

    function closeLightbox() {
        lightbox?.classList.remove('open');
        document.body.style.overflow = '';
    }

    infoImg?.addEventListener('click', openLightbox);
    document.getElementById('btnCloseLightbox')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => {
        if (e.target === lightbox || (e.target as HTMLElement).closest('.lightbox-content')) {
            // Si el click es en el fondo o en la imagen (para cerrar opcionalmente, o solo fondo)
            if (e.target === lightbox) closeLightbox();
        }
    });

    fetchData();
</script>

