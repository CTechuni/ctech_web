---
// Astro component script (if needed)
---

<div class="cards-container">
    <div class="card card-visitor">
        <div class="card-header">
            <h3><span class="icon-wrap" aria-hidden="true">🌐</span> Visitante</h3>
            <span class="badge free">Gratis</span>
        </div>
        <p class="card-note">Explora clases y eventos públicos</p>
        <ul>
            <li><span class="check" aria-hidden="true">✓</span> Vista de cursos públicos</li>
            <li><span class="check" aria-hidden="true">✓</span> Eventos comunitarios abiertos</li>
            <li><span class="check" aria-hidden="true">✓</span> Perfiles de expertos</li>
            <li><span class="check" aria-hidden="true">✓</span> Directorio de comunidades</li>
        </ul>
        <!-- Enlace eliminado por requerimiento -->
    </div>
    <div class="card card-premium">
        <div class="card-header">
            <h3><span class="icon-wrap" aria-hidden="true">★</span> Miembro CTech</h3>
            <span class="badge premium">Premium</span>
        </div>
        <p class="card-note">Acceso total a asesorías y material avanzado</p>
        <ul>
            <li><span class="check" aria-hidden="true">✓</span> Rutas de aprendizaje personalizadas</li>
            <li><span class="check" aria-hidden="true">✓</span> Sesiones 1-a-1 con expertos</li>
            <li><span class="check" aria-hidden="true">✓</span> Material avanzado y PDFs</li>
            <li><span class="check" aria-hidden="true">✓</span> Acceso a comunidades privadas</li>
            <li><span class="check" aria-hidden="true">✓</span> Certificaciones de compleción</li>
            <li><span class="check" aria-hidden="true">✓</span> Eventos exclusivos y hackathons</li>
        </ul>
        <button type="button" class="card-btn premium" onclick="openModal('signupModal')">Unirse con código de invitación</button>
    </div>
</div>

<style>
    .cards-container {
        display: flex;
        justify-content: center;
        align-items: stretch;
        gap: 2rem;
        max-width: 1000px;
        margin: 0 auto;
        flex-wrap: wrap;
    }

    .card {
        background: #f8fafc;
        color: #1e293b;
        padding: 2rem;
        border-radius: 16px;
        border: none;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        flex: 1;
        min-width: 280px;
        max-width: 420px;
        text-align: left;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        display: flex;
        flex-direction: column;
    }

    .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
    }

    .card-header h3 {
        font-size: 1.25rem;
        margin: 0;
        color: #1e293b;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .icon-wrap { font-size: 1.1rem; opacity: 0.9; }
    .badge {
        padding: 0.2rem 0.6rem;
        border-radius: 9999px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
    }
    .badge.free { background: #e2e8f0; color: #64748b; }
    .badge.premium { background: var(--color-azure-radiant); color: #fff; }

    .card-note {
        font-size: 1rem;
        font-weight: 600;
        color: #1e293b;
        margin: 0 0 1rem 0;
        line-height: 1.3;
    }

    .card ul {
        list-style: none;
        flex-grow: 1;
        margin: 0 0 1.5rem 0;
        padding: 0;
    }
    .card li {
        padding: 0.35rem 0;
        color: #475569;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .check {
        color: var(--color-azure-radiant);
        font-weight: 700;
        font-size: 0.9rem;
    }

    .card-link.visitor {
        display: inline-block;
        color: var(--color-azure-radiant);
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: opacity 0.2s;
    }
    .card-link.visitor:hover { opacity: 0.85; text-decoration: underline; }

    .card-btn.premium {
        display: inline-block;
        padding: 0.65rem 1.25rem;
        border-radius: 9999px;
        background: var(--color-azure-radiant);
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        text-align: center;
        transition: background 0.2s, transform 0.2s;
        border: none;
        cursor: pointer;
        width: 100%;
    }
    .card-btn.premium:hover { background: #005ceb; transform: translateY(-2px); }

    

    /* RESPONSIVE */
    @media (max-width: 1200px) {
        .cards-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 1.5rem;
            margin: 0 auto;
            flex-wrap: wrap;
        }

        .card {
            flex: 1; /* Asegurar mismo tamaño */
            min-width: 320px;
        }
    }

    @media (max-width: 768px) {
    .cards-container {
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    .card {
        width: 100%;
        max-width: 450px;
        min-width: 0;
    }
}
    @media (max-width: 480px) {
        .cards-container {
            max-width: 800px;
            gap: 1.5rem;
        }

        .card {
            padding: 0.7rem 1.5rem;
            border-radius: 10px;
        }

        .card h3 {
            font-size: 1.3rem;
            margin: 0.5rem;
        }

        .card ul {
            list-style: none;
            text-align: left;
            padding: 1rem;
            margin: 0;
        }

        .card p,
        .card li {
            font-size: 0.85rem;
        }
    }
</style>