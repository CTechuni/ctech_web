---

---

<section class="comunidades" id="comunidades">
    <h2>Nuestras Comunidades</h2>
    <p class="comunidades-sub">+6 comunidades activas con más de 500 miembros</p>
    <div class="comunidades-grid" id="comunidadesGrid">
        <!-- Renderizado dinámico vía JS -->
        <p class="loading-msg">Cargando comunidades...</p>
    </div>
</section>

<style>
    .comunidades {
        width: 100%;
        overflow: hidden;
        padding: 4rem 1rem 5rem;
        position: relative;
        background: #fff;
        text-align: center;
    }
    .comunidades h2 {
        font-size: 2.25rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        color: #0f172a;
        letter-spacing: -0.02em;
    }
    .comunidades-sub {
        color: #64748b;
        margin-bottom: 3rem;
        font-size: 1.1rem;
    }

    .comunidades-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 3rem; /* Más espacio entre logos */
        max-width: 1100px;
        margin: 0 auto;
        justify-content: center;
        align-items: flex-start;
    }

    /* Selectores :global para elementos inyectados por JS */
    .comunidades-grid :global(.comunidad-item) {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.85rem;
        text-align: center;
        width: 130px; /* Más ancho para que el nombre quepa mejor */
        transition: transform 0.2s ease;
    }

    .comunidades-grid :global(.comunidad-item:hover) {
        transform: translateY(-5px);
    }

    .comunidades-grid :global(.comunidad-icon) {
        width: 70px; /* Tamaño pequeño y fijo */
        height: 70px;
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        border: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px;
        overflow: hidden;
    }

    .comunidades-grid :global(.comunidad-icon img) {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    .comunidades-grid :global(.comunidad-name) {
        font-size: 0.8rem;
        font-weight: 600;
        color: #334155;
        line-height: 1.3;
        width: 100%;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .loading-msg {
        width: 100%;
        color: #94a3b8;
        font-style: italic;
    }

    @media (max-width: 768px) {
        .comunidades { padding: 3rem 1rem; }
        .comunidades-grid { gap: 2rem; }
        .comunidades-grid :global(.comunidad-item) { width: 110px; }
        .comunidades-grid :global(.comunidad-icon) { width: 60px; height: 60px; }
    }
</style>

<script>
    import { API_CONFIG, buildApiUrl } from '../../config/api.js';

    async function loadComunidades() {
        const grid = document.getElementById('comunidadesGrid');
        if (!grid) return;

        try {
            const url = buildApiUrl(API_CONFIG.COMMUNITIES.WITH_LOGO);
            const response = await fetch(url);
            if (!response.ok) throw new Error(`Error ${response.status}: ${response.statusText}`);
            
            /** @type {{logo_url?: string, name_community?: string}[]} */
            const communities = await response.json();
            
            if (!communities || communities.length === 0) {
                grid.innerHTML = '<p class="loading-msg">Próximamente más comunidades...</p>';
                return;
            }

            // Build nodes instead of assigning innerHTML to avoid XSS and handle missing data
            grid.innerHTML = '';
            communities.forEach(c => {
                const item = document.createElement('div');
                item.className = 'comunidad-item';

                const icon = document.createElement('div');
                icon.className = 'comunidad-icon';

                if (c.logo_url) {
                    const img = document.createElement('img');
                    img.loading = 'lazy';
                    img.alt = c.name_community || 'Comunidad';
                    img.src = c.logo_url;
                    icon.appendChild(img);
                } else {
                    const initials = document.createElement('span');
                    initials.className = 'comunidad-name'; // Reusing name style or similar
                    initials.textContent = c.name_community ? c.name_community.substring(0, 2).toUpperCase() : 'CT';
                    initials.style.fontSize = '1.2rem';
                    initials.style.fontWeight = '800';
                    initials.style.color = '#0073ff';
                    icon.appendChild(initials);
                    icon.style.backgroundColor = '#f0f7ff';
                }

                const name = document.createElement('span');
                name.className = 'comunidad-name';
                name.textContent = c.name_community || 'Sin nombre';

                item.appendChild(icon);
                item.appendChild(name);
                grid.appendChild(item);
            });

        } catch (err) {
            console.error(err);
            grid.innerHTML = '<p class="loading-msg">Error al cargar comunidades</p>';
        }
    }

    document.addEventListener('DOMContentLoaded', loadComunidades);
</script>
